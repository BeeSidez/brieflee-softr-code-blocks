}

// ─── Eyebrow (copied verbatim from hero) ─────────────────────────────
function Eyebrow({ children }) {
  return (
    <div
      style={{
        display: "inline-flex",
        alignItems: "center",
        gap: 10,
        padding: "10px 18px",
        background: "rgba(135,156,247,0.16)",
        color: NAVY,
        fontSize: 14,
        fontWeight: 700,
        letterSpacing: "0.06em",
        textTransform: "uppercase",
        borderRadius: 999,
        width: "fit-content",
      }}
    >
      <span style={{ width: 8, height: 8, borderRadius: "50%", background: PERI, boxShadow: `0 0 0 3px ${PERI}33` }} />
      {children}
    </div>
  );
}

// ─── Before card ─────────────────────────────────────────────────────
function BeforeCard() {
  return (
    <div className="ba-card before-card">
      <div className="card-head">
        <div className="card-title">Before <span className="dots">…</span></div>
        <div className="card-sub">Group chats, expired links and constant back-and-forth.</div>
      </div>
      <div className="pile">
        {FALLING.map((item, i) => (
          <FallingItem key={i} item={item} index={i} />
        ))}
      </div>
    </div>
  );
}

function FallingItem({ item, index }) {
  const animName = `bl-drop-${index}`;
  const finalRot = `${item.finalRot}deg`;
  const startRot = `${item.finalRot - 22}deg`;
  const overshootRot = `${item.finalRot + 5}deg`;
  return (
    <>
      <style>{`
        @keyframes ${animName} {
          0%   { transform: translateY(-360px) rotate(${startRot}); opacity: 0; }
          22%  { opacity: 1; }
          70%  { transform: translateY(0)       rotate(${finalRot}); }
          80%  { transform: translateY(-18px)   rotate(${overshootRot}); }
          90%  { transform: translateY(0)       rotate(${finalRot}); }
          96%  { transform: translateY(-5px)    rotate(${overshootRot}); }
          100% { transform: translateY(0)       rotate(${finalRot}); }
        }
      `}</style>
      <div
        className={`falling-item ${item.type}`}
        style={{
          left: item.finalLeft,
          bottom: item.finalBottom,
          animation: `${animName} 1.4s ${item.delay}s cubic-bezier(.36,.07,.32,1) both`,
        }}
      >
        {renderItem(item)}
      </div>
    </>
  );
}

function renderItem(item) {
  if (item.type === "app") {
    return (
      <div className="app-tile bl-glass" style={{ width: item.size, height: item.size }}>
        <img src={item.src} alt="" draggable={false} style={{ width: item.size * 0.6, height: item.size * 0.6 }} />
      </div>
    );
  }
  if (item.type === "rec") {
    return (
      <div className="rec-pill bl-glass">
        <span className="rec-dot" />
        REC
      </div>
    );
  }
  if (item.type === "folder") {
    return (
      <div className="folder-card bl-glass">
        <div className="folder-icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#fff" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <span>{item.label}</span>
      </div>
    );
  }
  if (item.type === "comment") {
    return (
      <div className="comment-pill bl-glass">
        <img src={item.avatar} alt="" draggable={false} className="comment-avatar" />
        <span>{item.label}</span>
      </div>
    );
  }
  return (
    <div className="text-pill bl-glass">
      <PillIcon name={item.icon} />
      <span>{item.label}</span>
    </div>
  );
}

function PillIcon({ name }) {
  const common = { width: 14, height: 14, viewBox: "0 0 24 24", fill: "none", stroke: NAVY, strokeWidth: 2.2, strokeLinecap: "round", strokeLinejoin: "round" };
  if (name === "crop") return (
    <svg {...common}><path d="M6 2v14a2 2 0 0 0 2 2h14"/><path d="M18 22V8a2 2 0 0 0-2-2H2"/></svg>
  );
  if (name === "play") return (
    <svg {...common} fill={PERI} stroke="none"><path d="M8 5v14l11-7z"/></svg>
  );
  if (name === "infinity") return (
    <svg {...common}><path d="M18.178 8c5.096 0 5.096 8 0 8-5.095 0-7.133-8-12.7-8-4.7 0-4.7 8 0 8 5.567 0 7.605-8 12.7-8z"/></svg>
  );
  if (name === "broken") return (
    <svg {...common}><path d="M9 17H7A5 5 0 0 1 7 7h2"/><path d="M15 7h2a5 5 0 0 1 4 8"/><line x1="8" y1="12" x2="12" y2="12"/><line x1="2" y1="2" x2="22" y2="22"/></svg>
  );
  return null;
}

// ─── After card ──────────────────────────────────────────────────────
function AfterCard() {
  return (
    <div className="ba-card after-card">
      <div className="card-head">
        <div className="card-title">After Brieflee</div>
        <div className="card-sub">Instant quality scores, specific feedback, every video reviewed.</div>
      </div>
      <div className="portrait-zone">
        <img
          src={PORTRAIT_SRC}
          alt="Creator on camera"
          className="portrait"
          draggable={false}
        />
        {PILLS_LEFT.map((p, i) => <FloatingPill key={`l-${i}`} pill={p} />)}
        {PILLS_RIGHT.map((p, i) => <FloatingPill key={`r-${i}`} pill={p} />)}
      </div>
    </div>
  );
}

function FloatingPill({ pill }) {
  const okBg = pill.ok ? "#dcfce7" : "#fee2e2";
  const okFg = pill.ok ? "#166534" : "#991b1b";
  return (
    <div
      className="float-pill bl-glass"
      style={{
        "--base-left":     pill.base.left     ?? "auto",
        "--base-right":    pill.base.right    ?? "auto",
        "--base-top":      pill.base.top      ?? "auto",
        "--base-bottom":   pill.base.bottom   ?? "auto",
        "--spread-left":   pill.spread.left   ?? "auto",
        "--spread-right":  pill.spread.right  ?? "auto",
        "--spread-top":    pill.spread.top    ?? "auto",
        "--spread-bottom": pill.spread.bottom ?? "auto",
      }}
    >
      <div
        style={{
          width: 20, height: 20, borderRadius: 6,
          background: okBg, color: okFg,
          display: "flex", alignItems: "center", justifyContent: "center",
          flexShrink: 0,
        }}
      >
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3.5" strokeLinecap="round" strokeLinejoin="round">
          {pill.ok
            ? <polyline points="20 6 9 17 4 12" />
            : <path d="M18 6L6 18M6 6l12 12" />}
        </svg>
      </div>
      <div>
        <div style={{ fontSize: 8, color: NAVY, opacity: 0.55, fontWeight: 800, letterSpacing: "0.08em", textTransform: "uppercase" }}>
          {pill.l}
        </div>
        <div style={{ fontSize: 13, color: NAVY, fontWeight: 700, letterSpacing: "-0.005em", lineHeight: 1.15 }}>
          {pill.v}
        </div>
      </div>
    </div>
  );
}

// ─── Keyframes + shared CSS ──────────────────────────────────────────
function Keyframes() {
  return (
    <style>{`
      /* ─── Card outer ─────────────────────────────────────────── */
      .ba-card {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1.05;
        background: transparent;
        border: 1px solid rgba(135,156,247,0.20);
        border-radius: 28px;
        box-shadow:
          0 1px 0 0 rgba(255,255,255,0.95) inset,
          0 12px 32px -16px rgba(0,19,100,0.06);
        overflow: hidden;
      }
      .card-head {
        position: absolute;
        top: 28px; left: 28px; right: 28px;
        z-index: 5;
      }
      .card-title {
        font-size: clamp(20px, 2.4vw, 26px);
        font-weight: 700;
        color: #001364;
        letter-spacing: -0.015em;
        line-height: 1.1;
      }
      .card-title .dots { color: #001364; opacity: 0.5; margin-left: 2px; }
      .card-sub {
        margin-top: 6px;
        font-size: clamp(13px, 1.4vw, 15px);
        color: #001364;
