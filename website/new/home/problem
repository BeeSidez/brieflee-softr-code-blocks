      /* ─── Apple Liquid Glass (same recipe as hero floating chips) ─ */
      .bl-glass {
        background: linear-gradient(135deg,
          rgba(255,255,255,0.62) 0%,
          rgba(244,246,255,0.42) 55%,
          rgba(236,240,255,0.34) 100%);
        -webkit-backdrop-filter: blur(28px) saturate(220%);
        backdrop-filter: blur(28px) saturate(220%);
        border: 1px solid rgba(255,255,255,0.55);
        box-shadow:
          0 1px 0 0 rgba(255,255,255,1)    inset,
          1px 0 0 0 rgba(255,255,255,0.6)  inset,
          0 -1px 0 0 rgba(0,19,100,0.10)   inset,
          -1px 0 0 0 rgba(0,19,100,0.05)   inset,
          0 12px 32px -10px rgba(0,19,100,0.18),
          0 4px 10px -4px rgba(0,19,100,0.08);
      }

      /* ─── Before card · pile area (bottom 32%) ───────────────── */
      .pile {
        position: absolute;
