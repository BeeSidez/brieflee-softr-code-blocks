      @media (min-width: 640px) and (max-width: 1023px) {
        .app-tile { width: 42px !important; height: 42px !important; }
        .app-tile img { width: 26px !important; height: 26px !important; }
        .text-pill { font-size: 10px; padding: 6px 10px 6px 8px; border-radius: 10px; }
