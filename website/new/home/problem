        .comment-pill { font-size: 10px; padding: 5px 12px 5px 5px; border-radius: 10px; max-width: 200px; }
        .comment-avatar { width: 22px; height: 22px; }
        .rec-pill { font-size: 9px; padding: 5px 9px 5px 7px; }
      }
      .falling-item {
        position: absolute;
        transform-origin: 50% 50%;
