        gap: 8px;
        padding: 8px 12px 8px 8px;
        border-radius: 12px;
        white-space: nowrap;
        /* Base position from CSS variables (NOT inline) so :hover applies */
        left:   var(--base-left);
        right:  var(--base-right);
        top:    var(--base-top);
        bottom: var(--base-bottom);
        transition: left 0.6s cubic-bezier(.4,0,.2,1),
