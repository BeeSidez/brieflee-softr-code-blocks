const NAVY = "#001364";
const PERI = "#879CF7";

// Same gradient the hero uses — soft periwinkle cloud on a #FAFBFF base
// (#FAFBFF matches the Softr nav colour so there's no seam between
// blocks).
const HERO_BG =
  "radial-gradient(ellipse 65% 50% at 50% 50%, rgba(135,156,247,0.28) 0%, rgba(180,192,245,0.14) 40%, rgba(180,192,245,0) 75%), #FAFBFF";

// ----- Asset URLs -----
const APP_ICON = (slug) =>
  `https://res.cloudinary.com/dchroynzv/image/upload/brieflee_app-icon_${slug}-transparent_2026-05.png`;
const PORTRAIT_SRC =
  "https://res.cloudinary.com/dchroynzv/image/upload/v1778618704/brieflee_feature-card_creator-still-black-woman-grey-set-apartment-transparent_2026-05.png";
const USER_PHOTOS = {
  man:   "https://res.cloudinary.com/dchroynzv/image/upload/brieflee_user-photo_man-moustache-cap-hoodie_2026-05.png",
  woman: "https://res.cloudinary.com/dchroynzv/image/upload/brieflee_user-photo_woman-yellow-sweater-smiling_2026-05.png",
};

// ----- Before card · 18-item pile, batched drops -----
// Foreplay-style stratification: messages at the BOTTOM (foreground),
// app icons piled on TOP. Items fall in 6 batches of varied sizes
// (3 / 1 / 4 / 2 / 3 / 5) instead of one continuous waterfall, so it
// reads as a natural cascade — some hit together, some land alone.
// Bottom items fall first (and form the pile floor); top items fall
// last (and pile on top). DOM order = z-order, so later items render
// on top of earlier ones — no extra z-index needed.
const FALLING = [
  // ─ BATCH 1 · t=0.00s — 3 items hit together, bottom-most layer ─
  { type: "comment", label: "They forgot to mention the date the offer ends",
    avatar: USER_PHOTOS.man,                              finalLeft: "4%",  finalBottom: "1%",  finalRot: -3,  delay: 0.00 },
  { type: "comment", label: "I like the concept but something feels off 🤔",
    avatar: USER_PHOTOS.woman,                            finalLeft: "44%", finalBottom: "3%",  finalRot: 2,   delay: 0.05 },
  { type: "pill", icon: "crop", label: "Screenshots",     finalLeft: "78%", finalBottom: "1%",  finalRot: 5,   delay: 0.10 },

  // ─ BATCH 2 · t=0.45s — 1 item alone ──────────────────────────
  { type: "pill", icon: "play", label: "Video Recording", finalLeft: "8%",  finalBottom: "11%", finalRot: -5,  delay: 0.45 },

  // ─ BATCH 3 · t=0.80s — 4 items together ─────────────────────
  { type: "pill", icon: "infinity", label: "Endless Slack channels",
                                                          finalLeft: "30%", finalBottom: "12%", finalRot: 4,   delay: 0.80 },
  { type: "pill", icon: "broken", label: "Broken Links",  finalLeft: "60%", finalBottom: "13%", finalRot: -3,  delay: 0.85 },
  { type: "rec",                                          finalLeft: "85%", finalBottom: "11%", finalRot: -10, delay: 0.90 },
  { type: "folder", label: "Ad Insp...",                  finalLeft: "16%", finalBottom: "19%", finalRot: 6,   delay: 0.95 },

  // ─ BATCH 4 · t=1.30s — 2 items together, mid layer ──────────
  { type: "app", src: APP_ICON("dropbox"),        size: 50, finalLeft: "44%", finalBottom: "19%", finalRot: -8, delay: 1.30 },
  { type: "app", src: APP_ICON("notion"),         size: 55, finalLeft: "70%", finalBottom: "20%", finalRot: 5,  delay: 1.35 },

  // ─ BATCH 5 · t=1.65s — 3 items together, mid-upper ──────────
  { type: "app", src: APP_ICON("microsoft-word"), size: 50, finalLeft: "8%",  finalBottom: "24%", finalRot: 7,  delay: 1.65 },
  { type: "app", src: APP_ICON("airtable"),       size: 60, finalLeft: "32%", finalBottom: "23%", finalRot: -5, delay: 1.70 },
  { type: "app", src: APP_ICON("frame-io"),       size: 56, finalLeft: "60%", finalBottom: "24%", finalRot: 4,  delay: 1.75 },

  // ─ BATCH 6 · t=2.10s — 5 items, top of pile (biggest icons) ─
  { type: "app", src: APP_ICON("instagram"),      size: 60, finalLeft: "20%", finalBottom: "28%", finalRot: -7, delay: 2.10 },
  { type: "app", src: APP_ICON("slack"),          size: 70, finalLeft: "44%", finalBottom: "27%", finalRot: 6,  delay: 2.15 },
  { type: "app", src: APP_ICON("tiktok"),         size: 65, finalLeft: "66%", finalBottom: "28%", finalRot: 10, delay: 2.20 },
  { type: "app", src: APP_ICON("microsoft-excel"), size: 56, finalLeft: "86%", finalBottom: "27%", finalRot: -4, delay: 2.25 },
  { type: "app", src: APP_ICON("canva"),          size: 50, finalLeft: "6%",  finalBottom: "30%", finalRot: -10, delay: 2.30 },
];

// ----- After card · 3 left + 3 right floating pills -----
// Mirror the hero floating chips exactly. Both base + spread positions
// live in CSS variables so the :hover rule actually applies (inline
// `style={{ left: ... }}` would beat the cascade and break the
// transition).
const PILLS_LEFT = [
  { l: "Visual hook",     v: "0.6s",  ok: true,
    base: { left: "8%",  top: "8%"  }, spread: { left: "-2%",  top: "2%"  } },
  { l: "Face time",       v: "58%",   ok: true,
    base: { left: "6%",  top: "42%" }, spread: { left: "-4%",  top: "42%" } },
  { l: "Product visible", v: "47%",   ok: true,
    base: { left: "8%",  bottom: "10%" }, spread: { left: "-2%", bottom: "2%" } },
];

const PILLS_RIGHT = [
  { l: "Audio clarity",   v: "94%",   ok: true,
    base: { right: "8%",  top: "8%"  }, spread: { right: "-2%",  top: "2%"  } },
  { l: "Brand mention",   v: "3×",    ok: true,
    base: { right: "6%",  top: "42%" }, spread: { right: "-4%",  top: "42%" } },
  { l: "CTA timing",      v: "Last 3s", ok: true,
    base: { right: "8%",  bottom: "10%" }, spread: { right: "-2%", bottom: "2%" } },
];

// =====================================================================
// Block
// =====================================================================
export default function Block() {
  return (
    <section
      className="relative w-full py-16 md:py-24 px-5 md:px-10"
      style={{
        background: HERO_BG,
        fontFamily: "'Plus Jakarta Sans', system-ui, sans-serif",
      }}
    >
      <Keyframes />

      {/* Section header — eyebrow + h2 + subhead */}
      <div className="max-w-3xl mx-auto flex flex-col items-center text-center">
        <Eyebrow>The Problem</Eyebrow>
        <h2
          className="mt-6 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1] text-balance"
          style={{ color: NAVY }}
        >
          Why you need Brieflee to check
          <br className="hidden sm:block" /> your video content
        </h2>
        <p
          className="mt-5 text-base md:text-lg leading-relaxed max-w-2xl mx-auto font-medium"
          style={{ color: NAVY, opacity: 0.7 }}
        >
          When you're creating multiple videos or managing multiple creators,
          maintaining consistent quality standards is nearly impossible. Brieflee
