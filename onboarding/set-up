// ─── Constants ─────────────────────────────────────────────────────
const LEE_AVATAR = "https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png";
const FINISH_URL = "/new";
const TOTAL_STEPS = 6;
const STEP_LABELS = {
  1: "Brand setup",
  2: "Review mode",
  3: "How Brieflee works",
  4: "QA Checklist",
  5: "Thresholds",
  6: "Content blueprint",
};

// ═══════════════════════════════════════════════════════════════════
// Block
// ═══════════════════════════════════════════════════════════════════
export default function Block() {
  const { data, status, refetch } = useRecords({ select, count: 1 });
  const record = data?.[0];

  const [currentStep, setCurrentStep] = useState(1);
  const [savedSteps, setSavedSteps] = useState({});  // { 1: true, 2: true, ... }
  const [skippedSteps, setSkippedSteps] = useState({});

  // Refs for smooth scroll
  const stepRefs = {
    1: useRef(null),
    2: useRef(null),
    3: useRef(null),
    4: useRef(null),
    5: useRef(null),
    6: useRef(null),
  };

  // Step 1 — Brand setup
  const [website, setWebsite] = useState("");
  const [description, setDescription] = useState("");
  const [useCases, setUseCases] = useState([]);

  // Step 2 — Review mode
  const [aiModeId, setAiModeId] = useState(null);

  // Step 4 — QA checklist
  const [qaIds, setQaIds] = useState([]);

  // Step 5 — Thresholds
  const [thresholds, setThresholds] = useState({});

  // Step 6 — Blueprint review
  const [brandBio, setBrandBio] = useState("");
  const [brandVoice, setBrandVoice] = useState("");
  const [brandCta, setBrandCta] = useState("");
  const [niche, setNiche] = useState("");
  const [targetAudience, setTargetAudience] = useState("");
  const [audiencePainPoints, setAudiencePainPoints] = useState("");
  const [audienceObjectives, setAudienceObjectives] = useState("");

  const updateRecord = useRecordUpdate({
    fields: updateFields,
    async onSuccess() { await refetch(); },
    onError(err) {
      toast.error("Couldn't save", { description: err?.message || "Try again." });
    },
  });

  // Pre-fill from existing record
  useEffect(() => {
    if (!record) return;
    if (record.website && !website) setWebsite(record.website);
    if (record.description && !description) setDescription(record.description);
    if (Array.isArray(record.useCase) && useCases.length === 0) {
      setUseCases(record.useCase.map((c) => c.id || c));
    }
    if (record.aiMode?.id && !aiModeId) setAiModeId(record.aiMode.id);
    if (Array.isArray(record.qaChecklist) && qaIds.length === 0) {
      setQaIds(record.qaChecklist.map((c) => c.id || c));
    }
    setThresholds((cur) => {
      const next = { ...cur };
      THRESHOLD_ROWS.forEach((r) => {
        if (record[r.key]?.id && !cur[r.key]) next[r.key] = record[r.key].id;
      });
      return next;
    });
    if (record.brandBio && !brandBio) setBrandBio(record.brandBio);
    if (record.brandVoice && !brandVoice) setBrandVoice(record.brandVoice);
    if (record.brandCta && !brandCta) setBrandCta(record.brandCta);
    if (record.niche && !niche) setNiche(record.niche);
    if (record.targetAudience && !targetAudience) setTargetAudience(record.targetAudience);
    if (record.audiencePainPoints && !audiencePainPoints) setAudiencePainPoints(record.audiencePainPoints);
    if (record.audienceObjectives && !audienceObjectives) setAudienceObjectives(record.audienceObjectives);
  }, [record]); // eslint-disable-line

  // Smooth-scroll to a step's section
  const scrollTo = (step) => {
    const el = stepRefs[step]?.current;
    if (!el) return;
    setTimeout(() => {
      el.scrollIntoView({ behavior: "smooth", block: "start" });
    }, 80);
  };

  const advance = (toStep) => {
    setCurrentStep(toStep);
    scrollTo(toStep);
  };

  const markSavedAndAdvance = (step) => {
    setSavedSteps((cur) => ({ ...cur, [step]: true }));
    advance(step + 1);
  };
  const markSkippedAndAdvance = (step) => {
    setSkippedSteps((cur) => ({ ...cur, [step]: true }));
    advance(step + 1);
  };

  // ─── Save handlers ────────────────────────────────────────────
  const save = (fieldsObj, after) => {
    if (!record?.id) {
      toast.error("Couldn't find your account record.");
      return;
    }
    updateRecord.mutate(
      { recordId: record.id, fields: fieldsObj },
      { onSuccess: () => { refetch(); after?.(); } },
    );
  };

  const handleStep1 = () => {
    const useCasePayload = USE_CASE_OPTIONS
      .filter((o) => useCases.includes(o.id))
      .map((o) => ({ id: o.id, label: o.label }));
    save(
      {
        website: website.trim(),
        description: description.trim(),
        useCase: useCasePayload,
      },
      () => markSavedAndAdvance(1),
    );
  };

  const handleStep2 = () => {
    if (!aiModeId) return;
    const m = AI_MODE_OPTIONS.find((x) => x.id === aiModeId);
    save(
      { aiMode: m ? { id: m.id, label: m.label } : null },
      () => markSavedAndAdvance(2),
    );
  };

  const handleStep3GotIt = () => markSavedAndAdvance(3);
  const handleStep3Skip  = () => markSkippedAndAdvance(3);

  const handleStep4 = ({ skip } = {}) => {
    if (skip) {
      markSkippedAndAdvance(4);
      return;
    }
    save({ qaChecklist: qaIds }, () => markSavedAndAdvance(4));
  };

  const handleStep5 = ({ skip } = {}) => {
    if (skip) {
      markSkippedAndAdvance(5);
      return;
    }
    const fields = {};
    Object.entries(thresholds).forEach(([key, optId]) => {
      const row = THRESHOLD_ROWS.find((r) => r.key === key);
      const opt = row?.options.find((o) => o.id === optId);
      if (opt) fields[key] = { id: opt.id, label: opt.label };
    });
    save(fields, () => markSavedAndAdvance(5));
  };

  const handleStep6 = () => {
    save(
      {
        brandBio: brandBio.trim(),
        brandVoice: brandVoice.trim(),
        brandCta: brandCta.trim(),
        niche: niche.trim(),
        targetAudience: targetAudience.trim(),
        audiencePainPoints: audiencePainPoints.trim(),
        audienceObjectives: audienceObjectives.trim(),
      },
      () => { window.location.href = FINISH_URL; },
    );
  };

  if (status === "pending") return <Loading />;
  if (status === "error" || !record) return <Loading error />;

  return (
    <div className="min-h-screen flex flex-col" style={{ background: "linear-gradient(to bottom, rgba(217, 224, 255, 0.15), rgba(255, 255, 255, 1))" }}>
      <Style />
      <ProgressDots active={currentStep} total={TOTAL_STEPS} />

      <div className="flex-1 overflow-y-auto pb-32">
        <div className="container mx-auto px-4 py-8 max-w-2xl">
          {/* Step 1 — Brand setup */}
          <section ref={stepRefs[1]}>
            <Step1
              active={currentStep === 1}
              done={!!savedSteps[1]}
              skipped={!!skippedSteps[1]}
              website={website} setWebsite={setWebsite}
              description={description} setDescription={setDescription}
              useCases={useCases} setUseCases={setUseCases}
              onSave={handleStep1}
              saving={updateRecord.status === "pending" && currentStep === 1}
            />
          </section>

          {/* Step 2 — Review mode */}
          {currentStep >= 2 && (
            <section ref={stepRefs[2]}>
              <Step2
                active={currentStep === 2}
                done={!!savedSteps[2]}
                skipped={!!skippedSteps[2]}
                aiModeId={aiModeId} setAiModeId={setAiModeId}
                onSave={handleStep2}
                saving={updateRecord.status === "pending" && currentStep === 2}
              />
            </section>
          )}

          {/* Step 3 — How Brieflee works */}
          {currentStep >= 3 && (
            <section ref={stepRefs[3]}>
              <Step3
                active={currentStep === 3}
                done={!!savedSteps[3]}
                skipped={!!skippedSteps[3]}
                onGotIt={handleStep3GotIt}
                onSkip={handleStep3Skip}
              />
            </section>
          )}

          {/* Step 4 — QA Checklist */}
          {currentStep >= 4 && (
            <section ref={stepRefs[4]}>
              <Step4
                active={currentStep === 4}
                done={!!savedSteps[4]}
                skipped={!!skippedSteps[4]}
                qaIds={qaIds} setQaIds={setQaIds}
                onSave={() => handleStep4()}
                onSkip={() => handleStep4({ skip: true })}
                saving={updateRecord.status === "pending" && currentStep === 4}
              />
            </section>
          )}

          {/* Step 5 — Thresholds */}
          {currentStep >= 5 && (
            <section ref={stepRefs[5]}>
              <Step5
                active={currentStep === 5}
                done={!!savedSteps[5]}
                skipped={!!skippedSteps[5]}
                thresholds={thresholds} setThresholds={setThresholds}
                onSave={() => handleStep5()}
                onSkip={() => handleStep5({ skip: true })}
                saving={updateRecord.status === "pending" && currentStep === 5}
              />
            </section>
          )}

          {/* Step 6 — Blueprint review */}
          {currentStep >= 6 && (
            <section ref={stepRefs[6]}>
              <Step6
                active={currentStep === 6}
                done={!!savedSteps[6]}
                blueprintReady={record.blueprintStatus?.label === "Complete"}
                brandBio={brandBio} setBrandBio={setBrandBio}
                brandVoice={brandVoice} setBrandVoice={setBrandVoice}
                brandCta={brandCta} setBrandCta={setBrandCta}
                niche={niche} setNiche={setNiche}
                targetAudience={targetAudience} setTargetAudience={setTargetAudience}
                audiencePainPoints={audiencePainPoints} setAudiencePainPoints={setAudiencePainPoints}
                audienceObjectives={audienceObjectives} setAudienceObjectives={setAudienceObjectives}
                onFinish={handleStep6}
                onRefetch={refetch}
                saving={updateRecord.status === "pending" && currentStep === 6}
              />
            </section>
          )}
        </div>
      </div>
    </div>
  );
}

