// Stagger an array of timers, returning an array of booleans for each milestone.
function useReveal(active, steps) {
  const [shown, setShown] = useState(steps.map(() => false));
  useEffect(() => {
    if (!active) return;
    const timers = steps.map((delay, i) =>
      setTimeout(() => setShown((cur) => { const next = [...cur]; next[i] = true; return next; }), delay),
    );
    return () => timers.forEach(clearTimeout);
  }, [active]); // eslint-disable-line
  return shown;
}

