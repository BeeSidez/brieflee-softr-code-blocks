import { useState, useEffect, useRef } from 'react';
import { useCurrentUser } from '@/lib/user';
import { useRecordCreate, useRecord, useUpload, q } from '@/lib/datasource';
import { Search, Shuffle, CloudUpload, Link, FileText, MessageSquare } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { toast } from 'sonner';

// Submission table field IDs
const createFields = q.select({
  video_file: 'PP7rO',
  video_url: 'XrARi',
  submission_type: 'b82bF',
  brief_attachment: 'GmjrC',
  submission_notes: 'UzR32',
  accounts: 'v94f0',
  users: 'DxNOa',
  logic: '3uQTp',
  creator_name: '9ZryL',
  first: 'AKsNc'
});

// For polling the internal_link field after creation
const readFields = q.select({
  internal_link: 'GarE7'
});

// For reading the user's linked account from users table
// NOTE: This must query the USERS datasource, not submissions
const userAccountFields = q.select({
  accounts: 'Nz6VX'
});

// Submission type choice IDs
const SUBMISSION_TYPES = {
  review: '5ed52a56-f33e-475a-bc32-95b11756290f',   // Content Review
  remix: '4d21296f-a7a6-4264-9298-21c7c4a7e6f2'     // Example/Swipe File
};

// Logic choice IDs
const LOGIC_CHOICES = {
  file: 'f8b72c1c-340a-4996-84bf-bae4c6ae7245',     // Upload a file
  url: '495afa00-1893-43f8-8879-fc996d7f72bf',       // Paste a link
  brief: '92a7017f-215a-4704-aca2-94bd7f4a6c9a',     // Attach a brief
  notes: '255b438e-d37c-40c5-b31f-4ea76ff4c02b'      // Add notes
};

export default function Block() {
  // Conversation state
  const [showTyping1, setShowTyping1] = useState(false);
  const [showMessage1, setShowMessage1] = useState(false);
  const [showTyping2, setShowTyping2] = useState(false);
  const [showCards, setShowCards] = useState(false);
  const [showTyping3, setShowTyping3] = useState(false);
  const [showMessage2, setShowMessage2] = useState(false);
  const [showTyping4, setShowTyping4] = useState(false);
  const [showUploadOptions, setShowUploadOptions] = useState(false);
  const [showUploadUI, setShowUploadUI] = useState(false);
  const [showTyping5, setShowTyping5] = useState(false);
  const [showMessage3, setShowMessage3] = useState(false);
  const [showContextOptions, setShowContextOptions] = useState(false);
  const [showTyping6, setShowTyping6] = useState(false);
  const [showMessage4, setShowMessage4] = useState(false);
  const [showButton, setShowButton] = useState(false);

  // Loading state
  const [showLoadingTyping, setShowLoadingTyping] = useState(false);
  const [showLoadingMessage, setShowLoadingMessage] = useState(false);
  const [showVideoFrame, setShowVideoFrame] = useState(false);
  const [reviewReady, setReviewReady] = useState(false);
  const [submissionRecordId, setSubmissionRecordId] = useState(null);
  const [submissionLink, setSubmissionLink] = useState('');

  // Form state
  const [selectedMode, setSelectedMode] = useState(null);
  const [uploadMethod, setUploadMethod] = useState(null);
  const [videoFile, setVideoFile] = useState(null);
  const [videoLink, setVideoLink] = useState('');
  const [briefFile, setBriefFile] = useState(null);
  const [notes, setNotes] = useState('');
  const [isDragging, setIsDragging] = useState(false);
  const [showNotesTextarea, setShowNotesTextarea] = useState(false);
  const [noThanksClicked, setNoThanksClicked] = useState(false);
  const [isSubmitted, setIsSubmitted] = useState(false);

  const fileInputRef = useRef(null);
  const briefInputRef = useRef(null);
  const pollingRef = useRef(null);
  const reviewTimerRef = useRef(null);
  const loadingRef = useRef(null);
  const user = useCurrentUser();

  // ─── Upload hook for files ───
  const { uploadAsync } = useUpload();

  // ─── Read user's linked account from users table (field Nz6VX) ───
  // CRITICAL: We need to fetch from a DIFFERENT datasource (users table)
  // The current useRecord is configured for submissions table only
  // For now, we'll skip account mapping until we can query the users datasource
  const userData = null;
  const userDataStatus = 'success';

  // ─── Record creation hook ───
  const createRecord = useRecordCreate({
    fields: createFields,
    onSuccess: (newRecord) => {
      setSubmissionRecordId(newRecord.id);
      toast.success('Submission created!');

      // Show Lee's typing, then loading message, then video frame
      setShowLoadingTyping(true);
      setTimeout(() => {
        setShowLoadingTyping(false);
        setShowLoadingMessage(true);
      }, 1800);
      setTimeout(() => {
        setShowVideoFrame(true);
      }, 2300);

      // After 1 minute, show the review ready state
      reviewTimerRef.current = setTimeout(() => {
        setReviewReady(true);
      }, 60000); // 1 minute
    },
    onError: (error) => {
      toast.error('Failed to create submission', {
        description: error.message,
      });
      // Re-show the submit button so user can retry
      setShowButton(true);
      setIsSubmitted(false);
    }
  });

  // ─── Poll for internal_link on the created record ───
  const { data: submissionData, refetch: refetchSubmission } = useRecord({
    recordId: submissionRecordId,
    select: readFields,
    enabled: false, // Only fetch when we call refetch
  });

  const startPolling = (recordId) => {
    // Poll every 5 seconds for the internal_link field
    pollingRef.current = setInterval(async () => {
      try {
        const result = await refetchSubmission();
        const link = result?.data?.fields?.internal_link;
        if (link && link.trim() !== '') {
          setSubmissionLink(link);
          setReviewReady(true);
          clearInterval(pollingRef.current);
          pollingRef.current = null;
        }
      } catch (e) {
        // Keep polling on error
      }
    }, 5000);
  };

  // ─── Also check submissionData changes ───
  useEffect(() => {
    if (submissionData?.fields?.internal_link) {
      const link = submissionData.fields.internal_link;
      if (link.trim() !== '') {
        setSubmissionLink(link);
        setReviewReady(true);
        if (pollingRef.current) {
          clearInterval(pollingRef.current);
          pollingRef.current = null;
        }
      }
    }
  }, [submissionData]);

  // Initial conversation start
  useEffect(() => {
    setTimeout(() => setShowTyping1(true), 300);
    setTimeout(() => {
      setShowTyping1(false);
      setShowMessage1(true);
    }, 1800);
    setTimeout(() => setShowTyping2(true), 2300);
    setTimeout(() => {
      setShowTyping2(false);
      setShowCards(true);
    }, 4000);
  }, []);

  // After mode selection
  useEffect(() => {
    if (selectedMode && !showMessage2) {
      setShowTyping3(true);
      setTimeout(() => {
        setShowTyping3(false);
        setShowMessage2(true);
      }, 1500);
      setTimeout(() => setShowTyping4(true), 2000);
      setTimeout(() => {
        setShowTyping4(false);
        setShowUploadOptions(true);
      }, 3500);
    }
  }, [selectedMode]);

  // Reset context when switching to Remix mode
  useEffect(() => {
    if (selectedMode === 'remix') {
      setShowMessage3(false);
      setShowContextOptions(false);
      setShowMessage4(false);
      setBriefFile(null);
      setNotes('');
      setShowNotesTextarea(false);
      setNoThanksClicked(false);
    }
  }, [selectedMode]);

  // After upload method selection
  useEffect(() => {
    if (uploadMethod && !showUploadUI) {
      setShowUploadUI(true);
    }
  }, [uploadMethod]);

  // After content is uploaded
  useEffect(() => {
    const hasContent = videoFile || videoLink.trim().length > 0;
    if (hasContent && !showMessage3) {
      if (selectedMode === 'remix') {
        setShowButton(true);
      } else {
        setShowTyping5(true);
        setTimeout(() => {
          setShowTyping5(false);
          setShowMessage3(true);
          setShowContextOptions(true);
        }, 1500);
      }
    }
  }, [videoFile, videoLink, selectedMode]);

  // After context interaction (brief, notes, or no thanks)
  useEffect(() => {
    if ((briefFile || notes.trim().length > 0 || showNotesTextarea || noThanksClicked) && !showMessage4 && selectedMode === 'review') {
      setShowTyping6(true);
      setTimeout(() => {
        setShowTyping6(false);
        setShowMessage4(true);
      }, 1500);
      setTimeout(() => setShowButton(true), 2000);
    }
  }, [briefFile, notes, showNotesTextarea, noThanksClicked, selectedMode]);

  // Auto-scroll to loading section when it appears
  useEffect(() => {
    if (showVideoFrame && loadingRef.current) {
      loadingRef.current.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [showVideoFrame]);

  // Auto-scroll when review is ready
  useEffect(() => {
    if (reviewReady && loadingRef.current) {
      loadingRef.current.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [reviewReady]);

  // Clean up polling and timers on unmount
  useEffect(() => {
    return () => {
      if (pollingRef.current) {
        clearInterval(pollingRef.current);
      }
      if (reviewTimerRef.current) {
        clearTimeout(reviewTimerRef.current);
      }
    };
  }, []);

  const handleDragOver = (e) => {
    e.preventDefault();
    setIsDragging(true);
  };

  const handleDragLeave = () => {
    setIsDragging(false);
  };

  const handleDrop = (e) => {
    e.preventDefault();
    setIsDragging(false);
    const file = e.dataTransfer.files[0];
    if (!file) return;

    if (!file.type.startsWith('video/')) {
      toast.error('Please upload a video file');
      return;
    }

    const maxSize = 100 * 1024 * 1024;
    if (file.size > maxSize) {
      toast.error('Video file must be under 100MB');
      return;
    }

    setVideoFile(file);
    setVideoLink('');
  };

  const handleFileSelect = (e) => {
    const file = e.target.files[0];
    if (!file) return;

    if (!file.type.startsWith('video/')) {
      toast.error('Please upload a video file');
      return;
    }

    const maxSize = 100 * 1024 * 1024;
    if (file.size > maxSize) {
      toast.error('Video file must be under 100MB');
      return;
    }

    setVideoFile(file);
    setVideoLink('');
  };

  const handleBriefSelect = (e) => {
    const file = e.target.files[0];
    if (!file) return;

    if (file.type !== 'application/pdf') {
      toast.error('Brief must be a PDF file');
      return;
    }

    setBriefFile(file);
  };

  const handleNoThanks = () => {
    setNoThanksClicked(true);
  };

  // ─── Build logic array from user choices ───
  const buildLogicChoices = () => {
    const choices = [];
    if (uploadMethod === 'file') choices.push(LOGIC_CHOICES.file);
    if (uploadMethod === 'url') choices.push(LOGIC_CHOICES.url);
    if (briefFile) choices.push(LOGIC_CHOICES.brief);
    if (notes.trim().length > 0) choices.push(LOGIC_CHOICES.notes);
    return choices;
  };

  // ─── Submit handler — uploads files then creates the record ───
  const handleSubmit = async () => {
    if (!videoFile && !videoLink) {
      toast.error('Please upload a video or paste a link');
      return;
    }

    // Check if user data is loaded
    if (userDataStatus === 'pending') {
      toast.error('Loading user data, please wait...');
      return;
    }

    // Hide the submit button immediately and lock all inputs
    setShowButton(false);
    setIsSubmitted(true);

    try {
      // Build the record payload
      const payload = {
        submission_type: SUBMISSION_TYPES[selectedMode],
        users: user?.id ? [user.id] : [],
        logic: buildLogicChoices(),
        submission_notes: notes.trim() || null,
        creator_name: user?.fullName || null,
        first: true,
      };

      // Map accounts from user's linked account field
      const userAccounts = userData?.fields?.accounts;
      console.log('=== ACCOUNT MAPPING DEBUG ===');
      console.log('User ID:', user?.id);
      console.log('User data status:', userDataStatus);
      console.log('User data (full):', userData);
      console.log('User accounts (raw):', userAccounts);
      console.log('Type:', typeof userAccounts);
      console.log('Is array?', Array.isArray(userAccounts));
      
      if (userAccounts) {
        if (Array.isArray(userAccounts)) {
          if (userAccounts.length > 0) {
            // Array of linked records - extract IDs
            const accountIds = userAccounts.map(acc => {
              if (typeof acc === 'object' && acc.id) return acc.id;
              if (typeof acc === 'string') return acc;
              return null;
            }).filter(Boolean);
            
            if (accountIds.length > 0) {
              payload.accounts = accountIds;
              console.log('✓ Using array format, account IDs:', accountIds);
            } else {
              console.warn('⚠ Array present but no valid IDs found');
            }
          } else {
            console.warn('⚠ Empty accounts array');
          }
        } else if (typeof userAccounts === 'object' && userAccounts !== null) {
          // Single linked record object
          if (userAccounts.id) {
            payload.accounts = [userAccounts.id];
            console.log('✓ Using object format, account ID:', userAccounts.id);
          } else {
            console.warn('⚠ Object present but no id property:', userAccounts);
          }
        } else if (typeof userAccounts === 'string') {
          // Direct ID string
          payload.accounts = [userAccounts];
          console.log('✓ Using string format, account ID:', userAccounts);
        } else {
          console.warn('⚠ Unexpected userAccounts format:', userAccounts);
        }
      } else {
        console.warn('⚠ No user accounts data available (null/undefined)');
      }

      console.log('Final payload.accounts:', payload.accounts);

      // Upload video file if provided
      if (videoFile) {
        console.log('Uploading video file:', videoFile.name);
        toast.info('Uploading video...');
        const [videoResult] = await uploadAsync(videoFile);
        console.log('Video upload result:', videoResult);
        
        if (videoResult.status === 'completed' && videoResult.url) {
          payload.video_file = [{ filename: videoResult.file.name, url: videoResult.url }];
          console.log('✓ Video uploaded successfully:', payload.video_file);
        } else {
          console.error('✗ Video upload failed:', videoResult);
          throw new Error(videoResult.error?.message || 'Video upload failed');
        }
      }

      // Add video URL if provided (not file)
      if (videoLink.trim() && !videoFile) {
        payload.video_url = videoLink.trim();
        console.log('✓ Using video URL:', payload.video_url);
      }

      // Upload brief attachment if provided
      if (briefFile) {
        console.log('Uploading brief file:', briefFile.name);
        toast.info('Uploading brief...');
        const [briefResult] = await uploadAsync(briefFile);
        console.log('Brief upload result:', briefResult);
        
        if (briefResult.status === 'completed' && briefResult.url) {
          payload.brief_attachment = [{ filename: briefResult.file.name, url: briefResult.url }];
          console.log('✓ Brief uploaded successfully:', payload.brief_attachment);
        } else {
          console.error('✗ Brief upload failed:', briefResult);
          throw new Error(briefResult.error?.message || 'Brief upload failed');
        }
      }

      console.log('=== FINAL PAYLOAD ===');
      console.log(JSON.stringify(payload, null, 2));

      // Create the record — onSuccess triggers the loading sequence
      createRecord.mutate(payload);

    } catch (error) {
      console.error('Submit error:', error);
      toast.error('Upload failed', {
        description: error.message,
      });
      // Re-show the submit button so user can retry
      setShowButton(true);
      setIsSubmitted(false);
    }
  };

  const hasContent = videoFile || videoLink.trim().length > 0;

  const modes = [
    {
      value: 'review',
      label: 'Review content',
      icon: Search,
      description: "Got a video you want checked? Upload it or paste a link and I'll review it against your content blueprint and quality standards."
    },
    {
      value: 'remix',
      label: 'Remix content',
      icon: Shuffle,
      description: "Seen a piece of content you love? Drop it in and I'll break down what makes it work, then remix it for your brand."
    }
  ];

  const uploadMethods = [
    { value: 'file', label: 'Upload a file', icon: CloudUpload },
    { value: 'url', label: 'Paste a link', icon: Link }
  ];

  return (
    <div className="min-h-screen flex flex-col" style={{ background: 'linear-gradient(to bottom, rgba(217, 224, 255, 0.15), rgba(255, 255, 255, 1))' }}>
      <style>
        {`
          @import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;500;800&display=swap');
          * {
            font-family: 'League Spartan', sans-serif;
          }
          @keyframes bounce {
            0%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-8px); }
          }
          .typing-dot {
            animation: bounce 1.4s infinite;
          }
          .typing-dot:nth-child(2) {
            animation-delay: 0.2s;
          }
          .typing-dot:nth-child(3) {
            animation-delay: 0.4s;
          }

          @keyframes gradientSpin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
          }

          @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
          }

          @keyframes pulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
          }

          @keyframes fadeInUp {
            from {
              opacity: 0;
              transform: translateY(12px);
            }
            to {
              opacity: 1;
              transform: translateY(0);
            }
          }

          .video-frame-outer {
            position: relative;
            width: 220px;
            height: 390px;
            border-radius: 20px;
            padding: 3px;
            overflow: hidden;
          }

          .video-frame-outer::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(
              from 0deg,
              #7A93FF,
              #294FF6,
              #D9E0FF,
              #7A93FF,
              #294FF6,
              #D9E0FF,
              #7A93FF
            );
            animation: gradientSpin 3s linear infinite;
          }

          .video-frame-inner {
            position: relative;
            width: 100%;
            height: 100%;
            background: #FFFFFF;
            border-radius: 17px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 1;
          }

          .review-ready .video-frame-outer::before {
            animation: none;
            background: conic-gradient(
              from 0deg,
              #7A93FF,
              #294FF6,
              #7A93FF
            );
          }
        `}
      </style>

      <div className="flex-1 overflow-y-auto pb-48">
        <div className="container mx-auto px-4 py-8 max-w-2xl">
          {/* Progress indicator */}
          <div className="mb-6">
            <div className="flex items-center justify-center gap-2">
              <div className="h-1.5 w-1.5 rounded-full bg-gray-200"></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#D9E0FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#D9E0FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#D9E0FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#D9E0FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#7A93FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full bg-gray-200"></div>
            </div>
          </div>

          {/* Typing 1 */}
          {showTyping1 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 1 */}
          {showMessage1 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Let's put Brieflee to work. What would you like to try?
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Typing 2 */}
          {showTyping2 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <div className="w-8 h-8 flex-shrink-0"></div>
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Review/Remix cards */}
          {showCards && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="space-y-3 max-w-lg">
                {modes.map((mode) => {
                  const Icon = mode.icon;
                  return (
                    <button
                      key={mode.value}
                      onClick={() => !isSubmitted && setSelectedMode(mode.value)}
                      className="w-full text-left px-4 py-3 rounded-xl transition-all duration-200 bg-white shadow-sm"
                      style={{
                        border: selectedMode === mode.value ? '2px solid #7A93FF' : '1px solid rgba(217, 224, 255, 0.4)',
                        backgroundColor: selectedMode === mode.value ? 'rgba(122, 147, 255, 0.05)' : '#FFFFFF',
                        opacity: isSubmitted ? 0.6 : 1,
                        cursor: isSubmitted ? 'default' : 'pointer',
                        pointerEvents: isSubmitted ? 'none' : 'auto'
                      }}
                    >
                      <div className="flex items-center gap-2 mb-1.5">
                        <div className="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: '#294FF6' }}>
                          <Icon className="w-3 h-3 text-white" />
                        </div>
                        <span className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          {mode.label}
                        </span>
                      </div>
                      <p className="text-xs leading-relaxed" style={{ color: '#001364', fontWeight: 300 }}>
                        {mode.description}
                      </p>
                    </button>
                  );
                })}
              </div>
            </div>
          )}

          {/* Typing 3 */}
          {showTyping3 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 2 */}
          {showMessage2 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Great choice! How would you like to add your content?
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Typing 4 */}
          {showTyping4 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <div className="w-8 h-8 flex-shrink-0"></div>
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Upload method options */}
          {showUploadOptions && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="space-y-3 max-w-lg">
                {uploadMethods.map((method) => {
                  const Icon = method.icon;
                  return (
                    <button
                      key={method.value}
                      onClick={() => !isSubmitted && setUploadMethod(method.value)}
                      className="w-full text-left px-4 py-3 rounded-xl transition-all duration-200 bg-white shadow-sm"
                      style={{
                        border: uploadMethod === method.value ? '2px solid #7A93FF' : '1px solid rgba(217, 224, 255, 0.4)',
                        backgroundColor: uploadMethod === method.value ? 'rgba(122, 147, 255, 0.05)' : '#FFFFFF',
                        opacity: isSubmitted ? 0.6 : 1,
                        cursor: isSubmitted ? 'default' : 'pointer',
                        pointerEvents: isSubmitted ? 'none' : 'auto'
                      }}
                    >
                      <div className="flex items-center gap-2">
                        <div className="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: '#294FF6' }}>
                          <Icon className="w-3 h-3 text-white" />
                        </div>
                        <span className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          {method.label}
                        </span>
                      </div>
                    </button>
                  );
                })}
              </div>
            </div>
          )}

          {/* Upload UI - File */}
          {showUploadUI && uploadMethod === 'file' && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="max-w-lg">
                <div
                  onDragOver={!isSubmitted ? handleDragOver : undefined}
                  onDragLeave={!isSubmitted ? handleDragLeave : undefined}
                  onDrop={!isSubmitted ? handleDrop : undefined}
                  onClick={() => !isSubmitted && fileInputRef.current?.click()}
                  className="rounded-xl p-6 text-center cursor-pointer transition-all duration-200"
                  style={{
                    border: isDragging ? '2px solid #294FF6' : '2px dashed rgba(41, 79, 246, 0.3)',
                    backgroundColor: isDragging ? 'rgba(217, 224, 255, 0.3)' : videoFile ? 'rgba(122, 147, 255, 0.05)' : '#FFFFFF',
                    opacity: isSubmitted ? 0.6 : 1,
                    cursor: isSubmitted ? 'default' : 'pointer',
                    pointerEvents: isSubmitted ? 'none' : 'auto'
                  }}
                >
                  <input
                    ref={fileInputRef}
                    type="file"
                    accept="video/*"
                    onChange={handleFileSelect}
                    className="hidden"
                  />
                  <div className="flex flex-col items-center gap-2">
                    <div className="w-10 h-10 rounded-full flex items-center justify-center" style={{ backgroundColor: 'rgba(41, 79, 246, 0.1)' }}>
                      <CloudUpload className="w-5 h-5" style={{ color: '#294FF6' }} />
                    </div>
                    {videoFile ? (
                      <div>
                        <p className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          {videoFile.name}
                        </p>
                        <p className="text-xs mt-0.5" style={{ color: '#7A93FF', fontWeight: 300 }}>
                          Click to change
                        </p>
                      </div>
                    ) : (
                      <div>
                        <p className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          Upload a video
                        </p>
                        <p className="text-xs mt-0.5" style={{ color: '#001364', fontWeight: 300 }}>
                          Drag and drop or click to browse
                        </p>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Upload UI - URL */}
          {showUploadUI && uploadMethod === 'url' && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="max-w-lg">
                <div className="relative">
                  <div className="absolute left-3 top-1/2 -translate-y-1/2">
                    <Link className="w-4 h-4" style={{ color: '#7A93FF' }} />
                  </div>
                  <input
                    type="url"
                    value={videoLink}
                    onChange={(e) => {
                      if (isSubmitted) return;
                      const url = e.target.value;
                      setVideoLink(url);

                      if (url.trim() && !url.includes('instagram.com') && !url.includes('tiktok.com')) {
                        toast.error('Please enter an Instagram or TikTok link');
                      }
                    }}
                    placeholder="Paste a TikTok or Instagram link"
                    className="w-full pl-10 pr-4 py-3 rounded-xl text-sm bg-white outline-none transition-all duration-200"
                    readOnly={isSubmitted}
                    style={{
                      border: '1px solid rgba(217, 224, 255, 0.4)',
                      color: '#000F4D',
                      fontWeight: 300,
                      opacity: isSubmitted ? 0.6 : 1
                    }}
                    onFocus={(e) => e.target.style.borderColor = '#7A93FF'}
                    onBlur={(e) => e.target.style.borderColor = 'rgba(217, 224, 255, 0.4)'}
                  />
                </div>
              </div>
            </div>
          )}

          {/* Typing 5 */}
          {showTyping5 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 3 - Only for Review mode */}
          {showMessage3 && selectedMode === 'review' && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Want to add any context for this review?
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Context options - Only for Review mode */}
          {showContextOptions && selectedMode === 'review' && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="max-w-lg space-y-3">
                {/* Attach brief */}
                <div
                  onClick={() => !isSubmitted && briefInputRef.current?.click()}
                  className="rounded-xl px-4 py-3 bg-white shadow-sm cursor-pointer transition-all duration-200 hover:shadow-md"
                  style={{
                    border: '1px solid rgba(217, 224, 255, 0.4)',
                    opacity: isSubmitted ? 0.6 : 1,
                    cursor: isSubmitted ? 'default' : 'pointer',
                    pointerEvents: isSubmitted ? 'none' : 'auto'
                  }}
                >
                  <input
                    ref={briefInputRef}
                    type="file"
                    accept=".pdf"
                    onChange={handleBriefSelect}
                    className="hidden"
                  />
                  <div className="flex items-center gap-2">
                    <div className="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: 'rgba(41, 79, 246, 0.1)' }}>
                      <FileText className="w-3 h-3" style={{ color: '#294FF6' }} />
                    </div>
                    <div className="flex-1">
                      <span className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                        {briefFile ? briefFile.name : 'Attach a brief'}
                      </span>
                      {!briefFile && (
                        <p className="text-xs" style={{ color: '#001364', fontWeight: 300 }}>PDF</p>
                      )}
                    </div>
                    {briefFile && (
                      <button
                        onClick={(e) => {
                          e.stopPropagation();
                          setBriefFile(null);
                        }}
                        className="text-xs px-2 py-0.5 rounded-full"
                        style={{ backgroundColor: '#D9E0FF', color: '#294FF6', fontWeight: 500 }}
                      >
                        Remove
                      </button>
                    )}
                  </div>
                </div>

                {/* Add notes */}
                <div
                  className="rounded-xl bg-white shadow-sm overflow-hidden transition-all duration-200"
                  style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}
                >
                  {!showNotesTextarea ? (
                    <button
                      onClick={() => setShowNotesTextarea(true)}
                      className="w-full text-left px-4 py-3 flex items-center gap-2"
                    >
                      <div className="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: 'rgba(41, 79, 246, 0.1)' }}>
                        <MessageSquare className="w-3 h-3" style={{ color: '#294FF6' }} />
                      </div>
                      <div>
                        <span className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>Add notes</span>
                        <p className="text-xs" style={{ color: '#001364', fontWeight: 300 }}>Any specific instructions or things to check for</p>
                      </div>
                    </button>
                  ) : (
                    <div className="px-4 py-3">
                      <div className="flex items-center gap-2 mb-2">
                        <div className="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: 'rgba(41, 79, 246, 0.1)' }}>
                          <MessageSquare className="w-3 h-3" style={{ color: '#294FF6' }} />
                        </div>
                        <span className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>Add notes</span>
                      </div>
                      <textarea
                        value={notes}
                        onChange={(e) => !isSubmitted && setNotes(e.target.value)}
                        placeholder="Any specific instructions or things to check for?"
                        rows={3}
                        readOnly={isSubmitted}
                        className="w-full text-sm rounded-lg p-3 outline-none resize-none transition-all duration-200"
                        style={{
                          border: '1px solid rgba(217, 224, 255, 0.4)',
                          color: '#000F4D',
                          fontWeight: 300,
                          backgroundColor: 'rgba(217, 224, 255, 0.1)',
                          opacity: isSubmitted ? 0.6 : 1
                        }}
                        onFocus={(e) => e.target.style.borderColor = '#7A93FF'}
                        onBlur={(e) => e.target.style.borderColor = 'rgba(217, 224, 255, 0.4)'}
                      />
                    </div>
                  )}
                </div>

                {/* No thanks button */}
                <button
                  onClick={handleNoThanks}
                  className="inline-block text-left px-4 py-3 rounded-xl transition-all duration-200 bg-white shadow-sm hover:shadow-md"
                  style={{
                    border: '1px solid rgba(217, 224, 255, 0.4)',
                    opacity: isSubmitted ? 0.6 : 1,
                    cursor: isSubmitted ? 'default' : 'pointer',
                    pointerEvents: isSubmitted ? 'none' : 'auto'
                  }}
                >
                  <div className="flex items-center gap-2">
                    <span className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>No thanks</span>
                  </div>
                </button>
              </div>
            </div>
          )}

          {/* Typing 6 */}
          {showTyping6 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 4 */}
          {showMessage4 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    No worries if not — I'll review it against your content blueprint and quality standards.
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Submit button */}
          {showButton && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <Button
                onClick={handleSubmit}
                disabled={!hasContent || createRecord.status === 'pending' || userDataStatus === 'pending'}
                className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300"
                style={{
                  backgroundColor: (hasContent && userDataStatus !== 'pending') ? '#7A93FF' : '#D9E0FF',
                  color: '#FFFFFF',
                  borderRadius: '8px',
                  fontWeight: 500,
                  cursor: (hasContent && userDataStatus !== 'pending') ? 'pointer' : 'not-allowed'
                }}
              >
                {userDataStatus === 'pending'
                  ? 'Loading...'
                  : createRecord.status === 'pending'
                  ? 'Submitting...'
                  : selectedMode === 'remix' ? 'Remix this video →' : 'Review my video →'
                }
              </Button>
            </div>
          )}

          {/* ================================================ */}
          {/* LOADING SECTION — appears inline after submit     */}
          {/* ================================================ */}

          {/* Loading typing indicator */}
          {showLoadingTyping && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Loading message from Lee */}
          {showLoadingMessage && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    {reviewReady
                      ? "Your review is ready! Here's what I found."
                      : "Give me a moment while I review your content..."
                    }
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Vertical video frame with animated gradient border */}
          {showVideoFrame && (
            <div ref={loadingRef} className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className={reviewReady ? 'review-ready' : ''}>
                <div className="video-frame-outer">
                  <div className="video-frame-inner">

                    {!reviewReady ? (
                      /* ---- LOADING STATE ---- */
                      <div className="flex flex-col items-center justify-center px-6 text-center">
                        {/* Spinner */}
                        <div
                          style={{
                            border: '3px solid #D9E0FF',
                            borderTop: '3px solid #7A93FF',
                            borderRadius: '50%',
                            width: '36px',
                            height: '36px',
                            animation: 'spin 1s linear infinite'
                          }}
                        ></div>

                        <p className="mt-5 text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          Analysing your content...
                        </p>
                        <p className="mt-2 text-xs leading-relaxed" style={{ color: '#001364', fontWeight: 300 }}>
                          Our AI is reviewing your submission. This usually takes a few minutes.
                        </p>

                        {/* Animated progress dots */}
                        <div className="flex gap-1.5 mt-6">
                          <div className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: '#7A93FF', animation: 'pulse 1.5s ease-in-out infinite' }}></div>
                          <div className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: '#7A93FF', animation: 'pulse 1.5s ease-in-out 0.3s infinite' }}></div>
                          <div className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: '#7A93FF', animation: 'pulse 1.5s ease-in-out 0.6s infinite' }}></div>
                        </div>
                      </div>
                    ) : (
                      /* ---- READY STATE ---- */
                      <div className="flex flex-col items-center justify-center px-6 text-center" style={{ animation: 'fadeInUp 0.5s ease-out' }}>
                        {/* Checkmark */}
                        <div
                          className="w-12 h-12 rounded-full flex items-center justify-center"
                          style={{ backgroundColor: 'rgba(122, 147, 255, 0.1)' }}
                        >
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7A93FF" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </div>

                        <p className="mt-4 text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          Review complete!
                        </p>
                        <p className="mt-1.5 text-xs leading-relaxed" style={{ color: '#001364', fontWeight: 300 }}>
                          Your content has been analysed. Click below to see your results.
                        </p>

                        {/* View results button */}
                        <a
                          href={'/review-details?recordId=' + submissionRecordId}
                          className="mt-5 inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm transition-all duration-200"
                          style={{
                            backgroundColor: '#7A93FF',
                            color: '#FFFFFF',
                            fontWeight: 500,
                            textDecoration: 'none',
                            boxShadow: '0 2px 8px rgba(122, 147, 255, 0.3)'
                          }}
                          onMouseEnter={(e) => e.target.style.boxShadow = '0 4px 12px rgba(122, 147, 255, 0.4)'}
                          onMouseLeave={(e) => e.target.style.boxShadow = '0 2px 8px rgba(122, 147, 255, 0.3)'}
                        >
                          View my results →
                        </a>
                      </div>
                    )}

                  </div>
                </div>
              </div>
            </div>
          )}

        </div>
      </div>
    </div>
  );
}
