// Main Block
// ═══════════════════════════════════════════════════════════════════
export default function Block() {
  const user = useCurrentUser();
  const [step, setStep] = useState("team");
  const [saving, setSaving] = useState(false);

  const [teamName, setTeamName] = useState("");
  const [teamEmails, setTeamEmails] = useState(["", "", ""]);
  const [workTypeId, setWorkTypeId] = useState(null);
  const [heardAboutUsId, setHeardAboutUsId] = useState(null);
  const [billingInterval, setBillingInterval] = useState("Yearly");
  const [selectedPlanId, setSelectedPlanId] = useState(null);

  // Pre-fill from the current user's record so refresh / re-entry doesn't wipe answers
  const { data: userRows } = useRecords({ select, count: 1 });
  const userRecord = userRows?.[0] ?? null;

  useEffect(() => {
    if (!userRecord) return;
    if (userRecord.teamName && !teamName) setTeamName(userRecord.teamName);
    if (userRecord.teamEmails && teamEmails.every((x) => !x)) {
      const parts = String(userRecord.teamEmails).split(",").map((s) => s.trim()).slice(0, 3);
      while (parts.length < 3) parts.push("");
      setTeamEmails(parts);
    }
    if (userRecord.workType?.id && !workTypeId) setWorkTypeId(userRecord.workType.id);
    if (userRecord.heardAboutUs?.id && !heardAboutUsId) setHeardAboutUsId(userRecord.heardAboutUs.id);
    if (Array.isArray(userRecord.plan) && userRecord.plan[0]?.id && !selectedPlanId) {
      setSelectedPlanId(userRecord.plan[0].id);
      const matched = PLANS.find((p) => p.id === userRecord.plan[0].id);
      if (matched) setBillingInterval(matched.interval);
    }
  }, [userRecord]); // eslint-disable-line

  const updateRecord = useRecordUpdate({
    fields: select,
    onError(err) {
      console.error("=== get-started save error:", err);
      toast.error("Save failed", { description: err?.message || "Open the console for details." });
      setSaving(false);
    },
  });

  const goNext = () => {
    const i = STEPS.findIndex((s) => s.id === step);
    // Setup is handled on /set-up, not here — the last in-block step is checkout (Confirm).
    const lastInBlock = STEPS.findIndex((s) => s.id === "checkout");
    if (i < lastInBlock) setStep(STEPS[i + 1].id);
    setSaving(false);
    if (typeof window !== "undefined") window.scrollTo({ top: 0, behavior: "smooth" });
  };
  const goBack = () => {
    const i = STEPS.findIndex((s) => s.id === step);
    if (i > 0) setStep(STEPS[i - 1].id);
    if (typeof window !== "undefined") window.scrollTo({ top: 0, behavior: "smooth" });
  };

  // Team step writes to USERS.team_name + USERS.team_emails. Bev's plan:
  // BL | New Workspace + Team workflow drops the team-creation half, BL | Onboarding
  // workflow gains the email-split step that fans the addresses out into invites.
  const handleTeamNext = ({ skip }) => {
    if (skip) { goNext(); return; }
    if (!user?.id) { goNext(); return; }
    setSaving(true);
    const cleanedEmails = teamEmails.map((e) => e.trim()).filter(Boolean).join(", ");
    updateRecord.mutate(
      {
        recordId: user.id,
        fields: { teamName: teamName.trim(), teamEmails: cleanedEmails },
      },
      { onSuccess: goNext },
    );
  };

  const handlePersonalizeNext = () => {
    if (!user?.id) { toast.error("Not signed in"); return; }
    if (updateRecord.enabled === false) {
      toast.error("Saving is disabled — check Visibility / permissions in Softr.");
      return;
    }
    if (!workTypeId || !heardAboutUsId) return;
    setSaving(true);
    updateRecord.mutate(
      {
        recordId: user.id,
        fields: {
          workType: toIdLabel(WORK_TYPE_OPTIONS, workTypeId),
          heardAboutUs: toIdLabel(HEARD_FROM_OPTIONS, heardAboutUsId),
        },
      },
      { onSuccess: goNext },
    );
  };

  const handlePlanNext = () => {
    if (!user?.id) { toast.error("Not signed in"); return; }
    if (!selectedPlanId) return;
    setSaving(true);
    updateRecord.mutate(
      { recordId: user.id, fields: { plan: [{ id: selectedPlanId }] } },
      { onSuccess: goNext },
    );
  };

  return (
    <div className="gs-root">
      <BlockStyles />
      <div className="gs-shell">
        {/* Topbar */}
        <header className="gs-topbar">
          <div className="gs-topbar-inner">
            <a href="/" aria-label="Brieflee">
              <img src={LOGO_WORDMARK} alt="Brieflee" className="gs-logo" />
            </a>
            <div className="gs-stepper-wrap"><Stepper currentId={step} /></div>
            <div className="gs-help">Need help? <a href="/book-a-demo">Contact us</a></div>
          </div>
        </header>

        {step === "team" && (
          <TeamStep
            teamName={teamName} setTeamName={setTeamName}
            teamEmails={teamEmails} setTeamEmails={setTeamEmails}
            onNext={() => handleTeamNext({ skip: false })}
            onSkip={() => handleTeamNext({ skip: true })}
            saving={saving}
          />
        )}
        {step === "personalize" && (
          <PersonalizeStep
            workTypeId={workTypeId} setWorkTypeId={setWorkTypeId}
            heardAboutUsId={heardAboutUsId} setHeardAboutUsId={setHeardAboutUsId}
            onNext={handlePersonalizeNext} onBack={goBack}
            saving={saving}
          />
        )}
        {step === "pricing" && (
          <PricingStep
            billingInterval={billingInterval} setBillingInterval={setBillingInterval}
            selectedPlanId={selectedPlanId} setSelectedPlanId={setSelectedPlanId}
            onNext={handlePlanNext} onBack={goBack}
            saving={saving}
          />
        )}
        {step === "checkout" && (
          <CheckoutStep
            selectedPlanId={selectedPlanId} billingInterval={billingInterval}
            user={user} onBack={goBack}
          />
        )}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════
// Stepper (pill-style, top-of-page)
// ═══════════════════════════════════════════════════════════════════
function Stepper({ currentId }) {
  const idx = STEPS.findIndex((s) => s.id === currentId);
  return (
    <div className="step-row">
      {STEPS.map((s, i) => {
        const done = i < idx;
        const active = i === idx;
        const klass = active ? "step-pill active" : done ? "step-pill done" : "step-pill";
        return (
          <span key={s.id} style={{ display: "inline-flex", alignItems: "center" }}>
            <span className={klass}>
              <span className="step-dot">
                {done ? <I.Check size={11} strokeWidth={3} /> : i + 1}
              </span>
              <span>{s.label}</span>
            </span>
            {i < STEPS.length - 1 && <span className="step-sep" />}
          </span>
        );
      })}
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════
// Team Step
// ═══════════════════════════════════════════════════════════════════
function TeamStep({ teamName, setTeamName, teamEmails, setTeamEmails, onNext, onSkip, saving }) {
  const setEmail = (i, v) => setTeamEmails(teamEmails.map((e, k) => (k === i ? v : e)));
  const addEmail = () => setTeamEmails([...teamEmails, ""]);
  const removeEmail = (i) => setTeamEmails(teamEmails.filter((_, k) => k !== i));
  const inviteCount = teamEmails.filter((e) => e.trim()).length;
  const canNext = teamName.trim().length > 0;

  return (
    <div className="gs-page gs-page-narrow">
      <div className="text-center mb-6">
        <div className="team-hero">
          <img src={LOGO_COMPACT} alt="" />
        </div>
        <span className="gs-eyebrow">Step 1 of 4 · Set up your workspace</span>
        <h1 className="gs-headline">Name your team and invite your crew</h1>
        <p className="gs-sub">Brieflee is built for review across briefs, brands and teammates. You can always add more people later.</p>
      </div>

      <div className="bl-card" style={{ padding: 28 }}>
        <label className="field-label" htmlFor="team-name">Team name</label>
        <input id="team-name" className="bl-input" placeholder="e.g. Ad Rockstars"
          value={teamName} onChange={(e) => setTeamName(e.target.value)} />
        <div className="field-help">This becomes your workspace title across Brieflee.</div>

        <div className="mt-6">
          <label className="field-label">
            <span className="row gap-2">
              <I.Mail size={14} /> <span>Invite teammates</span>
              <span style={{ color: "#bbb", fontWeight: 500 }}>· optional</span>
            </span>
          </label>
          <div className="stack gap-2">
            {teamEmails.map((val, i) => (
              <div key={i} className="row gap-2">
                <input className="bl-input" type="email" placeholder="name@company.com"
                  value={val} onChange={(e) => setEmail(i, e.target.value)} />
                {teamEmails.length > 1 && (
                  <button type="button" onClick={() => removeEmail(i)} aria-label="Remove" className="ic-btn">
                    <I.X size={14} />
                  </button>
                )}
              </div>
            ))}
          </div>
          <button type="button" onClick={addEmail} className="row gap-2 mt-3 link-btn">
            <I.Plus size={14} /> Add another teammate
          </button>
        </div>
      </div>

      <div className="nav-row">
        <button className="bl-btn bl-btn-ghost" onClick={onSkip} disabled={saving}>Skip for now</button>
        <button className="bl-btn bl-btn-primary" onClick={onNext} disabled={!canNext || saving}>
          {saving
            ? "Saving…"
            : inviteCount > 0
              ? <><I.Send size={14} /> Send {inviteCount} invite{inviteCount > 1 ? "s" : ""} & continue</>
              : <>Continue <I.ArrowRight size={14} /></>}
        </button>
      </div>

      <p className="text-center mt-6" style={{ fontSize: 12, color: "#bbb" }}>
        Teammates get a free seat under your trial. No card needed for them.
      </p>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════
// Personalize Step
// ═══════════════════════════════════════════════════════════════════
function PersonalizeStep({ workTypeId, setWorkTypeId, heardAboutUsId, setHeardAboutUsId, onNext, onBack, saving }) {
  const canNext = Boolean(workTypeId && heardAboutUsId);
  return (
    <div className="gs-page gs-page-medium">
      <div className="text-center mb-6">
        <span className="gs-eyebrow">Step 2 of 4 · Personalize</span>
        <h1 className="gs-headline">Tell us about your work</h1>
        <p className="gs-sub">We'll tune Brieflee's review thresholds, brief templates and onboarding examples to fit how you work.</p>
      </div>

      <div className="personalize-grid">
        <PersonalizeCard
          icon={ICON_BRIEFCASE_PERSONALIZE}
          title="Your work"
          subtitle="What best describes you?"
          options={WORK_TYPE_OPTIONS}
          valueId={workTypeId}
          onSelect={setWorkTypeId}
        />
        <PersonalizeCard
          icon={ICON_MEGAPHONE}
          title="How did you find us?"
          subtitle="Helps us know what's working."
          options={HEARD_FROM_OPTIONS}
          valueId={heardAboutUsId}
          onSelect={setHeardAboutUsId}
        />
