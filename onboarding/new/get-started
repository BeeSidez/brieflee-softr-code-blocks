}

function PersonalizeCard({ icon, title, subtitle, options, valueId, onSelect }) {
  return (
    <div className="personalize-card">
      <img src={icon} alt="" className="personalize-card-icon" />
      <div className="personalize-card-title">{title}</div>
      <div className="personalize-card-sub">{subtitle}</div>
      <div className="personalize-card-chips">
        {options.map((opt) => {
          const sel = valueId === opt.id;
          return (
            <button key={opt.id} className={"opt-chip" + (sel ? " selected" : "")} onClick={() => onSelect(opt.id)}>
              {sel && <I.Check size={12} strokeWidth={3} />}
              {opt.label}
            </button>
          );
        })}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════
// Pricing Step
// ═══════════════════════════════════════════════════════════════════
function PricingStep({ billingInterval, setBillingInterval, selectedPlanId, setSelectedPlanId, onNext, onBack, saving }) {
  const visiblePlans = useMemo(
    () => PLANS.filter((p) => p.interval === billingInterval),
    [billingInterval],
  );
  const selectedPlan = PLANS.find((p) => p.id === selectedPlanId);
  const canNext = Boolean(selectedPlanId);

  return (
    <div className="gs-page">
      <div className="text-center mb-6">
        <div className="trial-banner">
          <span className="trial-dot"></span>
          {TRIAL_DAYS} days free · No charge until your trial ends
        </div>
        <h1 className="gs-headline">Pick the plan that fits your team</h1>
        <p className="gs-sub">All plans include the full Brieflee toolkit. Cancel any time during your trial with one click.</p>
        <div className="mt-6">
          <IntervalToggle value={billingInterval} onChange={setBillingInterval} maxSavings={MAX_YEARLY_SAVINGS} />
        </div>
      </div>

      <div className="plan-grid mt-8">
        {visiblePlans.map((p) => {
          const selected = selectedPlanId === p.id;
          const isYearly = p.interval === "Yearly";
          const monthlyEquivalent = isYearly ? Math.round(p.price / 12) : p.price;
          const billNote = isYearly ? `Billed $${p.price.toLocaleString()} per year` : "Billed monthly";
          const savings = isYearly ? yearlySavingsPct(p.tier) : 0;
          const cls = "plan-card" + (p.popular ? " popular" : "") + (selected ? " selected" : "");

          return (
            <div key={p.id} className={cls} onClick={() => setSelectedPlanId(p.id)}>
              {p.popular && <div className="plan-popular-tag">Most popular</div>}

              <div className="plan-tier">{p.tier}</div>
              <div className="plan-name">For {p.tier === "Creator" ? "solos" : p.tier === "Crew" ? "growing teams" : "agencies"}</div>
              <div className="plan-desc">{p.desc}</div>

              <div className="plan-price-row">
                <span className="plan-price">${monthlyEquivalent}</span>
                <span className="plan-price-suffix">/mo</span>
              </div>
              <div className="plan-bill-note">{billNote}</div>
              {savings > 0
                ? <span className="plan-savings"><I.Zap size={11} /> Save {savings}% vs monthly</span>
                : <span style={{ display: "inline-block", height: 22 }} />}

              <div className="plan-divider"></div>

              <ul className="plan-feature-list">
                {FEATURE_ROWS(p).map((f) => (
                  <li key={f.label}>
                    <img src={f.iconUrl} alt="" className="plan-feat-icon-img" />
                    <span className="plan-feat-label">{f.label}</span>
                    <span className="plan-feat-amount">{f.amount}</span>
                  </li>
                ))}
              </ul>

              <div className="plan-cta">
                {selected
                  ? <><I.Check size={14} strokeWidth={3} /> &nbsp;Selected</>
                  : `Start ${TRIAL_DAYS}-day free trial`}
              </div>
            </div>
          );
        })}
      </div>

      <div className="trust-strip">
        {TRUST_ITEMS.map((t) => (
          <div className="trust-item" key={t.title}>
            <img src={t.iconUrl} alt="" className="trust-icon-img" />
            <div className="trust-text">
              <strong>{t.title}</strong>
              {t.body}
            </div>
          </div>
        ))}
      </div>

      <div className="text-center mt-10">
        <div style={{ fontSize: 12, letterSpacing: "0.08em", textTransform: "uppercase", color: "#555", fontWeight: 700 }}>
          Trusted by top D2C growth teams and agencies
        </div>
        <div className="logo-strip">
          {CUSTOMER_LOGOS.map((l) => (
            <img key={l.name} src={l.url} alt={l.name} className="customer-logo" />
          ))}
        </div>
      </div>

      <div className="sticky-cta">
        <div className="row gap-3">
          <button className="bl-btn bl-btn-ghost" onClick={onBack} disabled={saving}>
            <I.ArrowLeft size={14} /> Back
          </button>
          {selectedPlan ? (
            <div className="plan-summary-flash">
              <strong>{selectedPlan.tier}</strong> · ${selectedPlan.interval === "Yearly" ? Math.round(selectedPlan.price / 12) : selectedPlan.price}/mo · {TRIAL_DAYS} days free
            </div>
          ) : (
            <div style={{ fontSize: 13, color: "#555" }}>Pick a plan to continue · You won't be charged today</div>
          )}
        </div>
        <button className={"bl-btn bl-btn-primary" + (canNext ? " pulse" : "")} onClick={onNext} disabled={!canNext || saving}>
          {saving ? "Saving…" : <>Continue to checkout <I.ArrowRight size={14} /></>}
        </button>
      </div>
    </div>
  );
}

function IntervalToggle({ value, onChange, maxSavings }) {
  const opts = ["Monthly", "Yearly"];
  return (
    <div className="interval-toggle">
      {opts.map((o) => {
        const active = value === o;
        return (
          <button key={o} className={active ? "active" : ""} onClick={() => onChange(o)}>
            {o}
            {o === "Yearly" && maxSavings > 0 && <span className="save-pill">Save {maxSavings}%</span>}
          </button>
        );
      })}
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════
// Checkout Step — order summary + Stripe Payment Link redirect.
// (Stripe hosts the actual card form; trial logic + payment baked into the link.)
// ═══════════════════════════════════════════════════════════════════
function CheckoutStep({ selectedPlanId, billingInterval, user, onBack }) {
  const plan = PLANS.find((p) => p.id === selectedPlanId);
  if (!plan) {
    return (
      <div className="gs-page text-center">
        <p className="gs-sub">Pick a plan first.</p>
        <button className="bl-btn bl-btn-secondary mt-6" onClick={onBack}>
          <I.ArrowLeft size={14} /> Back to plans
        </button>
      </div>
    );
  }

  const isYearly = plan.interval === "Yearly";
  const price = plan.price;
  const monthlyEquivalent = isYearly ? Math.round(plan.price / 12) : plan.price;
  const savings = isYearly ? yearlySavingsPct(plan.tier) : 0;
  const savedDollars = isYearly
    ? (PLANS.find((p) => p.tier === plan.tier && p.interval === "Monthly")?.price || 0) * 12 - plan.price
    : 0;
  const trialEnds = new Date(Date.now() + TRIAL_DAYS * 86400000)
    .toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

  const emailParam = user?.email ? `?prefilled_email=${encodeURIComponent(user.email)}` : "";
  const paymentLinkUrl = `${plan.trialPaymentLink}${emailParam}`;

  const handlePay = () => {
    window.location.href = paymentLinkUrl;
  };

  return (
    <div className="gs-page">
      <div className="text-center mb-6">
        <div className="trial-banner">
          <span className="trial-dot"></span>
          You won't be charged today · Trial starts now
        </div>
        <h1 className="gs-headline">Activate your {TRIAL_DAYS}-day free trial</h1>
        <p className="gs-sub">Add a payment method so we can keep you in Brieflee after your trial. Cancel any time, in one click.</p>
      </div>

      <div className="checkout-grid">
        {/* LEFT: order summary + testimonial (balances the right column height) */}
        <div className="stack gap-4">
          <div className="bl-card summary-card">
            <div className="row-between mb-4">
              <div>
                <div className="plan-tier">{plan.tier} plan</div>
                <div style={{ fontFamily: "var(--gs-font)", fontSize: 22, fontWeight: 700, color: "#001364", letterSpacing: "-0.01em" }}>
                  Brieflee {plan.tier} · {plan.interval}
                </div>
              </div>
              <button onClick={onBack} className="bl-btn bl-btn-secondary" style={{ padding: "8px 12px", fontSize: 13 }}>
                Change
              </button>
            </div>

            <ul className="plan-feature-list" style={{ marginBottom: 0 }}>
              {FEATURE_ROWS(plan).slice(0, 5).map((f) => (
                <li key={f.label}>
                  <img src={f.iconUrl} alt="" className="plan-feat-icon-img" />
                  <span className="plan-feat-label">{f.label}</span>
                  <span className="plan-feat-amount">{f.amount}</span>
                </li>
              ))}
            </ul>

            <div className="summary-divider" />

            <div className="stack gap-2">
              <div className="price-row">
                <span>{plan.interval} subscription</span>
                <span>${price.toLocaleString()}</span>
              </div>
              <div className="price-row">
                <span>{TRIAL_DAYS}-day trial discount</span>
                <span style={{ color: "#166534", fontWeight: 600 }}>−${price.toLocaleString()}</span>
              </div>
              {savedDollars > 0 && (
                <div className="price-row" style={{ color: "#166534" }}>
                  <span>Annual savings</span>
                  <span style={{ fontWeight: 600 }}>−${savedDollars.toLocaleString()} ({savings}% off)</span>
                </div>
              )}
              <div className="price-row total">
                <span>Due today</span>
                <span>$0.00</span>
              </div>
              <div style={{ fontSize: 12, color: "#555", marginTop: 4 }}>
                On {trialEnds} you'll be charged ${price.toLocaleString()}{isYearly ? " for the year" : " for the month"}. Cancel any time before then.
              </div>
            </div>
          </div>

          <div className="testimonial">
            <div className="row gap-2 mb-3" style={{ color: "#f5b301" }}>
              {[1, 2, 3, 4, 5].map((i) => <I.Star key={i} size={14} fill="currentColor" stroke="currentColor" />)}
            </div>
            <p style={{ margin: 0, fontSize: 14, lineHeight: 1.5, color: "#001364" }}>
              "Brieflee cut our UGC review queue from a full afternoon to 12 minutes. The QA scoring is the part our brand managers won't shut up about."
            </p>
            <div className="row gap-3 mt-4">
              <div style={{ width: 36, height: 36, borderRadius: 999, background: "#d9e0ff", display: "inline-flex", alignItems: "center", justifyContent: "center", color: "#294ff6", fontWeight: 700, fontSize: 14 }}>MR</div>
              <div>
                <div style={{ fontSize: 13, fontWeight: 700, color: "#001364" }}>Maya Reyes</div>
                <div style={{ fontSize: 12, color: "#555" }}>Head of Creator Ops · Hello Bello</div>
              </div>
            </div>
          </div>
        </div>

        {/* RIGHT: pay CTA + trust card */}
        <div className="stack gap-4">
          <div className="bl-card pay-panel">
            <div className="row gap-2 mb-3">
              <I.Lock size={16} />
              <span style={{ fontWeight: 700, color: "#001364" }}>Continue to secure checkout</span>
            </div>
            <p style={{ fontSize: 14, color: "#333", lineHeight: 1.55, margin: "0 0 20px" }}>
              We'll send you to Stripe's secure checkout page to enter your card. Your {TRIAL_DAYS}-day free trial starts immediately — you won't be charged until {trialEnds}.
            </p>

            <button className="bl-btn bl-btn-primary pulse pay-cta" onClick={handlePay}>
              Pay $0 and start your {TRIAL_DAYS}-day trial <I.ArrowRight size={14} />
            </button>

            <p className="text-center mt-4" style={{ fontSize: 12, color: "#555", lineHeight: 1.55 }}>
              By starting your trial you agree to Brieflee's <a href="https://www.brieflee.co/terms">Terms</a> and <a href="https://www.brieflee.co/privacy">Privacy</a>.
              You won't be charged during the {TRIAL_DAYS}-day trial. End your subscription at any time with one click.
            </p>
          </div>

          <div className="bl-card" style={{ padding: 18 }}>
            <div className="stack gap-3">
              <div className="row gap-3" style={{ alignItems: "center" }}>
                <img src={CHECKOUT_TRUST_ICONS.guarantee} alt="" className="checkout-trust-icon" />
                <div style={{ fontSize: 13, lineHeight: 1.4 }}>
                  <strong style={{ color: "#001364" }}>15-day money-back guarantee</strong><br />
                  <span style={{ color: "#555" }}>Full refund within 15 days, no questions asked.</span>
                </div>
              </div>
              <div className="row gap-3" style={{ alignItems: "center" }}>
                <img src={CHECKOUT_TRUST_ICONS.cancel} alt="" className="checkout-trust-icon" />
                <div style={{ fontSize: 13, lineHeight: 1.4 }}>
                  <strong style={{ color: "#001364" }}>Cancel any time</strong><br />
                  <span style={{ color: "#555" }}>One click in settings. No emails, no friction.</span>
                </div>
              </div>
              <div className="row gap-3" style={{ alignItems: "center" }}>
                <img src={CHECKOUT_TRUST_ICONS.secure} alt="" className="checkout-trust-icon" />
                <div style={{ fontSize: 13, lineHeight: 1.4 }}>
                  <strong style={{ color: "#001364" }}>Secure checkout</strong><br />
                  <span style={{ color: "#555" }}>Powered by Stripe. We never see your card.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div className="text-center mt-10">
        <button className="bl-btn bl-btn-ghost" onClick={onBack}>
          <I.ArrowLeft size={14} /> Choose a different plan
        </button>
      </div>
    </div>
  );
}

