import { useState, useEffect, useRef } from 'react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
import { useCurrentUser } from '@/lib/user';
import { useRecordCreate, useRecord, q } from '@/lib/datasource';
import { toast } from 'sonner';
import { Globe } from 'lucide-react';

const createFields = q.select({
  website: 'RaK4B',
  description: 'RQcNB',
  useCase: 'i3nJ9',
  users: 'LNSSK',
  owner: 'ISmqP'
});



export default function Block() {
  const [showTyping1, setShowTyping1] = useState(false);
  const [showMessage1, setShowMessage1] = useState(false);
  const [showTyping2, setShowTyping2] = useState(false);
  const [showInputArea, setShowInputArea] = useState(false);
  const [showTyping3, setShowTyping3] = useState(false);
  const [showMessage2, setShowMessage2] = useState(false);
  const [showTyping4, setShowTyping4] = useState(false);
  const [showUseCases, setShowUseCases] = useState(false);

  const [saved, setSaved] = useState(false);
  const [accountRecordId, setAccountRecordId] = useState(null);
  const [showLoadingTyping, setShowLoadingTyping] = useState(false);
  const [showLoadingMessage, setShowLoadingMessage] = useState(false);
  const [showLoadingAnimation, setShowLoadingAnimation] = useState(false);
  const [showReadyTyping, setShowReadyTyping] = useState(false);
  const [showReadyMessage, setShowReadyMessage] = useState(false);
  const [showReadyButton, setShowReadyButton] = useState(false);

  const [hasWebsite, setHasWebsite] = useState(true);
  const [websiteUrl, setWebsiteUrl] = useState('');
  const [description, setDescription] = useState('');
  const [selectedUseCases, setSelectedUseCases] = useState([]);
  const [otherUseCase, setOtherUseCase] = useState('');
  const [showOtherInput, setShowOtherInput] = useState(false);
  const [websiteSubmitted, setWebsiteSubmitted] = useState(false);

  const loadingRef = useRef(null);
  const user = useCurrentUser();

  useEffect(() => {
    setTimeout(() => setShowTyping1(true), 300);
    setTimeout(() => { setShowTyping1(false); setShowMessage1(true); }, 1800);
    setTimeout(() => setShowTyping2(true), 2300);
    setTimeout(() => { setShowTyping2(false); setShowInputArea(true); }, 3800);
  }, []);

  useEffect(() => {
    if (accountRecordId) {
      const timer = setTimeout(() => {
        setShowLoadingAnimation(false);
        setShowReadyTyping(true);
        setTimeout(() => { setShowReadyTyping(false); setShowReadyMessage(true); }, 1500);
        setTimeout(() => setShowReadyButton(true), 2000);
      }, 120000);
      return () => clearTimeout(timer);
    }
  }, [accountRecordId]);

  useEffect(() => {
    if (showReadyMessage && loadingRef.current) {
      loadingRef.current.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [showReadyMessage]);

  const createRecord = useRecordCreate({
    fields: createFields,
    onSuccess: (newRecord) => {
      setSaved(true);
      setAccountRecordId(newRecord.id);
      setShowLoadingTyping(true);
      setTimeout(() => { setShowLoadingTyping(false); setShowLoadingMessage(true); }, 1800);
      setTimeout(() => { setShowLoadingAnimation(true); }, 2300);
    },
    onError: (error) => {
      toast.error('Failed to save brand setup', { description: error.message });
    }
  });

  const isValidUrl = (url) => {
    try {
      const urlObj = new URL(url);
      return urlObj.protocol === 'http:' || urlObj.protocol === 'https:';
    } catch { return false; }
  };

  const handleWebsiteSubmit = () => {
    if (hasWebsite && !websiteUrl) { toast.error('Please enter your website URL'); return; }
    if (hasWebsite && !isValidUrl(websiteUrl)) { toast.error('Please enter a valid URL (must start with http:// or https://)'); return; }
    if (!hasWebsite && description.length < 100) { toast.error('Please write at least 100 characters about your brand'); return; }
    setWebsiteSubmitted(true);
    setShowTyping3(true);
    setTimeout(() => { setShowTyping3(false); setShowMessage2(true); }, 1500);
    setTimeout(() => setShowTyping4(true), 2000);
    setTimeout(() => { setShowTyping4(false); setShowUseCases(true); }, 3500);
  };

  const handleContinue = () => {
    if (selectedUseCases.length === 0) { toast.error('Please select at least one use case'); return; }
    const useCaseIds = selectedUseCases.map(label => {
      const choices = {
        'Review UGC creator submissions': '8a24a59b-40f7-4988-851e-e2837c7da0ba',
        'Review Influencer submissions': '92b35e89-622b-41fb-abca-78a30b55f8f1',
        'Build content example library': 'f52025ba-dd9d-4a6b-85fc-6305704a23da',
        'Agency managing multiple brands': '4db3a81a-c5c3-4c86-a6a3-33d7d04cedcb',
        'Other': '825f9e77-c70b-42a1-b3ec-516b25fccde9'
      };
      return choices[label];
    });
    createRecord.mutate({
      website: hasWebsite ? websiteUrl : null,
      description: !hasWebsite ? description : null,
      useCase: useCaseIds,
      users: user?.id ? [user.id] : [],
      owner: user?.id ? [user.id] : []
    });
  };

  const toggleUseCase = (label) => {
    if (label === 'Other') { setShowOtherInput(!showOtherInput); }
    if (selectedUseCases.includes(label)) {
      setSelectedUseCases(selectedUseCases.filter(c => c !== label));
    } else {
      setSelectedUseCases([...selectedUseCases, label]);
    }
  };

  const strengthColor = description.length < 100 ? '#d92626' : '#20956f';
  const strengthLabel = description.length < 100 ? 'Too short' : 'Strong';
  return (
    <div className="min-h-screen flex flex-col" style={{ background: 'linear-gradient(to bottom, rgba(217, 224, 255, 0.15), rgba(255, 255, 255, 1))' }}>
      <style>
        {`
          @import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;500;800&display=swap');
          * { font-family: 'League Spartan', sans-serif; }
          @keyframes bounce {
            0%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-8px); }
          }
          .typing-dot { animation: bounce 1.4s infinite; }
          .typing-dot:nth-child(2) { animation-delay: 0.2s; }
          .typing-dot:nth-child(3) { animation-delay: 0.4s; }
          @keyframes globeRotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
          }
          @keyframes scanLine {
            0% { top: 15%; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: 80%; opacity: 0; }
          }
          @keyframes pulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
          }
          @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
          }
        `}
      </style>

      <div className="flex-1 overflow-y-auto pb-48">
        <div className="container mx-auto px-4 py-8 max-w-2xl">
          {/* Progress — 7 dots */}
          <div className="mb-6">
            <div className="flex items-center justify-center gap-2">
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#7A93FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#7A93FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#D9E0FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full" style={{ backgroundColor: '#D9E0FF' }}></div>
              <div className="h-1.5 w-1.5 rounded-full bg-gray-200"></div>
              <div className="h-1.5 w-1.5 rounded-full bg-gray-200"></div>
              <div className="h-1.5 w-1.5 rounded-full bg-gray-200"></div>
            </div>
          </div>

          {/* Typing 1 */}
          {showTyping1 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 1 — Lee asks for website */}
          {showMessage1 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Great! First I need to gather some information about your brand. Could you please provide me the URL of your company's website? I'll use this to build your content blueprint.
                  </p>
                </div>
              </div>
              <div className="ml-10 mt-2">
                <button onClick={() => setHasWebsite(!hasWebsite)} className="text-xs" style={{ color: '#7A93FF', fontWeight: 500 }}>
                  {hasWebsite ? "Don't have a website?" : "Have a website? Enter URL instead"}
                </button>
              </div>
            </div>
          )}

          {/* Typing 2 */}
          {showTyping2 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <div className="w-8 h-8 flex-shrink-0"></div>
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Inline input — website URL or description */}
          {showInputArea && !websiteSubmitted && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="max-w-lg">
                {hasWebsite ? (
                  <div className="space-y-3">
                    <div className="relative">
                      <div className="absolute left-3 top-1/2 -translate-y-1/2">
                        <Globe className="w-4 h-4" style={{ color: '#7A93FF' }} />
                      </div>
                      <input type="url" value={websiteUrl} onChange={(e) => setWebsiteUrl(e.target.value)} placeholder="https://yourbrand.com"
                        className="w-full pl-10 pr-4 py-3 rounded-xl text-sm bg-white outline-none transition-all duration-200"
                        style={{ border: '1px solid rgba(217, 224, 255, 0.4)', color: '#000F4D', fontWeight: 300 }}
                        onFocus={(e) => e.target.style.borderColor = '#7A93FF'}
                        onBlur={(e) => e.target.style.borderColor = 'rgba(217, 224, 255, 0.4)'}
                      />
                    </div>
                    <Button onClick={handleWebsiteSubmit} disabled={!websiteUrl || !isValidUrl(websiteUrl)}
                      className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300"
                      style={{ backgroundColor: (!websiteUrl || !isValidUrl(websiteUrl)) ? '#D9E0FF' : '#7A93FF', color: '#FFFFFF', borderRadius: '8px', fontWeight: 500, cursor: (!websiteUrl || !isValidUrl(websiteUrl)) ? 'not-allowed' : 'pointer' }}>
                      Submit →
                    </Button>
                  </div>
                ) : (
                  <div className="space-y-3">
                    <textarea value={description} onChange={(e) => setDescription(e.target.value)}
                      placeholder="Type a few sentences on your business. Brieflee will use this information to create a custom content blueprint for you. The more details you can provide, the better."
                      rows={5} className="w-full text-sm rounded-xl p-3 outline-none resize-none transition-all duration-200"
                      style={{ border: '1px solid rgba(217, 224, 255, 0.4)', color: '#000F4D', fontWeight: 300, backgroundColor: '#FFFFFF' }}
                      onFocus={(e) => e.target.style.borderColor = '#7A93FF'}
                      onBlur={(e) => e.target.style.borderColor = 'rgba(217, 224, 255, 0.4)'}
                    />
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-2">
                        <div className="h-1.5 w-20 bg-gray-200 rounded-full overflow-hidden">
                          <div className="h-full transition-all duration-300" style={{ width: `${Math.min((description.length / 100) * 100, 100)}%`, backgroundColor: strengthColor }}></div>
                        </div>
                        <span className="text-xs" style={{ color: strengthColor, fontWeight: 500 }}>{strengthLabel}</span>
                      </div>
                      <span className="text-xs" style={{ color: '#001364', fontWeight: 300 }}>{description.length}/100</span>
                    </div>
                    <Button onClick={handleWebsiteSubmit} disabled={description.length < 100}
                      className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300"
                      style={{ backgroundColor: description.length < 100 ? '#D9E0FF' : '#7A93FF', color: '#FFFFFF', borderRadius: '8px', fontWeight: 500, cursor: description.length < 100 ? 'not-allowed' : 'pointer' }}>
                      Submit →
                    </Button>
                  </div>
                )}
              </div>
            </div>
          )}

          {/* Typing 3 */}
          {showTyping3 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 2 — How will you use Brieflee? */}
          {showMessage2 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>How will you use Brieflee?</p>
                </div>
              </div>
            </div>
          )}

          {/* Typing 4 */}
          {showTyping4 && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <div className="w-8 h-8 flex-shrink-0"></div>
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Use case cards */}
          {showUseCases && (
            <>
              <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
                <div className="space-y-3 max-w-lg">
                  {['Review UGC creator submissions', 'Review Influencer submissions', 'Build content example library', 'Agency managing multiple brands', 'Other'].map((label) => (
                    <div key={label} className="space-y-2">
                      <button onClick={() => !saved && toggleUseCase(label)}
                        className="flex items-center gap-2 w-full text-left px-4 py-3 rounded-xl transition-all duration-200 bg-white shadow-sm"
                        style={{
                          border: selectedUseCases.includes(label) ? '2px solid #7A93FF' : '1px solid rgba(217, 224, 255, 0.4)',
                          backgroundColor: selectedUseCases.includes(label) ? 'rgba(122, 147, 255, 0.05)' : '#FFFFFF',
                          opacity: saved ? 0.6 : 1, cursor: saved ? 'default' : 'pointer'
                        }}>
                        <div className="w-5 h-5 rounded border-2 flex items-center justify-center flex-shrink-0"
                          style={{ borderColor: selectedUseCases.includes(label) ? '#7A93FF' : 'rgba(217, 224, 255, 0.5)' }}>
                          {selectedUseCases.includes(label) && (<div className="w-2.5 h-2.5 rounded-sm" style={{ backgroundColor: '#7A93FF' }}></div>)}
                        </div>
                        <span className="text-sm" style={{ color: '#000F4D', fontWeight: 300 }}>{label}</span>
                      </button>
                      {label === 'Other' && showOtherInput && !saved && (
                        <div className="ml-7">
                          <input type="text" placeholder="Please specify..." value={otherUseCase} onChange={(e) => setOtherUseCase(e.target.value)}
                            className="w-full px-4 py-3 rounded-xl text-sm bg-white outline-none transition-all duration-200"
                            style={{ border: '1px solid rgba(217, 224, 255, 0.4)', color: '#000F4D', fontWeight: 300 }}
                            onFocus={(e) => e.target.style.borderColor = '#7A93FF'}
                            onBlur={(e) => e.target.style.borderColor = 'rgba(217, 224, 255, 0.4)'} />
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
              <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
                <Button onClick={handleContinue}
                  disabled={saved || createRecord.status === 'pending' || selectedUseCases.length === 0}
                  className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300"
                  style={{
                    backgroundColor: saved ? '#D9E0FF' : (selectedUseCases.length === 0) ? '#D9E0FF' : '#7A93FF',
                    color: '#FFFFFF', borderRadius: '8px', fontWeight: 500,
                    cursor: saved ? 'default' : (selectedUseCases.length === 0) ? 'not-allowed' : 'pointer'
                  }}>
                  {saved ? 'Saved ✓' : createRecord.status === 'pending' ? 'Saving...' : 'Continue →'}
                </Button>
              </div>
            </>
          )}

          {/* ================================================ */}
          {/* POST-SAVE: Loading & polling for blueprint        */}
          {/* ================================================ */}

          {/* Loading typing */}
          {showLoadingTyping && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Loading message from Lee */}
          {showLoadingMessage && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Give me a moment — I'm scanning your website and building your content blueprint...
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Loading animation — globe with scanning effect */}
          {showLoadingAnimation && (
            <div ref={loadingRef} className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="bg-white rounded-2xl p-8 shadow-sm max-w-xs flex flex-col items-center text-center" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                {/* Globe with spinning ring and scan line */}
                <div style={{ position: 'relative', width: '80px', height: '80px' }}>
                  {/* Spinning outer ring */}
                  <div style={{
                    position: 'absolute', inset: 0,
                    border: '3px solid #D9E0FF', borderTop: '3px solid #7A93FF',
                    borderRadius: '50%', animation: 'globeRotate 2s linear infinite'
                  }}></div>
                  {/* Globe icon in center */}
                  <div style={{ position: 'absolute', inset: 0, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                    <Globe style={{ width: '28px', height: '28px', color: '#294FF6' }} />
                  </div>
                  {/* Scan line */}
                  <div style={{
                    position: 'absolute', left: '15%', right: '15%', height: '2px',
                    background: 'linear-gradient(90deg, transparent, #7A93FF, transparent)',
                    borderRadius: '1px', animation: 'scanLine 2s ease-in-out infinite'
                  }}></div>
                </div>

                <p className="mt-5 text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>Scouring your website...</p>
                <p className="mt-1.5 text-xs leading-relaxed" style={{ color: '#001364', fontWeight: 300 }}>
                  Building your content blueprint. This usually takes a minute or two.
                </p>

                {/* Pulsing dots */}
                <div className="flex gap-1.5 mt-5">
                  <div className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: '#7A93FF', animation: 'pulse 1.5s ease-in-out infinite' }}></div>
                  <div className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: '#7A93FF', animation: 'pulse 1.5s ease-in-out 0.3s infinite' }}></div>
                  <div className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: '#7A93FF', animation: 'pulse 1.5s ease-in-out 0.6s infinite' }}></div>
                </div>
              </div>
            </div>
          )}

          {/* Ready typing */}
          {showReadyTyping && (
            <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Ready message */}
          {showReadyMessage && (
            <div ref={loadingRef} className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className="flex gap-2.5 items-start">
                <img src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" alt="Lee" className="w-8 h-8 rounded-full flex-shrink-0" />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Your content blueprint is ready! Let's take a look and make sure everything looks right.
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Continue to blueprint review button */}
          {showReadyButton && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <Button
                onClick={() => {
                  window.location.href = '/review-account';
                }}
                className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300"
                style={{ backgroundColor: '#7A93FF', color: '#FFFFFF', borderRadius: '8px', fontWeight: 500 }}>
                Review your blueprint →
              </Button>
            </div>
          )}

        </div>
      </div>
    </div>
  );
}
