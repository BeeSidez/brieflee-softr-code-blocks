// ═══════════════════════════════════════════════════════════════════
// Main Block
// ═══════════════════════════════════════════════════════════════════
export default function Block() {
  const user = useCurrentUser();
  const [step, setStep] = useState("team");
  const [saving, setSaving] = useState(false);

  const [teamName, setTeamName] = useState("");
  const [teamEmails, setTeamEmails] = useState(["", "", ""]);
  const [workTypeId, setWorkTypeId] = useState(null);
  const [heardAboutUsId, setHeardAboutUsId] = useState(null);
  const [billingInterval, setBillingInterval] = useState("Yearly");
  const [selectedPlanId, setSelectedPlanId] = useState(null);

  const { data: accountData } = useLinkedRecords({
    select, field: "accounts", count: 1,
  });
  const userAccount = accountData?.pages.flatMap((p) => p.items)[0] ?? null;

  useEffect(() => {
    if (userAccount?.title && !teamName) setTeamName(userAccount.title);
  }, [userAccount]); // eslint-disable-line

  const updateRecord = useRecordUpdate({
    fields: select,
    onError(err) {
      console.error("=== get-started save error:", err);
      toast.error("Save failed", { description: err?.message || "Open the console for details." });
      setSaving(false);
    },
  });

  const goNext = () => {
    const i = STEPS.findIndex((s) => s.id === step);
    if (i < STEPS.length - 1) setStep(STEPS[i + 1].id);
    setSaving(false);
    if (typeof window !== "undefined") window.scrollTo({ top: 0, behavior: "smooth" });
  };
  const goBack = () => {
    const i = STEPS.findIndex((s) => s.id === step);
    if (i > 0) setStep(STEPS[i - 1].id);
    if (typeof window !== "undefined") window.scrollTo({ top: 0, behavior: "smooth" });
  };

  const handleTeamNext = async ({ skip }) => {
    if (skip) { goNext(); return; }
    if (!userAccount?.id) { goNext(); return; }
    if (!TEAM_UPDATE_WORKFLOW_URL) {
      console.warn("=== TEAM_UPDATE_WORKFLOW_URL is empty; team data not persisted to accounts");
      goNext();
      return;
    }
    setSaving(true);
    try {
      const cleanedEmails = teamEmails.filter((e) => e && e.trim()).join(", ");
      const res = await fetch(TEAM_UPDATE_WORKFLOW_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          accountId: userAccount.id,
          teamName: teamName.trim() || userAccount.title || "",
          teamEmails: cleanedEmails,
        }),
      });
      if (!res.ok) throw new Error(`team workflow ${res.status}`);
      goNext();
    } catch (e) {
      console.error("=== team save failed:", e);
      toast.error("Couldn't save team", { description: e.message });
      setSaving(false);
    }
  };

  const handlePersonalizeNext = () => {
    if (!user?.id) { toast.error("Not signed in"); return; }
    if (updateRecord.enabled === false) {
      toast.error("Saving is disabled — check Visibility / permissions in Softr.");
      return;
    }
    if (!workTypeId || !heardAboutUsId) return;
    setSaving(true);
    updateRecord.mutate(
      {
        recordId: user.id,
        fields: {
          workType: toIdLabel(WORK_TYPE_OPTIONS, workTypeId),
          heardAboutUs: toIdLabel(HEARD_FROM_OPTIONS, heardAboutUsId),
        },
      },
      { onSuccess: goNext },
    );
  };

  const handlePlanNext = () => {
    if (!user?.id) { toast.error("Not signed in"); return; }
    if (!selectedPlanId) return;
    setSaving(true);
    updateRecord.mutate(
      { recordId: user.id, fields: { plan: [{ id: selectedPlanId }] } },
      { onSuccess: goNext },
    );
  };

  return (
    <div className="gs-root">
      <BlockStyles />
      <div className="gs-shell">
        {/* Topbar */}
        <header className="gs-topbar">
          <div className="gs-topbar-inner">
            <a href="/" aria-label="Brieflee">
              <img src={LOGO_WORDMARK} alt="Brieflee" className="gs-logo" />
            </a>
            <div className="gs-stepper-wrap"><Stepper currentId={step} /></div>
            <div className="gs-help">Need help? <a href="mailto:hi@brieflee.co">Contact us</a></div>
          </div>
        </header>

        {step === "team" && (
          <TeamStep
            teamName={teamName} setTeamName={setTeamName}
            teamEmails={teamEmails} setTeamEmails={setTeamEmails}
            onNext={() => handleTeamNext({ skip: false })}
            onSkip={() => handleTeamNext({ skip: true })}
            saving={saving}
          />
        )}
        {step === "personalize" && (
          <PersonalizeStep
            workTypeId={workTypeId} setWorkTypeId={setWorkTypeId}
            heardAboutUsId={heardAboutUsId} setHeardAboutUsId={setHeardAboutUsId}
            onNext={handlePersonalizeNext} onBack={goBack}
            saving={saving}
          />
        )}
        {step === "pricing" && (
          <PricingStep
            billingInterval={billingInterval} setBillingInterval={setBillingInterval}
            selectedPlanId={selectedPlanId} setSelectedPlanId={setSelectedPlanId}
            onNext={handlePlanNext} onBack={goBack}
            saving={saving}
          />
        )}
        {step === "checkout" && (
          <CheckoutStep
            selectedPlanId={selectedPlanId} billingInterval={billingInterval}
            user={user} onBack={goBack}
          />
        )}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════
// Stepper (pill-style, top-of-page)
// ═══════════════════════════════════════════════════════════════════
function Stepper({ currentId }) {
  const idx = STEPS.findIndex((s) => s.id === currentId);
  return (
    <div className="step-row">
      {STEPS.map((s, i) => {
        const done = i < idx;
        const active = i === idx;
        const klass = active ? "step-pill active" : done ? "step-pill done" : "step-pill";
        return (
          <span key={s.id} style={{ display: "inline-flex", alignItems: "center" }}>
            <span className={klass}>
              <span className="step-dot">
                {done ? <I.Check size={11} strokeWidth={3} /> : i + 1}
              </span>
              <span>{s.label}</span>
            </span>
            {i < STEPS.length - 1 && <span className="step-sep" />}
          </span>
        );
      })}
    </div>
  );
}

