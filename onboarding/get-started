  { id: "041f445c-3c48-4089-b06d-fd02f109b1b8", label: "Google Search" },
  { id: "435a25e8-d3c4-4650-8022-81381dc5beac", label: "YouTube" },
  { id: "c4c24270-59cc-463a-b7a4-b9b67a72e4b2", label: "Newsletter" },
