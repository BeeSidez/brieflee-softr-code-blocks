      .plan-card:hover { transform: translateY(-2px); border-color: var(--bl-blue-4); box-shadow: var(--bl-shadow); }
      .plan-card.popular {
        border-color: var(--bl-blue-5);
        box-shadow: 0 12px 32px -10px rgba(135,156,247,0.45);
        transform: translateY(-4px);
