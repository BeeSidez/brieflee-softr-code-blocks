const PLANS = [
  { id: "MOFJ50J3sX5cQ4", tier: "Creator", interval: "Monthly", price: 59,   stripePriceId: "price_1SGHuzIG1gGY9y21517vrys7", maxVideos: 30,  maxWorkspaces: 1,  maxUsers: 1 },
  { id: "efLCArKogDzBco", tier: "Creator", interval: "Yearly",  price: 588,  stripePriceId: "price_1SGHvdIG1gGY9y21twF3H7NU", maxVideos: 30,  maxWorkspaces: 1,  maxUsers: 1 },
