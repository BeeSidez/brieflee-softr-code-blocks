// Get Started — single multi-step form on /get-started.
// Steps: team → personalize → pricing → checkout. Stage 2 of the 3-stage onboarding.
//
// SOFTR CONFIG NEEDED:
//   Primary table binding: users
//   Actions tab → add update_user (table: users, fields: work_type, heard_about_us, Plan)
//   Actions tab → add update_account (table: accounts, fields: name, team_emails)
//   Data sources → add pricing data source (table: pricing) so the pricing-step list loads
//
// Trial is per-Stripe-Session (trial_period_days: 7), set by the backend endpoint that
// creates the Checkout Session — pricing rows themselves carry no trial config.

import { useState, useEffect, useMemo } from 'react';
import { Check } from 'lucide-react';
import { useRecords, useRecordUpdate, q } from '@/lib/datasource';
import { toast } from 'sonner';

const userSelect = q.select({
  fullName: 'Pk6Tx',
  email: 'PBrIP',
  workType: 'Xqhif',
  heardAboutUs: 'B8uMy',
  plan: 'Ux1pf',
  accountIds: 'Nz6VX',
  accountName: 'uCxtP',
});

const userUpdateFields = q.select({
  workType: 'Xqhif',
  heardAboutUs: 'B8uMy',
  plan: 'Ux1pf',
});

const accountUpdateFields = q.select({
  name: 'aAKkT',
  teamEmails: 'wIvhQ',
});

const pricingSelect = q.select({
  productName: 'OyXm9',
  price: 'nI2YF',
  tier: 'jgaYP',
  interval: 'CSTWq',
  maxVideos: 'NFbCM',
  maxWorkspaces: 'fvkuh',
  maxUsers: 'tZBGk',
  stripePriceId: 'CJjrn',
});

const STEPS = [
  { id: 'team', label: 'Team' },
  { id: 'personalize', label: 'Personalize' },
  { id: 'pricing', label: 'Plan' },
  { id: 'checkout', label: 'Checkout' },
];

const WORK_TYPES = [
  'Agency', 'Brand', 'App or Game', 'Software', 'Freelancer', 'Solo creator', 'Other',
];
const HEARD_FROM = [
  'X / Twitter', 'LinkedIn', 'Instagram', 'TikTok', 'Google Search', 'YouTube',
  'Newsletter', 'Podcast', 'Word of mouth', 'From a friend / colleague',
  'From a client', 'Ad I saw', 'Other',
];

const FEATURES = [
  { key: 'maxVideos',     label: (v) => `${v} videos / mo` },
  { key: 'maxWorkspaces', label: (v) => `${v} ${v === 1 ? 'workspace' : 'workspaces'}` },
  { key: 'maxUsers',      label: (v) => `${v} ${v === 1 ? 'seat' : 'seats'}` },
];

export default function Block() {
  const { data: userData, refetch: refetchUser } = useRecords({ select: userSelect, count: 1 });
  const user = userData?.[0];
  const accountId = Array.isArray(user?.accountIds) ? user.accountIds[0]?.id || user.accountIds[0] : user?.accountIds;

  const { data: pricingData } = useRecords({ select: pricingSelect, count: 50 });

  const [step, setStep] = useState('team');

  const [teamName, setTeamName] = useState('');
  const [teamEmails, setTeamEmails] = useState(['', '', '']);

  const [workType, setWorkType] = useState(null);
  const [heardAboutUs, setHeardAboutUs] = useState(null);

  const [billingInterval, setBillingInterval] = useState('Yearly');
  const [selectedPriceRowId, setSelectedPriceRowId] = useState(null);

  useEffect(() => {
    if (!user) return;
    setTeamName(user.accountName || '');
    setWorkType(user.workType || null);
    setHeardAboutUs(user.heardAboutUs || null);
    if (user.plan) {
      const pid = Array.isArray(user.plan) ? user.plan[0]?.id : user.plan;
      if (pid) setSelectedPriceRowId(pid);
    }
  }, [user]);

  const updateUser = useRecordUpdate({
    fields: userUpdateFields,
    onError: (e) => toast.error("Couldn't save", { description: e.message }),
  });
  const updateAccount = useRecordUpdate({
    fields: accountUpdateFields,
    onError: (e) => toast.error("Couldn't save team details", { description: e.message }),
  });

  const visiblePricingRows = useMemo(() => {
    if (!pricingData) return [];
    const tiers = ['Creator', 'Crew', 'Studio'];
    return pricingData.filter((r) => {
      const tierLabel = r.tier?.label || r.tier;
      const intervalLabel = r.interval?.label || r.interval;
      return tiers.includes(tierLabel) && intervalLabel === billingInterval;
    });
  }, [pricingData, billingInterval]);

  const goNext = () => {
    const i = STEPS.findIndex((s) => s.id === step);
    if (i < STEPS.length - 1) setStep(STEPS[i + 1].id);
  };

  const handleTeamSave = ({ skip }) => {
    if (skip) {
      goNext();
      return;
    }
    if (!accountId) {
      goNext();
      return;
    }
    const cleanedEmails = teamEmails.filter((e) => e && e.trim()).join(', ');
    updateAccount.mutate(
      {
        recordId: accountId,
        fields: { name: teamName.trim() || user?.accountName || '', teamEmails: cleanedEmails },
      },
      { onSuccess: goNext },
    );
  };

  const handlePersonalizeNext = () => {
    if (!user || !workType || !heardAboutUs) return;
    updateUser.mutate(
      { recordId: user.id, fields: { workType, heardAboutUs } },
      { onSuccess: goNext },
    );
  };

  const handlePlanNext = () => {
    if (!user || !selectedPriceRowId) return;
    updateUser.mutate(
      { recordId: user.id, fields: { plan: [selectedPriceRowId] } },
      { onSuccess: goNext },
    );
  };

  const isSavingTeam = updateAccount.status === 'pending';
  const isSavingUser = updateUser.status === 'pending';

  return (
    <div className="min-h-screen" style={{ background: '#FAFBFF' }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;500;800&display=swap');
        * { font-family: 'League Spartan', sans-serif; }
        .gs-input {
          width: 100%;
          padding: 12px 14px;
          border: 1px solid #D6DEFC;
          border-radius: 12px;
          background: #FFFFFF;
          color: #001364;
          font-size: 0.95rem;
          outline: none;
        }
        .gs-input:focus { border-color: #879CF7; }
      `}</style>

      <Stepper currentId={step} />

      <div className="max-w-2xl mx-auto px-6 pb-20">
        {step === 'team' && (
          <TeamStep
            teamName={teamName}
            setTeamName={setTeamName}
            teamEmails={teamEmails}
            setTeamEmails={setTeamEmails}
            onNext={() => handleTeamSave({ skip: false })}
            onSkip={() => handleTeamSave({ skip: true })}
            saving={isSavingTeam}
          />
        )}

        {step === 'personalize' && (
          <PersonalizeStep
            workType={workType}
            setWorkType={setWorkType}
            heardAboutUs={heardAboutUs}
            setHeardAboutUs={setHeardAboutUs}
            onNext={handlePersonalizeNext}
            saving={isSavingUser}
          />
        )}

        {step === 'pricing' && (
          <PricingStep
            rows={visiblePricingRows}
            billingInterval={billingInterval}
            setBillingInterval={setBillingInterval}
            selectedRowId={selectedPriceRowId}
            setSelectedRowId={setSelectedPriceRowId}
            onNext={handlePlanNext}
            saving={isSavingUser}
          />
        )}

        {step === 'checkout' && (
          <CheckoutStep
            user={user}
            pricingRows={pricingData}
            selectedPriceRowId={selectedPriceRowId}
          />
        )}
      </div>
    </div>
  );
}

function Stepper({ currentId }) {
  const idx = STEPS.findIndex((s) => s.id === currentId);
  return (
    <div className="flex items-center justify-center gap-3 py-8 px-4 text-sm flex-wrap">
      {STEPS.map((s, i) => {
        const done = i < idx;
        const active = i === idx;
        const reached = done || active;
        return (
          <div key={s.id} className="flex items-center gap-3">
            <div className="flex items-center gap-2">
              <div
                className="w-5 h-5 rounded-full flex items-center justify-center"
                style={{
                  background: reached ? '#879CF7' : 'transparent',
                  border: reached ? 'none' : '1.5px solid #D6DEFC',
                }}
              >
                {done && <Check className="w-3 h-3" style={{ color: '#FFFFFF' }} strokeWidth={3} />}
              </div>
              <span style={{ color: reached ? '#001364' : '#555555', fontWeight: active ? 700 : 500 }}>
                {s.label}
              </span>
            </div>
            {i < STEPS.length - 1 && <div className="w-12 h-px" style={{ background: '#D6DEFC' }} />}
          </div>
        );
      })}
    </div>
  );
}

function TeamStep({ teamName, setTeamName, teamEmails, setTeamEmails, onNext, onSkip, saving }) {
  const setEmail = (i, val) => setTeamEmails(teamEmails.map((e, k) => (k === i ? val : e)));
  const hasAnyInvite = teamEmails.some((e) => e.trim().length > 0);
  const canNext = teamName.trim().length > 0;

  return (
    <div className="text-center">
      <h1 className="text-3xl mb-3" style={{ color: '#001364', fontWeight: 800 }}>Create your team</h1>
      <p className="mb-12 text-sm leading-relaxed max-w-md mx-auto" style={{ color: '#333333' }}>
        Brieflee is better with friends — invite teammates to join your trial.
      </p>

      <div className="max-w-md mx-auto text-left">
        <label className="block mb-2 text-sm" style={{ color: '#001364', fontWeight: 600 }}>
          Team name
        </label>
        <input
          className="gs-input mb-6"
          placeholder="Ad Rockstars"
          value={teamName}
          onChange={(e) => setTeamName(e.target.value)}
        />

        <div className="rounded-xl px-4 py-3 mb-3 text-sm text-center"
             style={{ background: '#ECF0FF', color: '#001364', fontWeight: 500 }}>
          Enter email addresses to invite your team
        </div>

        {teamEmails.map((val, i) => (
          <input
            key={i}
            type="email"
            className="gs-input mb-2"
            placeholder="name@example.com"
            value={val}
            onChange={(e) => setEmail(i, e.target.value)}
          />
        ))}
      </div>

      <button
        onClick={onNext}
        disabled={!canNext || saving}
        className="mt-8 w-full max-w-md py-3.5 rounded-xl"
        style={{
          background: '#879CF7', color: '#FFFFFF', border: 'none',
          opacity: canNext && !saving ? 1 : 0.4,
          cursor: canNext && !saving ? 'pointer' : 'not-allowed',
          fontWeight: 600,
        }}
      >
        {saving ? 'Saving…' : hasAnyInvite ? 'Send invites' : 'Next'}
      </button>

      <button
        onClick={onSkip}
        disabled={saving}
        className="mt-3 text-sm"
        style={{ color: '#001364', background: 'transparent', border: 'none', cursor: 'pointer', fontWeight: 600 }}
      >
        Skip
      </button>
    </div>
  );
}

function PersonalizeStep({ workType, setWorkType, heardAboutUs, setHeardAboutUs, onNext, saving }) {
  const canNext = Boolean(workType && heardAboutUs);
  return (
    <div className="text-center">
      <h1 className="text-3xl mb-3" style={{ color: '#001364', fontWeight: 800 }}>
        Personalize your Experience
      </h1>
      <p className="mb-12 text-sm leading-relaxed max-w-md mx-auto" style={{ color: '#333333' }}>
        Tell us a bit about your work and how you found us — we'll tune Brieflee to fit.
      </p>

      <Question label="What best describes your work?" options={WORK_TYPES} value={workType} onChange={setWorkType} />
      <Question label="Where did you hear about us?" options={HEARD_FROM} value={heardAboutUs} onChange={setHeardAboutUs} />

      <button
        onClick={onNext}
        disabled={!canNext || saving}
        className="mt-8 w-full max-w-md py-3.5 rounded-xl"
        style={{
          background: '#879CF7', color: '#FFFFFF', border: 'none',
          opacity: canNext && !saving ? 1 : 0.4,
          cursor: canNext && !saving ? 'pointer' : 'not-allowed',
          fontWeight: 600,
        }}
      >
        {saving ? 'Saving…' : 'Next'}
      </button>
    </div>
  );
}

function Question({ label, options, value, onChange }) {
  return (
    <div className="mb-10">
      <p className="mb-5 text-sm" style={{ color: '#001364', fontWeight: 600 }}>
        {label} <span style={{ color: '#879CF7' }}>*</span>
      </p>
      <div className="flex flex-wrap justify-center gap-2 max-w-xl mx-auto">
        {options.map((opt) => {
          const selected = value === opt;
          return (
            <button
              key={opt}
              onClick={() => onChange(opt)}
              className="px-4 py-2 rounded-lg text-sm flex items-center gap-2"
              style={{
                background: selected ? '#879CF7' : '#FFFFFF',
                color: selected ? '#FFFFFF' : '#001364',
                border: selected ? '1px solid #879CF7' : '1px solid #D6DEFC',
                fontWeight: 500, cursor: 'pointer',
              }}
            >
              {selected && <Check className="w-3.5 h-3.5" strokeWidth={3} />}
              {opt}
            </button>
          );
        })}
      </div>
    </div>
  );
}

function PricingStep({ rows, billingInterval, setBillingInterval, selectedRowId, setSelectedRowId, onNext, saving }) {
  const canNext = Boolean(selectedRowId);
  return (
    <div>
      <div className="text-center">
        <h1 className="text-3xl mb-3" style={{ color: '#001364', fontWeight: 800 }}>
          Test one plan 7 days for free
        </h1>
        <p className="mb-8 text-sm leading-relaxed max-w-md mx-auto" style={{ color: '#333333' }}>
          Choose a plan and start your free trial. Cancel anytime.
        </p>

        <IntervalToggle value={billingInterval} onChange={setBillingInterval} />
      </div>

      <div className="grid md:grid-cols-3 gap-4 mt-8">
        {rows.map((r) => {
          const isSelected = selectedRowId === r.id;
          const tierLabel = r.tier?.label || r.tier;
          const intervalLabel = r.interval?.label || r.interval;
          const priceLabel = intervalLabel === 'Yearly'
            ? `$${Math.round((r.price || 0) / 12)} /mo`
            : `$${r.price} /mo`;
          const subLabel = intervalLabel === 'Yearly' ? `Billed $${r.price} annually` : 'Billed monthly';
          return (
            <button
              key={r.id}
              onClick={() => setSelectedRowId(r.id)}
              className="text-left rounded-2xl p-6"
              style={{
                background: '#FFFFFF',
                border: isSelected ? '2px solid #879CF7' : '1px solid #D6DEFC',
                cursor: 'pointer',
              }}
            >
              <div className="text-xs uppercase tracking-wide mb-2" style={{ color: '#879CF7', fontWeight: 700 }}>
                {tierLabel}
              </div>
              <div className="text-2xl mb-1" style={{ color: '#001364', fontWeight: 800 }}>{priceLabel}</div>
              <div className="text-xs mb-5" style={{ color: '#555555' }}>{subLabel}</div>
              <ul className="space-y-2 text-sm" style={{ color: '#333333' }}>
                {FEATURES.map((f) => (
                  <li key={f.key} className="flex items-center gap-2">
                    <Check className="w-4 h-4" style={{ color: '#879CF7' }} strokeWidth={3} />
                    {f.label(r[f.key])}
                  </li>
                ))}
              </ul>
              <div
                className="mt-6 text-center py-2.5 rounded-lg text-sm"
                style={{
                  background: isSelected ? '#879CF7' : '#ECF0FF',
                  color: isSelected ? '#FFFFFF' : '#001364',
                  fontWeight: 600,
                }}
              >
                {isSelected ? 'Selected' : 'Choose plan'}
              </div>
            </button>
          );
        })}
      </div>

      <div className="text-center">
        <button
          onClick={onNext}
          disabled={!canNext || saving}
          className="mt-10 w-full max-w-md py-3.5 rounded-xl"
          style={{
            background: '#879CF7', color: '#FFFFFF', border: 'none',
            opacity: canNext && !saving ? 1 : 0.4,
            cursor: canNext && !saving ? 'pointer' : 'not-allowed',
            fontWeight: 600,
          }}
        >
          {saving ? 'Saving…' : 'Continue to checkout'}
        </button>
      </div>
    </div>
  );
}

function IntervalToggle({ value, onChange }) {
  const options = ['Monthly', 'Yearly'];
  return (
    <div className="inline-flex p-1 rounded-full" style={{ background: '#ECF0FF' }}>
      {options.map((o) => {
        const active = value === o;
        return (
          <button
            key={o}
            onClick={() => onChange(o)}
            className="px-5 py-1.5 rounded-full text-sm flex items-center gap-2"
            style={{
              background: active ? '#FFFFFF' : 'transparent',
              color: '#001364',
              border: 'none',
              fontWeight: active ? 700 : 500,
              cursor: 'pointer',
              boxShadow: active ? '0 1px 2px rgba(0,19,100,0.06)' : 'none',
            }}
          >
            {o}
            {o === 'Yearly' && (
              <span className="text-xs px-1.5 py-0.5 rounded" style={{ background: '#879CF7', color: '#FFFFFF', fontWeight: 700 }}>
                Save ~17%
              </span>
            )}
          </button>
        );
      })}
    </div>
  );
}

function CheckoutStep({ user, pricingRows, selectedPriceRowId }) {
  const selected = (pricingRows || []).find((r) => r.id === selectedPriceRowId);

  // TODO: Embedded Stripe Checkout. Needs a backend endpoint that creates a Checkout Session
  // with { mode: 'subscription', line_items: [{ price: <stripePriceId>, quantity: 1 }],
  //        subscription_data: { trial_period_days: 7 }, customer_email: <user.email>,
  //        ui_mode: 'embedded', return_url: '/setup' }
  // Then mount it via @stripe/stripe-js initEmbeddedCheckout({ clientSecret }).

  if (!selected) {
    return (
      <div className="text-center py-20">
        <p style={{ color: '#555555' }}>Pick a plan first.</p>
      </div>
    );
  }

  const tierLabel = selected.tier?.label || selected.tier;
  const intervalLabel = selected.interval?.label || selected.interval;

  return (
    <div className="grid md:grid-cols-2 gap-6">
      <div className="rounded-2xl p-6" style={{ background: '#FFFFFF', border: '1px solid #D6DEFC' }}>
        <div className="text-xs uppercase tracking-wide mb-1" style={{ color: '#879CF7', fontWeight: 700 }}>
          {tierLabel} · {intervalLabel}
        </div>
        <div className="text-2xl mb-4" style={{ color: '#001364', fontWeight: 800 }}>
          ${selected.price} {intervalLabel === 'Yearly' ? '/yr' : '/mo'}
        </div>

        <ul className="space-y-2 text-sm mb-6" style={{ color: '#333333' }}>
          {FEATURES.map((f) => (
            <li key={f.key} className="flex items-center gap-2">
              <Check className="w-4 h-4" style={{ color: '#879CF7' }} strokeWidth={3} />
              {f.label(selected[f.key])}
            </li>
          ))}
        </ul>

        <div className="text-xs space-y-2" style={{ color: '#555555' }}>
          <div>Pay $0 today — your 7-day trial starts now.</div>
          <div>Cancel anytime in settings, no questions asked.</div>
          <div>Powered by Stripe.</div>
        </div>
      </div>

      <div
        className="rounded-2xl p-6 flex items-center justify-center text-center"
        style={{ background: '#FFFFFF', border: '1px dashed #D6DEFC', minHeight: '320px' }}
        id="stripe-embedded-checkout"
      >
        <div>
          <div className="text-sm mb-2" style={{ color: '#001364', fontWeight: 700 }}>
            Stripe Embedded Checkout mounts here
          </div>
          <div className="text-xs leading-relaxed max-w-xs mx-auto" style={{ color: '#555555' }}>
            Wire a backend endpoint that creates a Checkout Session with
            <code style={{ background: '#ECF0FF', padding: '0 4px', margin: '0 2px', borderRadius: 4 }}>
              trial_period_days: 7
            </code>
            and price <code style={{ background: '#ECF0FF', padding: '0 4px', margin: '0 2px', borderRadius: 4 }}>
              {selected.stripePriceId}
            </code>, then mount via <code>initEmbeddedCheckout(clientSecret)</code>.
          </div>
        </div>
      </div>
    </div>
  );
}
