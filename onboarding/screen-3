import { useState, useEffect } from 'react';
import { Button } from '@/components/ui/button';
import { Textarea } from '@/components/ui/textarea';
import { useRecords, useRecordUpdate, q } from '@/lib/datasource';
import { toast } from 'sonner';
import { Edit2 } from 'lucide-react';

const select = q.select({
  name: 'aAKkT',
  blueprintStatus: 'fElW1',
  brandBio: 'iVPat',
  brandVoice: 'ybmp8',
  brandCta: 's9vzj',
  targetAudience: '6g1Vd',
  audiencePainPoints: 'B4zya',
  audienceObjectives: '5Wq2k',
  niche: 'vOp4b',
  productScreenTimeThreshold: 'AFgpo',
  textLegibilityThreshold: 'TNRuM',
  hookSpeedThreshold: 'wthaW',
  visualHookThreshold: 'Nq4ZX',
  ctaPlacementThreshold: 'FA452',
  engagementPacingThreshold: 'bR5PL',
  faceTimeThreshold: 'FH27O',
  brandMentionCountThreshold: 'HCvZw'
});

const updateFields = q.select({
  name: 'aAKkT',
  brandBio: 'iVPat',
  brandVoice: 'ybmp8',
  brandCta: 's9vzj',
  targetAudience: '6g1Vd',
  audiencePainPoints: 'B4zya',
  audienceObjectives: '5Wq2k',
  niche: 'vOp4b',
  productScreenTimeThreshold: 'AFgpo',
  textLegibilityThreshold: 'TNRuM',
  hookSpeedThreshold: 'wthaW',
  visualHookThreshold: 'Nq4ZX',
  ctaPlacementThreshold: 'FA452',
  engagementPacingThreshold: 'bR5PL',
  faceTimeThreshold: 'FH27O',
  brandMentionCountThreshold: 'HCvZw'
});

export default function Block() {
  const { data, status, refetch } = useRecords({
    select,
    count: 1
  });

  const [editingField, setEditingField] = useState(null);
  const [editedValues, setEditedValues] = useState({});
  const [blueprintSaved, setBlueprintSaved] = useState(false);
  const [thresholdsSaved, setThresholdsSaved] = useState(false);
  
  // Reveal states
  const [showTyping0, setShowTyping0] = useState(false);
  const [showMessage1, setShowMessage1] = useState(false);
  const [showTyping1, setShowTyping1] = useState(false);
  const [showBlueprintCard, setShowBlueprintCard] = useState(false);
  const [showTyping2, setShowTyping2] = useState(false);
  const [showMessage2, setShowMessage2] = useState(false);
  const [showBlueprintSave, setShowBlueprintSave] = useState(false);
  const [showTyping3, setShowTyping3] = useState(false);
  const [showMessage3, setShowMessage3] = useState(false);
  const [showTyping4, setShowTyping4] = useState(false);
  const [showThresholdCard, setShowThresholdCard] = useState(false);
  const [showTyping5, setShowTyping5] = useState(false);
  const [showMessage4, setShowMessage4] = useState(false);
  const [showThresholdSave, setShowThresholdSave] = useState(false);
  const [showContinue, setShowContinue] = useState(false);

  const updateRecord = useRecordUpdate({
    fields: updateFields,
    async onSuccess() {
      await refetch();
      toast.success('Blueprint updated!');
      setEditedValues({});
    },
    onError: (error) => {
      toast.error('Failed to update blueprint', {
        description: error.message,
      });
    }
  });

  const blueprintFieldsConfig = [
    { key: 'brandBio', label: 'Brand Bio', placeholder: 'Describe your brand...' },
    { key: 'brandVoice', label: 'Brand Voice', placeholder: 'Describe your brand voice...' },
    { key: 'brandCta', label: 'Brand CTA', placeholder: 'Your call to action...' },
    { key: 'targetAudience', label: 'Target Audience', placeholder: 'Who is your target audience...' },
    { key: 'audiencePainPoints', label: 'Audience Pain Points', placeholder: 'What problems do they face...' },
    { key: 'audienceObjectives', label: 'Audience Objectives', placeholder: 'What are their goals...' },
    { key: 'niche', label: 'Niche', placeholder: 'Your niche...' }
  ];

  const thresholdFields = [
    {
      key: 'productScreenTimeThreshold',
      label: 'Product Visibility',
      description: 'Minimum percentage of the video that must show the product clearly',
      options: ['40%', '50%', '60%', '70%', '80%', '90%', '100%', 'None']
    },
    {
      key: 'textLegibilityThreshold',
      label: 'Text Legibility',
      description: 'How readable must the text overlays be',
      options: ['70%', '80%', '90%', '100%', 'None']
    },
    {
      key: 'hookSpeedThreshold',
      label: 'Audio Hook Timing',
      description: 'How quickly must the video grab attention with spoken content',
      options: ['1 second', '2 seconds', '3 seconds', '5 seconds', 'None']
    },
    {
      key: 'visualHookThreshold',
      label: 'Visual Hook',
      description: 'Does the first frame or first moment have to grab your attention?',
      options: ['Required', 'Not required']
    },
    {
      key: 'ctaPlacementThreshold',
      label: 'Call to Action Timing',
      description: 'When should the call to action appear in the video?',
      options: ['Last 3 seconds', 'Last 5 seconds', 'Last 7 seconds', 'Last 10 seconds', 'None']
    },
    {
      key: 'engagementPacingThreshold',
      label: 'Engagement Pacing',
      description: 'How often should the video change scenes or angles?',
      options: ['Every 2 seconds', 'Every 3 seconds', 'Every 4 seconds', 'Every 5 seconds', 'None']
    },
    {
      key: 'faceTimeThreshold',
      label: 'Creator Visibility',
      description: "Minimum percentage of the video showing creator's face",
      options: ['20%', '30%', '40%', '50%', '60%', '70%', 'None']
    },
    {
      key: 'brandMentionCountThreshold',
      label: 'Brand Mentions',
      description: 'How many times must the brand name be mentioned?',
      options: ['0', '1', '2', '3', '4+']
    }
  ];

  const record = data?.pages[0]?.items[0];

  const getFieldValue = (key) => {
    if (editedValues[key] !== undefined) return editedValues[key];
    if (!record) return '';
    const value = record.fields[key];
    if (typeof value === 'object' && value?.label) return value.label;
    return value || '';
  };

  const formatTextWithBullets = (text) => {
    if (!text) return null;
    
    // First, convert HTML <br> tags to actual newlines
    let cleaned = text.replace(/<br\s*\/?>/gi, '\n');
    
    // Split into lines
    const lines = cleaned.split('\n').filter(line => line.trim());
    
    if (lines.length === 0) return null;
    
    const elements = [];
    let currentList = [];
    let listType = null;
    
    lines.forEach((line, idx) => {
      const trimmed = line.trim();
      const bulletMatch = trimmed.match(/^([•\-\*])\s+(.+)$/);
      
      if (bulletMatch) {
        // This is a bullet point
        currentList.push(bulletMatch[2]);
        if (!listType) listType = 'ul';
      } else {
        // Not a bullet - flush any pending list
        if (currentList.length > 0) {
          elements.push(
            <ul key={`list-${elements.length}`} className="list-disc list-inside space-y-1 my-2">
              {currentList.map((item, i) => (
                <li key={i}>{item}</li>
              ))}
            </ul>
          );
          currentList = [];
          listType = null;
        }
        // Add the non-bullet line
        elements.push(<div key={`text-${elements.length}`}>{trimmed}</div>);
      }
    });
    
    // Flush any remaining list
    if (currentList.length > 0) {
      elements.push(
        <ul key={`list-${elements.length}`} className="list-disc list-inside space-y-1 my-2">
          {currentList.map((item, i) => (
            <li key={i}>{item}</li>
          ))}
        </ul>
      );
    }
    
    return elements.length > 0 ? elements : trimmed;
  };

  const handleBlueprintSave = () => {
    if (!record) return;
    
    const blueprintKeys = ['name', ...blueprintFieldsConfig.map(f => f.key)];
    const updates = {};
    blueprintKeys.forEach(key => {
      if (editedValues[key] !== undefined) {
        updates[key] = editedValues[key];
      }
    });

    if (Object.keys(updates).length > 0) {
      updateRecord.mutate({
        recordId: record.id,
        fields: updates
      });
    }
    
    setBlueprintSaved(true);
  };

  const handleThresholdSave = () => {
    if (!record) return;
    
    const thresholdKeys = thresholdFields.map(f => f.key);
    const updates = {};
    thresholdKeys.forEach(key => {
      if (editedValues[key] !== undefined) {
        updates[key] = editedValues[key];
      }
    });

    if (Object.keys(updates).length > 0) {
      updateRecord.mutate({
        recordId: record.id,
        fields: updates
      });
    }
    
    setThresholdsSaved(true);
  };

  const handleContinue = () => {
    window.location.href = '/review-mode';
  };

  // Sequential reveal effect
  useEffect(() => {
    if (status !== 'success' || !record) return;

    const timers = [];
    
    // Initial blueprint section
    timers.push(setTimeout(() => setShowTyping0(true), 500));
    timers.push(setTimeout(() => {
      setShowTyping0(false);
      setShowMessage1(true);
    }, 3000));
    timers.push(setTimeout(() => setShowTyping1(true), 2500));
    timers.push(setTimeout(() => {
      setShowTyping1(false);
      setShowBlueprintCard(true);
    }, 4500));
    timers.push(setTimeout(() => setShowTyping2(true), 5000));
    timers.push(setTimeout(() => {
      setShowTyping2(false);
      setShowMessage2(true);
    }, 6500));
    timers.push(setTimeout(() => setShowBlueprintSave(true), 7000));

    return () => timers.forEach(t => clearTimeout(t));
  }, [status, record]);

  // After blueprint save
  useEffect(() => {
    if (!blueprintSaved) return;

    const timers = [];
    timers.push(setTimeout(() => setShowTyping3(true), 500));
    timers.push(setTimeout(() => {
      setShowTyping3(false);
      setShowMessage3(true);
    }, 2000));
    timers.push(setTimeout(() => setShowTyping4(true), 2500));
    timers.push(setTimeout(() => {
      setShowTyping4(false);
      setShowThresholdCard(true);
    }, 4500));
    timers.push(setTimeout(() => setShowTyping5(true), 5000));
    timers.push(setTimeout(() => {
      setShowTyping5(false);
      setShowMessage4(true);
    }, 6500));
    timers.push(setTimeout(() => setShowThresholdSave(true), 7000));

    return () => timers.forEach(t => clearTimeout(t));
  }, [blueprintSaved]);

  // After threshold save
  useEffect(() => {
    if (!thresholdsSaved) return;
    const timer = setTimeout(() => setShowContinue(true), 500);
    return () => clearTimeout(timer);
  }, [thresholdsSaved]);

  if (status === 'pending') {
    return (
      <div className="min-h-screen flex items-center justify-center" style={{ background: 'linear-gradient(to bottom, rgba(217, 224, 255, 0.15), rgba(255, 255, 255, 1))' }}>
        <div className="text-center">
          <div className="text-lg font-medium" style={{ color: '#001364' }}>Loading...</div>
        </div>
      </div>
    );
  }

  if (status === 'error') {
    return (
      <div className="min-h-screen flex items-center justify-center" style={{ background: 'linear-gradient(to bottom, rgba(217, 224, 255, 0.15), rgba(255, 255, 255, 1))' }}>
        <div className="text-center">
          <div className="text-lg font-medium" style={{ color: '#d92626' }}>Error loading data</div>
          <div className="text-sm mt-2" style={{ color: '#001364' }}>Please try refreshing the page</div>
        </div>
      </div>
    );
  }

  if (!record) {
    return (
      <div className="min-h-screen flex items-center justify-center" style={{ background: 'linear-gradient(to bottom, rgba(217, 224, 255, 0.15), rgba(255, 255, 255, 1))' }}>
        <div className="text-center">
          <div className="text-lg font-medium" style={{ color: '#001364' }}>No workspace found</div>
          <div className="text-sm mt-2" style={{ color: '#001364' }}>Please create a workspace first</div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen flex flex-col" style={{ background: 'linear-gradient(to bottom, rgba(217, 224, 255, 0.15), rgba(255, 255, 255, 1))' }}>
      <style>
        {`
          @import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;500;800&display=swap');
          * {
            font-family: 'League Spartan', sans-serif;
          }
          @keyframes bounce {
            0%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-8px); }
          }
          .typing-dot { animation: bounce 1.4s infinite; }
          .typing-dot:nth-child(2) { animation-delay: 0.2s; }
          .typing-dot:nth-child(3) { animation-delay: 0.4s; }
        `}
      </style>

      {/* Progress dots */}
      <div className="flex justify-center gap-2 py-6">
        {[0, 1, 2, 3, 4, 5, 6].map((i) => (
          <div
            key={i}
            className="w-1.5 h-1.5 rounded-full"
            style={{
              backgroundColor: i <= 2 ? '#7A93FF' : i <= 4 ? '#D9E0FF' : '#e5e7eb'
            }}
          />
        ))}
      </div>

      <div className="flex-1 overflow-y-auto pb-48">
        <div className="container mx-auto px-4 py-8 max-w-2xl">
          {/* Typing 0 */}
          {showTyping0 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 1 */}
          {showMessage1 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Great! I've analyzed your brand and created a content blueprint. Please review the fields below and edit anything that needs adjustment.
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Typing 1 */}
          {showTyping1 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Blueprint card */}
          {showBlueprintCard && (
            <div className="mb-4 ml-10">
              <div className="bg-white rounded-xl p-4 shadow-sm space-y-4" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                {/* Workspace Name Heading */}
                <div className="space-y-2 pb-3 border-b" style={{ borderColor: 'rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex items-center justify-between">
                    <label className="text-xs font-medium" style={{ color: '#001364' }}>
                      Brand Name
                    </label>
                    {editingField !== 'name' && (
                      <button
                        onClick={() => setEditingField('name')}
                        className="p-1 hover:bg-gray-100 rounded transition-colors"
                      >
                        <Edit2 className="w-3.5 h-3.5" style={{ color: '#7A93FF' }} />
                      </button>
                    )}
                  </div>
                  {editingField === 'name' ? (
                    <input
                      type="text"
                      value={getFieldValue('name')}
                      onChange={(e) => setEditedValues({ ...editedValues, name: e.target.value })}
                      onBlur={() => setEditingField(null)}
                      placeholder="Enter brand name..."
                      className="w-full text-2xl font-medium border rounded-lg px-3 py-2"
                      style={{ borderColor: '#7A93FF', color: '#001364' }}
                      autoFocus
                    />
                  ) : (
                    <h2 className="text-2xl font-medium" style={{ color: '#001364' }}>
                      {getFieldValue('name') || 'Enter brand name...'}
                    </h2>
                  )}
                </div>

                {blueprintFieldsConfig.map(({ key, label, placeholder }) => (
                  <div key={key} className="space-y-2">
                    <div className="flex items-center justify-between">
                      <label className="text-xs font-medium" style={{ color: '#001364' }}>
                        {label}
                      </label>
                      {editingField !== key && (
                        <button
                          onClick={() => setEditingField(key)}
                          className="p-1 hover:bg-gray-100 rounded transition-colors"
                        >
                          <Edit2 className="w-3.5 h-3.5" style={{ color: '#7A93FF' }} />
                        </button>
                      )}
                    </div>
                    {editingField === key ? (
                      <Textarea
                        value={getFieldValue(key)}
                        onChange={(e) => setEditedValues({ ...editedValues, [key]: e.target.value })}
                        onBlur={() => setEditingField(null)}
                        placeholder={placeholder}
                        className="text-sm min-h-[80px]"
                        style={{ borderColor: '#7A93FF' }}
                        autoFocus
                      />
                    ) : (
                      <div 
                        className="text-sm leading-relaxed" 
                        style={{ color: '#000F4D', fontWeight: 300 }}
                      >
                        {formatTextWithBullets(getFieldValue(key)) || placeholder}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Typing 2 */}
          {showTyping2 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 2 */}
          {showMessage2 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Anything look off? Edit whatever you need — I'll use this to review every video that comes through.
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Blueprint Save button */}
          {showBlueprintSave && !blueprintSaved && (
            <div className="mb-4 ml-10">
              <Button 
                onClick={handleBlueprintSave}
                disabled={updateRecord.status === 'pending'}
                className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300" 
                style={{ 
                  backgroundColor: '#7A93FF', 
                  color: '#FFFFFF',
                  borderRadius: '8px',
                  fontWeight: 500
                }}
              >
                {updateRecord.status === 'pending' ? 'Saving...' : 'Save'}
              </Button>
            </div>
          )}

          {/* Typing 3 */}
          {showTyping3 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 3 */}
          {showMessage3 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Now let's set your quality standards — these are the thresholds I'll use when scoring content. Adjust anything that matters to your brand.
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Typing 4 */}
          {showTyping4 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Threshold Settings card */}
          {showThresholdCard && (
            <div className="mb-4 ml-10">
              <div className="bg-white rounded-xl p-4 shadow-sm space-y-4" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                <div>
                  <h3 className="text-base font-medium mb-1" style={{ color: '#001364' }}>Threshold Settings</h3>
                  <p className="text-xs" style={{ color: '#7A93FF', fontWeight: 300 }}>Configure quality standards for video submissions</p>
                </div>

                <div className="space-y-3">
                  {thresholdFields.map(({ key, label, description, options }) => (
                    <div key={key} className="space-y-1.5">
                      <label className="text-xs font-medium" style={{ color: '#001364' }}>{label}</label>
                      <p className="text-xs" style={{ color: '#000F4D', fontWeight: 300 }}>{description}</p>
                      <select 
                        className="w-full text-sm border rounded-lg px-3 py-2" 
                        style={{ borderColor: 'rgba(217, 224, 255, 0.4)' }}
                        value={getFieldValue(key)}
                        onChange={(e) => setEditedValues({ ...editedValues, [key]: e.target.value })}
                      >
                        {options.map(opt => (
                          <option key={opt} value={opt}>{opt}</option>
                        ))}
                      </select>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {/* Typing 5 */}
          {showTyping5 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <div className="flex gap-1.5">
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                    <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Message 4 */}
          {showMessage4 && (
            <div className="mb-4">
              <div className="flex gap-2.5 items-start">
                <img 
                  src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png" 
                  alt="Lee" 
                  className="w-8 h-8 rounded-full flex-shrink-0"
                />
                <div className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg" style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}>
                  <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
                    Don't overthink it — these are starting points. You can fine-tune as you see real reviews come in.
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Threshold Save button */}
          {showThresholdSave && !thresholdsSaved && (
            <div className="mb-4 ml-10">
              <Button 
                onClick={handleThresholdSave}
                disabled={updateRecord.status === 'pending'}
                className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300" 
                style={{ 
                  backgroundColor: '#7A93FF', 
                  color: '#FFFFFF',
                  borderRadius: '8px',
                  fontWeight: 500
                }}
              >
                {updateRecord.status === 'pending' ? 'Saving...' : 'Save'}
              </Button>
            </div>
          )}

          {/* Continue button */}
          {showContinue && (
            <div className="mb-4 ml-10">
              <Button 
                onClick={handleContinue}
                className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300" 
                style={{ 
                  backgroundColor: '#7A93FF', 
                  color: '#FFFFFF',
                  borderRadius: '8px',
                  fontWeight: 500
                }}
              >
                Continue →
              </Button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
