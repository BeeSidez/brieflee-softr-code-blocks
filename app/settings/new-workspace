// /settings · "+ New workspace" button (separate Vibe Code block).
//
// Shows a single button. Click → in-block form expands. Submit →
// creates a new ACCOUNTS record. The Softr workflow watching the
// accounts table picks it up and triggers the AI content-blueprint
// build automatically; this block doesn't need to know about that.
//
// Place this block above (or beside) the workspace switcher. Set
// VISIBILITY in Softr to user groups whose plan allows multiple
// workspaces — single-workspace plans never see the button.
//
// SOFTR CONFIG REQUIRED:
//   Source tab: bind to ACCOUNTS table. The Source filter doesn't
//   matter for the create — what matters is that the Actions tab
//   below picks up the q.select() aliases.
//
//   Actions tab: should auto-populate from createFields. If Softr
//   doesn't auto-link the new account to the logged-in user, you'll
//   need to add the `users` field ID below (uncomment the line in
//   createFields and set the real field ID).

import { useState } from "react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { Plus } from "lucide-react";
import { useRecordCreate, q } from "@/lib/datasource";
import { useCurrentUser } from "@/lib/user";
import { toast } from "sonner";

const createFields = q.select({
  name:        "aAKkT",
  website:     "RaK4B",
  description: "RQcNB",
  // users:    "REPLACE_WITH_FIELD_ID",  // uncomment if Softr doesn't auto-link
});

export default function Block() {
  const [open, setOpen] = useState(false);
  const [name, setName] = useState("");
  const [hasWebsite, setHasWebsite] = useState(true);
  const [website, setWebsite] = useState("");
  const [description, setDescription] = useState("");
  const [submitting, setSubmitting] = useState(false);

  const user = useCurrentUser();
  const createRecord = useRecordCreate({ fields: createFields });

  const reset = () => {
    setName("");
    setWebsite("");
    setDescription("");
    setHasWebsite(true);
  };

  const handleClose = () => {
    reset();
    setOpen(false);
  };

  const handleSubmit = async () => {
    if (!name.trim()) {
      toast.error("Workspace name is required");
      return;
    }
    if (hasWebsite && !website.trim()) {
      toast.error("Website is required (or switch to description)");
      return;
    }
    if (!hasWebsite && !description.trim()) {
      toast.error("Description is required (or switch to website)");
      return;
    }
    if (!user?.id) {
      toast.error("Please log in to create a workspace");
      return;
    }
    if (!createRecord.enabled) {
      toast.error("Cannot create records right now");
      return;
    }

    setSubmitting(true);
    try {
      const fields = { name: name.trim() };
      if (hasWebsite) {
        fields.website = website.trim();
      } else {
        fields.description = description.trim();
      }
      // If Softr doesn't auto-link, uncomment:
      // fields.users = [{ id: user.id }];

      await createRecord.mutateAsync(fields);
      toast.success("Workspace created — Brieflee is building your content blueprint.");
      reset();
      setOpen(false);
    } catch (e) {
      toast.error("Couldn't create workspace", {
        description: e?.message || "Try again.",
      });
    } finally {
      setSubmitting(false);
    }
  };

  return (
    <div
      style={{
        display: "flex",
        justifyContent: "flex-end",
        padding: "16px 24px 0",
        width: "100%",
      }}
    >
      <Style />

      <button
        type="button"
        onClick={() => setOpen(true)}
        className="newws-trigger"
      >
        <Plus className="h-4 w-4" strokeWidth={2.5} />
        New workspace
      </button>

      {open && (
        <div
          className="newws-backdrop"
          onClick={handleClose}
          role="presentation"
        >
          <div
            className="newws-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="newws-title"
            onClick={(e) => e.stopPropagation()}
          >
            <header className="newws-form-header">
              <div>
                <h3 id="newws-title" className="newws-form-title">
                  New workspace
                </h3>
                <p className="newws-form-sub">
                  Brieflee will build a fresh content blueprint for it.
                </p>
              </div>
              <button
                type="button"
                onClick={handleClose}
                className="newws-close"
                aria-label="Close"
              >
                ×
              </button>
            </header>

            <div className="newws-fields">
              <div>
                <label className="newws-label">Workspace name</label>
                <Input
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  placeholder="e.g. My Brand"
                  disabled={submitting}
                  autoFocus
                />
              </div>

              <div>
                <label className="newws-label">How should we set this up?</label>
                <div className="newws-toggle-row">
                  <button
                    type="button"
                    onClick={() => setHasWebsite(true)}
                    className={"newws-toggle " + (hasWebsite ? "active" : "")}
                    disabled={submitting}
                  >
                    From a website
                  </button>
                  <button
                    type="button"
                    onClick={() => setHasWebsite(false)}
                    className={"newws-toggle " + (!hasWebsite ? "active" : "")}
                    disabled={submitting}
                  >
                    From a description
                  </button>
                </div>
              </div>

              {hasWebsite ? (
                <div>
                  <label className="newws-label">Website URL</label>
                  <Input
                    type="url"
                    value={website}
                    onChange={(e) => setWebsite(e.target.value)}
                    placeholder="https://example.com"
                    disabled={submitting}
                  />
                </div>
              ) : (
                <div>
                  <label className="newws-label">Brand description</label>
                  <Textarea
                    value={description}
                    onChange={(e) => setDescription(e.target.value)}
                    placeholder="A few sentences on what this brand is and who it's for."
                    rows={3}
                    disabled={submitting}
                  />
                </div>
              )}
            </div>

            <footer className="newws-form-footer">
              <button
                type="button"
                onClick={handleClose}
                disabled={submitting}
                className="newws-cancel"
              >
                Cancel
              </button>
              <Button
                onClick={handleSubmit}
                disabled={submitting || !name.trim() || !createRecord.enabled}
              >
                {submitting ? "Creating…" : "Create workspace"}
              </Button>
            </footer>
          </div>
        </div>
      )}
    </div>
  );
}

