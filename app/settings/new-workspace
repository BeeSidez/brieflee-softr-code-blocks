          color: #001364;
          margin-bottom: 6px;
        }

        .newws-toggle-row {
          display: flex;
          gap: 6px;
        }
        .newws-toggle {
          flex: 1;
          padding: 9px 12px;
          background: #FFFFFF;
          color: #6b7a99;
          border: 1px solid rgba(217, 224, 255, 0.7);
          border-radius: 8px;
          font-size: 12px;
          font-weight: 500;
          cursor: pointer;
          transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
        }
        .newws-toggle.active {
          background: rgba(135, 156, 247, 0.10);
          color: #001364;
          border-color: #879CF7;
          font-weight: 600;
        }
        .newws-toggle:disabled { opacity: 0.6; cursor: not-allowed; }

        .newws-form-footer {
          display: flex;
          justify-content: flex-end;
          align-items: center;
          gap: 8px;
          margin-top: 20px;
          padding-top: 16px;
          border-top: 1px solid rgba(217, 224, 255, 0.55);
        }
        .newws-cancel {
          background: transparent;
          color: #6b7a99;
          border: none;
          font-size: 14px;
          font-weight: 500;
          padding: 8px 14px;
          border-radius: 8px;
          cursor: pointer;
          transition: color 0.2s ease;
        }
        .newws-cancel:hover:not(:disabled) { color: #001364; }
