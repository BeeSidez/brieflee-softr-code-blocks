          top: 0; left: 0; right: 0; bottom: 0;
          background: rgba(0, 15, 77, 0.40);
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 9999;
          padding: 20px;
          animation: newwsBackdropFade 0.16s ease-out;
        }
        .newws-modal {
