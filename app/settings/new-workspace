          max-width: 460px;
          background: #FFFFFF;
          border: 1px solid rgba(217, 224, 255, 0.6);
          border-radius: 14px;
          padding: 22px 24px 18px;
          box-shadow: 0 12px 36px rgba(0, 15, 77, 0.18);
          animation: newwsModalRise 0.18s ease-out;
          max-height: calc(100vh - 40px);
          overflow-y: auto;
        }
        .newws-form-header {
          display: flex;
          align-items: flex-start;
          justify-content: space-between;
          gap: 12px;
          margin-bottom: 18px;
        }
        .newws-form-title {
          font-size: 16px;
          font-weight: 600;
