    window.open(AFFILIATE_LOGIN_URL, "_blank", "noopener,noreferrer");
  };

  return (
    <div
      className="flex flex-col"
      style={{
        background: "#FAFBFF",
        borderRadius: "16px",
        padding: "12px 0 48px",
