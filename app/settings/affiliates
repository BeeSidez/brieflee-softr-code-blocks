            Earn{" "}
            <span className="aff-percent">{COMMISSION_PERCENT}%</span>{" "}
            on every customer you refer
          </h2>
          <p className="aff-body">
            Share Brieflee with creators, agencies, and brand teams. When they
            sign up through your link, we pay you {COMMISSION_PERCENT}%
            commission on their subscription — for as long as they stay
            subscribed.
          </p>

          <div className="aff-perks">
            <Perk title="Recurring payouts">
              You earn on every billing cycle, not just the first.
            </Perk>
            <Perk title="Real-time tracking">
              See clicks, sign-ups and earnings live in your affiliate
              dashboard.
            </Perk>
            <Perk title="Monthly payments">
              Cashed out automatically — no minimum threshold.
            </Perk>
          </div>

          <button type="button" onClick={handleOpen} className="aff-cta">
            Open affiliate dashboard
            <span className="aff-cta-arrow" aria-hidden="true">↗</span>
          </button>

          <p className="aff-note">
            New affiliate? Sign up on the dashboard with the email you use for
            Brieflee.
          </p>
        </section>
      </div>
    </div>
  );
}

