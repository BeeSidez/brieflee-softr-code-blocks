// /settings · Workspace tab — single Vibe Code block.
// Three sub-sections: Identity → Brand → Audience.
// Each section has its own Save / Discard buttons; nothing persists
// until the user explicitly hits Save.
//
// SOFTR CONFIG REQUIRED:
//   Source tab: bind to ACCOUNTS in "brieflee beta", filter to logged-in
//   user (or to the workspace from the URL param `workspace` if you've
//   wired up the multi-workspace switcher block).
//   Actions tab: auto-populated from updateFields aliases below.
//
import { useState, useEffect, useRef } from "react";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import {
  useRecord,
  useCurrentRecordId,
  useRecordUpdate,
  useUpload,
  q,
} from "@/lib/datasource";
import { toast } from "sonner";

// ---- Field map (ACCOUNTS) -----------------------------------------
const select = q.select({
  name:               "aAKkT",
  logo:               "q1B5K",
  niche:              "vOp4b",
  brandBio:           "iVPat",
  brandVoice:         "ybmp8",
  brandCta:           "s9vzj",
  targetAudience:     "6g1Vd",
  audiencePainPoints: "B4zya",
  audienceObjectives: "5Wq2k",
});

const updateFields = q.select({
  name:               "aAKkT",
  logo:               "q1B5K",
  niche:              "vOp4b",
  brandBio:           "iVPat",
  brandVoice:         "ybmp8",
  brandCta:           "s9vzj",
  targetAudience:     "6g1Vd",
  audiencePainPoints: "B4zya",
  audienceObjectives: "5Wq2k",
});

const EMPTY_DRAFT = {
  name: "",
  niche: "",
  brandBio: "",
  brandVoice: "",
  brandCta: "",
  targetAudience: "",
  audiencePainPoints: "",
  audienceObjectives: "",
};

// =====================================================================
// Block
// =====================================================================
export default function Block() {
  const recordId = useCurrentRecordId();
  const { data: record, status, refetch } = useRecord({ recordId, select });

  // Saved state — mirrors the record after each successful save
  const [saved, setSaved] = useState(EMPTY_DRAFT);
  // Draft state — what the user is editing right now
  const [draft, setDraft] = useState(EMPTY_DRAFT);

  // Logo state (handled separately — not a plain string)
  const [logoSaved, setLogoSaved] = useState(null); // attachment array or null
  const [logoPending, setLogoPending] = useState(null); // File object pending save
  const [logoCleared, setLogoCleared] = useState(false); // user removed it

  // Save lifecycle
  const [savingSection, setSavingSection] = useState(null);
  const [recentlySavedSection, setRecentlySavedSection] = useState(null);

  // Hydration is keyed by record.id so workspace switches re-hydrate
  const hydratedForRecordIdRef = useRef(null);
  const pendingSaveContextRef = useRef(null);
  const savedFlashTimerRef = useRef(null);
  const logoInputRef = useRef(null);

  // ---- File upload hook --------------------------------------------
  const upload = useUpload();

  // ---- Hydrate from record (re-runs when record.id changes) -------
  // useRecord returns data with fields nested under data.fields.<alias>.
  // (Confirmed against Bev's working Softr-generated reference block.)
  useEffect(() => {
    if (!record || !record.fields) return;
    if (hydratedForRecordIdRef.current === record.id) return;
    hydratedForRecordIdRef.current = record.id;

    const f = record.fields;
    const next = {
      name:               extractText(f.name),
      niche:              extractText(f.niche),
      brandBio:           extractText(f.brandBio),
      brandVoice:         extractText(f.brandVoice),
      brandCta:           extractText(f.brandCta),
      targetAudience:     extractText(f.targetAudience),
      audiencePainPoints: extractText(f.audiencePainPoints),
      audienceObjectives: extractText(f.audienceObjectives),
    };
    setSaved(next);
    setDraft(next);
    setLogoSaved(f.logo ?? null);
  }, [record]);

  // ---- Update hook -------------------------------------------------
  const updateRecord = useRecordUpdate({
    fields: updateFields,
    onSuccess: () => {
      const ctx = pendingSaveContextRef.current;
      pendingSaveContextRef.current = null;
      setSavingSection(null);
      if (!ctx) { refetch(); return; }
      ctx.onComplete?.();
      setRecentlySavedSection(ctx.section);
      if (savedFlashTimerRef.current) clearTimeout(savedFlashTimerRef.current);
      savedFlashTimerRef.current = setTimeout(() => {
        setRecentlySavedSection((cur) => (cur === ctx.section ? null : cur));
      }, 1800);
      refetch();
    },
    onError: (err) => {
      pendingSaveContextRef.current = null;
      setSavingSection(null);
      toast.error("Couldn't save", { description: err?.message || "Try again." });
    },
  });

  const performSave = (section, fields, onComplete) => {
    if (!recordId) {
      toast.error("Couldn't find your account record.");
      return;
    }
    pendingSaveContextRef.current = { section, onComplete };
    setSavingSection(section);
    updateRecord.mutate({ recordId, fields });
  };

  // ---- Cleanup -----------------------------------------------------
  useEffect(() => () => {
    if (savedFlashTimerRef.current) clearTimeout(savedFlashTimerRef.current);
  }, []);

  // ---- Per-section dirty checks ------------------------------------
  const isLogoDirty = logoPending !== null || logoCleared;
  const isIdentityDirty =
    draft.name !== saved.name || isLogoDirty;
  const isBrandDirty =
    draft.brandBio !== saved.brandBio ||
    draft.brandVoice !== saved.brandVoice ||
    draft.brandCta !== saved.brandCta ||
    draft.niche !== saved.niche;
  const isAudienceDirty =
    draft.targetAudience !== saved.targetAudience ||
    draft.audiencePainPoints !== saved.audiencePainPoints ||
    draft.audienceObjectives !== saved.audienceObjectives;
  const anyDirty = isIdentityDirty || isBrandDirty || isAudienceDirty;

  // ---- beforeunload guard -----------------------------------------
  useEffect(() => {
    if (!anyDirty) return;
    const handler = (e) => { e.preventDefault(); e.returnValue = ""; };
    window.addEventListener("beforeunload", handler);
    return () => window.removeEventListener("beforeunload", handler);
  }, [anyDirty]);

  // ---- Save / discard handlers ------------------------------------
  const setField = (key, value) =>
    setDraft((cur) => ({ ...cur, [key]: value }));

  const saveIdentity = async () => {
    if (!recordId) {
      toast.error("Couldn't find your account record.");
      return;
    }

    let logoForWrite = undefined; // undefined = don't touch the field
    try {
      if (logoPending) {
        setSavingSection("identity");
        const uploaded = await upload.mutateAsync(logoPending);
        logoForWrite = Array.isArray(uploaded) ? uploaded : [uploaded];
      } else if (logoCleared) {
        logoForWrite = null;
      }
    } catch (err) {
      setSavingSection(null);
      toast.error("Couldn't upload logo", {
        description: err?.message || "Try again.",
      });
      return;
    }

    const fields = { name: draft.name.trim() };
    if (logoForWrite !== undefined) fields.logo = logoForWrite;

    performSave(
      "identity",
      fields,
      () => {
        setSaved((cur) => ({ ...cur, name: draft.name }));
        if (logoForWrite !== undefined) {
          setLogoSaved(logoForWrite);
        }
        setLogoPending(null);
        setLogoCleared(false);
        if (logoInputRef.current) logoInputRef.current.value = "";
      },
    );
  };
  const discardIdentity = () => {
    setDraft((cur) => ({ ...cur, name: saved.name }));
    setLogoPending(null);
    setLogoCleared(false);
    if (logoInputRef.current) logoInputRef.current.value = "";
  };

  // ---- Logo handlers ----------------------------------------------
  const handleLogoFileChange = (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    setLogoPending(file);
    setLogoCleared(false);
  };

  const handleLogoRemove = () => {
    setLogoPending(null);
    setLogoCleared(true);
    if (logoInputRef.current) logoInputRef.current.value = "";
  };

  const currentLogoUrl = (() => {
    if (logoCleared) return null;
    if (logoPending) {
      return URL.createObjectURL(logoPending);
    }
    return extractAttachmentUrl(logoSaved);
  })();

  const saveBrand = () => {
    performSave(
      "brand",
      {
        brandBio: draft.brandBio.trim(),
        brandVoice: draft.brandVoice.trim(),
        brandCta: draft.brandCta.trim(),
        niche: draft.niche.trim(),
      },
      () => setSaved((cur) => ({
        ...cur,
        brandBio: draft.brandBio,
        brandVoice: draft.brandVoice,
        brandCta: draft.brandCta,
        niche: draft.niche,
      })),
    );
  };
  const discardBrand = () =>
    setDraft((cur) => ({
      ...cur,
      brandBio: saved.brandBio,
      brandVoice: saved.brandVoice,
      brandCta: saved.brandCta,
      niche: saved.niche,
    }));

  const saveAudience = () => {
    performSave(
      "audience",
      {
        targetAudience: draft.targetAudience.trim(),
        audiencePainPoints: draft.audiencePainPoints.trim(),
        audienceObjectives: draft.audienceObjectives.trim(),
      },
      () => setSaved((cur) => ({
        ...cur,
        targetAudience: draft.targetAudience,
        audiencePainPoints: draft.audiencePainPoints,
        audienceObjectives: draft.audienceObjectives,
      })),
    );
  };
  const discardAudience = () =>
    setDraft((cur) => ({
      ...cur,
      targetAudience: saved.targetAudience,
      audiencePainPoints: saved.audiencePainPoints,
      audienceObjectives: saved.audienceObjectives,
    }));

  // ---- Render guards -----------------------------------------------
  if (status === "pending") return <BlockShell><Loading /></BlockShell>;
  if (status === "error") return <BlockShell><Loading error /></BlockShell>;
  if (!record) {
    return (
      <BlockShell>
        <Loading message="No account record found. Check the block's Source tab is bound to accounts with a filter to the logged-in user." />
      </BlockShell>
    );
  }

  return (
    <BlockShell>
      {/* ── Section 1 · Identity ────────────────────────────────────── */}
      <SectionCard
        title="Workspace identity"
        subtitle="The name and logo that anchor this workspace."
        dirty={isIdentityDirty}
        saving={savingSection === "identity"}
        justSaved={recentlySavedSection === "identity"}
        onSave={saveIdentity}
        onDiscard={discardIdentity}
      >
        <FieldRow label="Workspace name">
          <Input
            value={draft.name}
            onChange={(e) => setField("name", e.target.value)}
          />
        </FieldRow>

        <FieldRow label="Logo">
          <div className="workspace-logo-row">
            <div className="workspace-logo-preview">
              {currentLogoUrl ? (
                <img src={currentLogoUrl} alt="Workspace logo" />
              ) : (
                <span className="workspace-logo-placeholder">No logo yet</span>
              )}
            </div>
            <div className="workspace-logo-actions">
              <input
                ref={logoInputRef}
                type="file"
                accept="image/*"
                onChange={handleLogoFileChange}
                style={{ display: "none" }}
              />
              <button
                type="button"
                onClick={() => logoInputRef.current?.click()}
                className="workspace-logo-btn"
              >
                {currentLogoUrl ? "Change logo" : "Upload logo"}
              </button>
              {currentLogoUrl && (
                <button
                  type="button"
                  onClick={handleLogoRemove}
                  className="workspace-logo-btn workspace-logo-btn-ghost"
                >
                  Remove
                </button>
              )}
            </div>
          </div>
          <p
            className="text-xs"
            style={{ color: "#7A93FF", fontWeight: 400, marginTop: 6 }}
          >
            Square image works best. Click Save changes to upload.
          </p>
        </FieldRow>
      </SectionCard>

      {/* ── Section 2 · Brand ───────────────────────────────────────── */}
      <SectionCard
        title="Brand"
        subtitle="How Brieflee should think about your brand when reviewing content."
        dirty={isBrandDirty}
        saving={savingSection === "brand"}
        justSaved={recentlySavedSection === "brand"}
        onSave={saveBrand}
        onDiscard={discardBrand}
      >
        <FieldRow label="Brand bio">
          <Textarea
            value={draft.brandBio}
            onChange={(e) => setField("brandBio", e.target.value)}
            rows={3}
          />
        </FieldRow>

        <FieldRow label="Brand voice">
          <Textarea
            value={draft.brandVoice}
            onChange={(e) => setField("brandVoice", e.target.value)}
            rows={3}
          />
        </FieldRow>

        <FieldRow label="Brand CTA">
          <Textarea
            value={draft.brandCta}
            onChange={(e) => setField("brandCta", e.target.value)}
            rows={2}
          />
        </FieldRow>

        <FieldRow label="Niche">
          <Textarea
            value={draft.niche}
            onChange={(e) => setField("niche", e.target.value)}
            rows={2}
          />
        </FieldRow>
      </SectionCard>

      {/* ── Section 3 · Audience ───────────────────────────────────── */}
      <SectionCard
        title="Audience"
        subtitle="Who you're talking to and what they care about."
        dirty={isAudienceDirty}
        saving={savingSection === "audience"}
        justSaved={recentlySavedSection === "audience"}
        onSave={saveAudience}
        onDiscard={discardAudience}
      >
        <FieldRow label="Target audience">
          <Textarea
            value={draft.targetAudience}
            onChange={(e) => setField("targetAudience", e.target.value)}
            rows={3}
          />
        </FieldRow>

        <FieldRow label="Audience pain points">
          <Textarea
            value={draft.audiencePainPoints}
            onChange={(e) => setField("audiencePainPoints", e.target.value)}
            rows={3}
          />
        </FieldRow>

        <FieldRow label="Audience objectives">
          <Textarea
            value={draft.audienceObjectives}
            onChange={(e) => setField("audienceObjectives", e.target.value)}
            rows={3}
          />
        </FieldRow>
      </SectionCard>
    </BlockShell>
  );
}

// =====================================================================
// Sub-components
// =====================================================================

function BlockShell({ children }) {
  return (
    <div
      className="flex flex-col"
      style={{
        background: "#FAFBFF",
        borderRadius: "16px",
        padding: "12px 0 48px",
      }}
    >
      <Style />
      <div className="settings-workspace container mx-auto px-4 max-w-4xl w-full">
        <div className="space-y-4">{children}</div>
      </div>
    </div>
  );
}

function SectionCard({
  title, subtitle, dirty, saving, justSaved, onSave, onDiscard, children,
}) {
  let pill = null;
  if (saving) pill = <StatusPill tone="loading" label="Saving…" />;
  else if (justSaved) pill = <StatusPill tone="success" label="Saved" />;
  else if (dirty) pill = <StatusPill tone="warning" label="Unsaved" />;

  return (
    <section
      style={{
        background: "#FFFFFF",
        border: "1px solid rgba(217, 224, 255, 0.55)",
        borderRadius: "18px",
        padding: "22px 24px",
        boxShadow: "0 1px 3px rgba(0, 15, 77, 0.04)",
      }}
    >
      <header className="mb-4 flex items-start justify-between gap-3">
        <div className="min-w-0">
          <h3
            className="text-base"
            style={{ color: "#000F4D", fontWeight: 600, letterSpacing: "-0.005em" }}
          >
            {title}
          </h3>
          {subtitle && (
            <p
              className="text-xs mt-0.5"
              style={{ color: "#7A93FF", fontWeight: 400, lineHeight: 1.5 }}
            >
              {subtitle}
            </p>
          )}
        </div>
        {pill && <div style={{ flexShrink: 0 }}>{pill}</div>}
      </header>

      <div className="space-y-4">{children}</div>

      <footer
        className="mt-5 pt-4 flex items-center justify-end gap-2"
        style={{ borderTop: "1px solid rgba(217, 224, 255, 0.5)" }}
      >
        <button
          type="button"
          onClick={onDiscard}
          disabled={!dirty || saving}
          className="workspace-discard-btn"
        >
          Discard
        </button>
        <button
          type="button"
          onClick={onSave}
          disabled={!dirty || saving}
          className="workspace-save-btn"
        >
          {saving ? "Saving…" : "Save changes"}
        </button>
      </footer>
    </section>
  );
}

function FieldRow({ label, children }) {
  return (
    <div className="space-y-1.5">
      <label
        className="text-xs font-medium block"
        style={{ color: "#001364", fontWeight: 600 }}
      >
        {label}
      </label>
      {children}
    </div>
  );
}

function StatusPill({ tone, label }) {
  const palette =
    tone === "success"
      ? { fg: "#22A06B", dot: "#22A06B", border: "rgba(34, 160, 107, 0.30)" }
      : tone === "warning"
      ? { fg: "#C97D3F", dot: "#E89B5C", border: "rgba(232, 155, 92, 0.45)" }
      : { fg: "#7A93FF", dot: "#7A93FF", border: "rgba(122, 147, 255, 0.45)" };

  return (
    <span
      style={{
        display: "inline-flex",
        alignItems: "center",
        gap: 6,
        fontSize: 11,
        fontWeight: 600,
        color: palette.fg,
        padding: "4px 10px",
        background: "#FFFFFF",
        border: `1px solid ${palette.border}`,
        borderRadius: 999,
        whiteSpace: "nowrap",
      }}
    >
      <span
        style={{
          width: 5,
          height: 5,
          borderRadius: "50%",
          background: palette.dot,
          animation: tone === "loading" ? "wsPulse 1.2s ease-in-out infinite" : "none",
        }}
      />
      {label}
    </span>
  );
}

function Loading({ message, error }) {
  return (
    <div
      className="text-center"
      style={{ padding: "60px 20px", color: error ? "#D14343" : "#7A93FF" }}
    >
      <p className="text-sm">{message || (error ? "Couldn't load workspace." : "Loading…")}</p>
    </div>
  );
}

function extractAttachmentUrl(raw) {
  if (raw == null) return null;
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    const first = raw[0];
    if (!first) return null;
    if (typeof first === "string") return first;
    return first.url || first.thumbnailUrl || null;
  }
  if (typeof raw === "object") {
    return raw.url || raw.thumbnailUrl || null;
  }
  return null;
}

function extractText(raw) {
  if (raw == null) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    const f = raw[0];
    if (typeof f === "string") return f;
    return f?.label ?? "";
  }
  if (typeof raw === "object") return raw.label ?? "";
  return String(raw);
}

function Style() {
  return (
    <style>
      {`
        @import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;400;500;600;700&display=swap');
        .settings-workspace * { font-family: 'League Spartan', sans-serif; }

        @keyframes wsPulse {
          0%, 100% { opacity: 0.5; transform: scale(0.85); }
          50%      { opacity: 1;   transform: scale(1.15); }
        }

        .workspace-save-btn {
          background: #7A93FF;
          color: #FFFFFF;
          font-size: 13px;
          font-weight: 600;
          padding: 8px 18px;
          border-radius: 999px;
          border: none;
          cursor: pointer;
          box-shadow: 0 2px 6px rgba(122, 147, 255, 0.3);
          transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
        }
        .workspace-save-btn:hover:not(:disabled) {
          background: #294FF6;
          transform: translateY(-1px);
          box-shadow: 0 4px 12px rgba(41, 79, 246, 0.35);
        }
        .workspace-save-btn:active:not(:disabled) {
          transform: translateY(0);
        }
        .workspace-save-btn:disabled {
          background: #D9E0FF;
          color: #FFFFFF;
          cursor: not-allowed;
          box-shadow: none;
        }

        .workspace-discard-btn {
          background: transparent;
          color: #7A93FF;
          font-size: 13px;
          font-weight: 500;
          padding: 8px 14px;
          border-radius: 999px;
          border: none;
          cursor: pointer;
          transition: color 0.2s ease;
        }
        .workspace-discard-btn:hover:not(:disabled) {
          color: #294FF6;
        }
        .workspace-discard-btn:disabled {
          color: #C5CFE8;
          cursor: not-allowed;
        }

        /* ── Logo upload ──────────────────────────────────────── */
        .workspace-logo-row {
          display: flex;
          align-items: center;
          gap: 14px;
          flex-wrap: wrap;
        }
        .workspace-logo-preview {
          display: flex;
          align-items: center;
          justify-content: flex-start;
          flex-shrink: 0;
          min-height: 64px;
        }
        .workspace-logo-preview img {
          width: 120px;
          height: auto;
          max-height: 120px;
          object-fit: contain;
        }
        .workspace-logo-placeholder {
          font-size: 11px;
          color: #7A93FF;
          font-weight: 500;
          padding: 0;
        }
        .workspace-logo-actions {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          flex-wrap: wrap;
        }
        .workspace-logo-btn {
          padding: 8px 14px;
          background: #FFFFFF;
          color: #7A93FF;
          border: 1px solid rgba(122, 147, 255, 0.45);
          border-radius: 999px;
          font-size: 13px;
          font-weight: 600;
          cursor: pointer;
          transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
        }
        .workspace-logo-btn:hover {
          background: rgba(122, 147, 255, 0.10);
          color: #294FF6;
          border-color: rgba(41, 79, 246, 0.55);
        }
        .workspace-logo-btn-ghost {
          color: #DC2626;
          border-color: rgba(220, 38, 38, 0.40);
        }
        .workspace-logo-btn-ghost:hover {
          background: rgba(220, 38, 38, 0.08);
          color: #B91C1C;
          border-color: rgba(185, 28, 28, 0.55);
        }
      `}
    </style>
  );
}
