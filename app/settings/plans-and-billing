// /settings · Plans and Billing tab
//
// Reads the user's current subscription (via accounts.subscription_*
// lookups, which read through accounts.current_subscription → subscriptions
// table) plus usage-vs-max numbers (via accounts.*_remaining usage
// lookups). Read-only display + action buttons:
//   • Change plan  →  /plans/upgrade  (modal)
//   • Manage billing →  STRIPE_PORTAL_URL  (configure below)
//
// SOFTR CONFIG REQUIRED:
//   Source tab: bind to ACCOUNTS, filter by URL parameter `workspace`
//   so the workspace switcher works end-to-end on this tab too.

import { useRecord, useCurrentRecordId, q } from "@/lib/datasource";

// Stripe customer portal URL (Bev: replace with your portal link
// from Stripe Dashboard → Settings → Billing → Customer portal).
const STRIPE_PORTAL_URL = "https://billing.stripe.com/p/login/REPLACE_ME";
const CHANGE_PLAN_PATH = "/plans/upgrade";
const CHANGE_PLAN_MODAL_SIZE = "xl"; // 'sm' | 'md' | 'lg' | 'xl'

const select = q.select({
  name:                       "aAKkT",
  subscriptionTier:           "oYTWQ",
  subscriptionStatus:         "LX54T",
  subscriptionPeriodEnd:      "xhi4r",
  subscriptionProductName:    "eX2ZC",
  subscriptionInterval:       "nhVIe",
  subscriptionMaxVideos:      "cNlUS",
  subscriptionMaxStorageGb:   "anN5E",
  subscriptionMaxWorkspaces:  "MFzCN",
  subscriptionMaxMembers:     "2k4fx",
  videosRemaining:            "A0Cwp",
  storageRemaining:           "1WK5u",
  workspacesRemaining:        "ILIg2",
  membersRemaining:           "VY8Ge",
  totalVideos:                "qyGWx",
  totalStorageGb:             "1MssQ",
  totalWorkspaces:            "3gogx",
  totalUsers:                 "qwSF2",
});

function useWorkspaceRecordId() {
  const fromContext = useCurrentRecordId();
  const fromUrl =
    typeof window !== "undefined"
      ? new URL(window.location.href).searchParams.get("workspace")
      : null;
  return fromUrl || fromContext;
}

export default function Block() {
  const recordId = useWorkspaceRecordId();
  const { data: record, status } = useRecord({ recordId, select });

  if (status === "pending") return <Shell><Loading /></Shell>;
  if (status === "error") return <Shell><Loading error /></Shell>;
  if (!record || !record.fields) {
    return <Shell><Loading message="No account record found." /></Shell>;
  }

  const f = record.fields;
  const tier            = unwrap(f.subscriptionTier);
  const statusLabel     = unwrap(f.subscriptionStatus);
  const productName     = unwrapText(f.subscriptionProductName);
  const interval        = unwrap(f.subscriptionInterval);
  const periodEnd       = unwrapText(f.subscriptionPeriodEnd);
  const hasSubscription = !!(tier || productName || statusLabel);

  const usage = [
    {
      label: "Videos this cycle",
      used: numberFromMaybeArray(f.totalVideos),
      max: numberFromMaybeArray(f.subscriptionMaxVideos),
      remaining: numberFromMaybeArray(f.videosRemaining),
    },
    {
      label: "Storage",
      used: parseFloat(unwrapText(f.totalStorageGb) || "0"),
      max: numberFromMaybeArray(f.subscriptionMaxStorageGb),
      remaining: numberFromMaybeArray(f.storageRemaining),
      unit: "GB",
    },
    {
      label: "Workspaces",
      used: numberFromMaybeArray(f.totalWorkspaces),
      max: numberFromMaybeArray(f.subscriptionMaxWorkspaces),
      remaining: numberFromMaybeArray(f.workspacesRemaining),
    },
    {
      label: "Team members",
      used: numberFromMaybeArray(f.totalUsers),
      max: numberFromMaybeArray(f.subscriptionMaxMembers),
      remaining: numberFromMaybeArray(f.membersRemaining),
    },
  ];

  const handleChangePlan = () => {
    if (
      typeof window !== "undefined" &&
      typeof window.openSwModal === "function"
    ) {
      window.openSwModal(CHANGE_PLAN_PATH, CHANGE_PLAN_MODAL_SIZE);
    } else if (typeof window !== "undefined") {
      window.location.href = CHANGE_PLAN_PATH;
    }
  };

  const handleManageBilling = () => {
    if (typeof window === "undefined") return;
    window.open(STRIPE_PORTAL_URL, "_blank", "noopener,noreferrer");
  };

  return (
    <Shell>
      {/* ── Current plan card ─────────────────────────────────────── */}
      <section className="pb-card">
        <header className="pb-card-header">
          <div>
            <h3 className="pb-card-title">Current plan</h3>
            <p className="pb-card-sub">
              {hasSubscription
                ? "Your active subscription"
                : "You're on the free tier — upgrade to unlock more."}
            </p>
          </div>
          {hasSubscription && (
            <StatusBadge status={statusLabel} />
          )}
        </header>

        {hasSubscription ? (
          <div className="pb-plan-row">
            <div className="pb-plan-name">
              <span className="pb-plan-product">{productName || tier || "—"}</span>
              {interval && (
                <span className="pb-plan-interval">{interval}</span>
              )}
            </div>
            {periodEnd && (
              <div className="pb-plan-renew">
                {statusLabel === "trial"
                  ? `Trial ends ${formatDate(periodEnd)}`
                  : `Renews ${formatDate(periodEnd)}`}
              </div>
            )}
          </div>
        ) : (
          <div className="pb-empty-state">
            <p>Pick a plan to start reviewing videos at scale.</p>
          </div>
        )}

        <footer className="pb-card-footer">
          <button
            type="button"
            onClick={handleChangePlan}
            className="pb-btn-primary"
          >
            {hasSubscription ? "Change plan" : "Choose a plan"}
          </button>
          {hasSubscription && (
            <button
              type="button"
              onClick={handleManageBilling}
              className="pb-btn-secondary"
            >
              Manage billing →
            </button>
          )}
        </footer>
      </section>

      {/* ── Usage card ────────────────────────────────────────────── */}
      <section className="pb-card">
        <header className="pb-card-header">
          <div>
            <h3 className="pb-card-title">Usage this cycle</h3>
            <p className="pb-card-sub">
              {periodEnd
                ? `Resets on ${formatDate(periodEnd)}`
                : "Track what's left of your monthly allowance."}
            </p>
          </div>
        </header>
        <div className="pb-usage-list">
          {usage.map((u) => (
            <UsageRow key={u.label} {...u} />
          ))}
        </div>
      </section>
    </Shell>
  );
}

// ─────────────────────────────────────────────────────────────────
// Sub-components
// ─────────────────────────────────────────────────────────────────

function Shell({ children }) {
  return (
    <div
      className="flex flex-col"
      style={{
        background: "#FAFBFF",
        borderRadius: "16px",
        padding: "12px 0 48px",
      }}
    >
      <Style />
      <div className="settings-pb container mx-auto px-4 max-w-4xl w-full">
        <div className="space-y-4">{children}</div>
      </div>
    </div>
  );
}

function StatusBadge({ status }) {
  const map = {
    active:   { fg: "#22A06B", bg: "rgba(34, 160, 107, 0.12)", border: "rgba(34, 160, 107, 0.30)", label: "Active" },
    trial:    { fg: "#7A93FF", bg: "rgba(122, 147, 255, 0.12)", border: "rgba(122, 147, 255, 0.30)", label: "Trial" },
    trialing: { fg: "#7A93FF", bg: "rgba(122, 147, 255, 0.12)", border: "rgba(122, 147, 255, 0.30)", label: "Trial" },
    past_due: { fg: "#C97D3F", bg: "rgba(232, 155, 92, 0.12)", border: "rgba(232, 155, 92, 0.40)", label: "Past due" },
    canceled: { fg: "#DC2626", bg: "rgba(220, 38, 38, 0.10)",  border: "rgba(220, 38, 38, 0.35)", label: "Canceled" },
    cancelled:{ fg: "#DC2626", bg: "rgba(220, 38, 38, 0.10)",  border: "rgba(220, 38, 38, 0.35)", label: "Canceled" },
  };
  const v = map[String(status || "").toLowerCase()] || map.trial;
  return (
    <span
      style={{
        display: "inline-flex",
        alignItems: "center",
        gap: 6,
        fontSize: 11,
        fontWeight: 600,
        color: v.fg,
        background: v.bg,
        border: `1px solid ${v.border}`,
        borderRadius: 999,
        padding: "4px 10px",
      }}
    >
      <span
        style={{
          width: 5,
          height: 5,
          borderRadius: "50%",
          background: v.fg,
        }}
      />
      {v.label}
    </span>
  );
}

function UsageRow({ label, used, max, remaining, unit }) {
  const safeMax = Number.isFinite(max) && max > 0 ? max : null;
  const safeUsed = Number.isFinite(used) ? Math.max(0, used) : 0;
  const pct = safeMax ? Math.min(100, Math.round((safeUsed / safeMax) * 100)) : 0;
  const over = safeMax !== null && safeUsed > safeMax;

  return (
    <div className="pb-usage-row">
      <div className="pb-usage-row-top">
        <span className="pb-usage-label">{label}</span>
        <span className="pb-usage-numbers">
          {safeMax !== null
            ? `${formatNum(safeUsed)}${unit ? unit : ""} of ${formatNum(safeMax)}${unit ? unit : ""}`
            : "Not on a plan"}
        </span>
      </div>
      {safeMax !== null && (
        <div className="pb-progress-track">
          <div
            className="pb-progress-fill"
            style={{
              width: `${pct}%`,
              background: over
                ? "linear-gradient(90deg, #DC2626, #B91C1C)"
                : "linear-gradient(90deg, #7A93FF, #294FF6)",
            }}
          />
        </div>
      )}
      {Number.isFinite(remaining) && (
        <div className="pb-usage-remaining">
          {remaining < 0
            ? `${formatNum(Math.abs(remaining))} over`
            : `${formatNum(remaining)} remaining`}
        </div>
      )}
    </div>
  );
}

function Loading({ message, error }) {
  return (
    <div
      className="text-center"
      style={{ padding: "60px 20px", color: error ? "#D14343" : "#7A93FF" }}
    >
      <p className="text-sm">{message || (error ? "Couldn't load billing." : "Loading…")}</p>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────────────────────

function unwrap(raw) {
  if (raw == null) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    const f = raw[0];
    if (typeof f === "string") return f;
    return f?.label ?? "";
  }
  if (typeof raw === "object") return raw.label ?? "";
  return String(raw);
}
function unwrapText(raw) {
  if (raw == null) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    const f = raw[0];
    if (typeof f === "string") return f;
    return f?.label ?? String(f ?? "");
  }
  return String(raw);
}
function numberFromMaybeArray(raw) {
  if (raw == null) return null;
  if (Array.isArray(raw)) {
    if (raw.length === 0) return null;
    return Number(raw[0]);
  }
  if (typeof raw === "number") return raw;
  if (typeof raw === "string") return parseFloat(raw);
  return null;
}
function formatNum(n) {
  if (!Number.isFinite(n)) return "—";
  if (Math.abs(n) < 100) return n.toString();
  return Math.round(n).toLocaleString();
}
function formatDate(iso) {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString("en-GB", {
    day: "numeric", month: "short", year: "numeric",
  });
}

