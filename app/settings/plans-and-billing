// /settings · Plans and Billing tab
//
// Lifts the design Bev had on the existing native column-container
// block: "You are currently on: <tier> plan" heading, "Credits Renew
// on: <date>" subhead, then a 4-column grid of progress-bar stat cards
// (Videos / Team / Workspaces) with an actions card on the right
// (Manage billing + Change plan).
//
// Data source: accounts.subscription_* lookups (which resolve through
// accounts.current_subscription → subscriptions table). No more
// dependency on the legacy usage table — subscription_max_videos,
// subscription_max_members, etc. are the source of truth now.
//
// SOFTR CONFIG REQUIRED:
//   Source tab: bind to ACCOUNTS, filter by URL parameter `workspace`
//   so the workspace switcher works on this tab too (id equals URL
//   parameter `workspace`, fallback to user's first account when
//   absent).

import { useRecord, useCurrentRecordId, q } from "@/lib/datasource";
import { Video, Users, Layers, ExternalLink } from "lucide-react";

// Stripe customer portal URL — Bev: paste the real link from
// Stripe Dashboard → Settings → Billing → Customer portal.
const STRIPE_PORTAL_URL = "https://billing.stripe.com/p/login/REPLACE_ME";
const CHANGE_PLAN_PATH = "/plans/upgrade";
const CHANGE_PLAN_MODAL_SIZE = "xl"; // 'sm' | 'md' | 'lg' | 'xl'

// ─── Brand palette ────────────────────────────────────────────
const BL_NAVY = "#000F4D";
const BL_DEEP = "#001364";
const BL_PERIWINKLE = "#7A93FF";
const BL_BORDER = "rgba(217, 224, 255, 0.55)";
const BL_TRACK = "rgba(217, 224, 255, 0.6)";
const BL_MUTED = "#7A93FF";

const select = q.select({
  // Primary field of the accounts table — useRecord requires it.
  name:                       "aAKkT",
  subscriptionTier:           "oYTWQ",
  subscriptionStatus:         "LX54T",
  subscriptionPeriodEnd:      "xhi4r",
  subscriptionProductName:    "eX2ZC",
  subscriptionInterval:       "nhVIe",
  subscriptionMaxVideos:      "cNlUS",
  subscriptionMaxWorkspaces:  "MFzCN",
  subscriptionMaxMembers:     "2k4fx",
  videosRemaining:            "A0Cwp",
  workspacesRemaining:        "ILIg2",
  membersRemaining:           "VY8Ge",
  totalVideos:                "qyGWx",
  totalWorkspaces:            "3gogx",
  totalUsers:                 "qwSF2",
});

function useWorkspaceRecordId() {
  const fromContext = useCurrentRecordId();
  const fromUrl =
    typeof window !== "undefined"
      ? new URL(window.location.href).searchParams.get("workspace")
      : null;
  return fromUrl || fromContext;
}

export default function Block() {
  const recordId = useWorkspaceRecordId();
  const { data: record, status } = useRecord({ recordId, select });

  if (status === "pending") {
    return <Shell><Loading /></Shell>;
  }
  if (status === "error" || !record || !record.fields) {
    return <Shell><Loading message="Couldn't load billing." error /></Shell>;
  }

  const f = record.fields;
  const tier            = unwrap(f.subscriptionTier);
  const productName     = unwrap(f.subscriptionProductName) || tier;
  const interval        = unwrap(f.subscriptionInterval);
  const statusLabel     = unwrap(f.subscriptionStatus);
  const periodEnd       = unwrap(f.subscriptionPeriodEnd);
  const hasSubscription = !!(productName || tier || statusLabel);

  const videosUsed = num(f.totalVideos);
  const videosMax  = num(f.subscriptionMaxVideos);
  const teamUsed   = num(f.totalUsers);
  const teamMax    = num(f.subscriptionMaxMembers);
  const wsUsed     = num(f.totalWorkspaces);
  const wsMax      = num(f.subscriptionMaxWorkspaces);

  const handleChangePlan = () => {
    if (
      typeof window !== "undefined" &&
      typeof window.openSwModal === "function"
    ) {
      window.openSwModal(CHANGE_PLAN_PATH, CHANGE_PLAN_MODAL_SIZE);
    } else if (typeof window !== "undefined") {
      window.location.href = CHANGE_PLAN_PATH;
    }
  };

  const handleManageBilling = () => {
    if (typeof window === "undefined") return;
    window.open(STRIPE_PORTAL_URL, "_blank", "noopener,noreferrer");
  };

  return (
    <Shell>
      {/* ── Heading row ── */}
      <header className="pb-heading">
        <h2 className="pb-heading-title">
          {hasSubscription ? (
            <>
              You are currently on:{" "}
              <span className="pb-heading-tier">{productName}</span>{" "}
              {interval && <span className="pb-heading-interval">({interval})</span>}{" "}
              plan
            </>
          ) : (
            <>You're not on a plan yet</>
          )}
          {hasSubscription && <StatusBadge status={statusLabel} />}
        </h2>
        {periodEnd && (
          <p className="pb-heading-sub">
            {String(statusLabel).toLowerCase().includes("trial")
              ? `Trial ends ${formatDate(periodEnd)}`
              : `Credits renew on ${formatDate(periodEnd)}`}
          </p>
        )}
      </header>

      {/* ── 4-column grid ── */}
      <div className="pb-grid">
        <StatCard
          icon={Video}
          label="Videos used"
          used={videosUsed}
          max={videosMax}
          hasPlan={hasSubscription}
        />
        <StatCard
          icon={Users}
          label="Team members"
          used={teamUsed}
          max={teamMax}
          hasPlan={hasSubscription}
        />
        <StatCard
          icon={Layers}
          label="Workspaces"
          used={wsUsed}
          max={wsMax}
          hasPlan={hasSubscription}
        />
        <ActionsCard
          hasSubscription={hasSubscription}
          onChangePlan={handleChangePlan}
          onManageBilling={handleManageBilling}
        />
      </div>
    </Shell>
  );
}

// ─── Sub-components ───────────────────────────────────────────

function Shell({ children }) {
  return (
    <div
      className="flex flex-col"
      style={{
        background: "#FAFBFF",
        borderRadius: "16px",
        padding: "12px 0 48px",
      }}
    >
      <Style />
      <div className="settings-pb container mx-auto px-4 max-w-4xl w-full">
        <div className="space-y-6">{children}</div>
      </div>
    </div>
  );
}

function StatCard({ icon: Icon, label, used, max, hasPlan }) {
  const safeMax = Number.isFinite(max) && max > 0 ? max : null;
  const safeUsed = Number.isFinite(used) ? Math.max(0, used) : 0;
  const pct = safeMax ? Math.min(100, Math.round((safeUsed / safeMax) * 100)) : 0;
  const over = safeMax !== null && safeUsed > safeMax;

  return (
    <div className="pb-card">
      <div className="pb-card-head">
        <Icon className="pb-card-icon" size={16} />
        <span className="pb-card-label">{label}</span>
      </div>
      <div className="pb-progress-track">
        <div
          className="pb-progress-fill"
          style={{
            width: `${hasPlan && safeMax ? pct : 0}%`,
            background: over
              ? "linear-gradient(90deg, #DC2626, #B91C1C)"
              : "linear-gradient(90deg, #7A93FF, #294FF6)",
          }}
        />
      </div>
      <div className="pb-card-numbers">
        {hasPlan && safeMax !== null
          ? `${formatCount(safeUsed)} / ${formatCount(safeMax)}`
          : "Not on a plan"}
      </div>
    </div>
  );
}

function ActionsCard({ hasSubscription, onChangePlan, onManageBilling }) {
  return (
    <div className="pb-actions">
      <button
        type="button"
        onClick={onChangePlan}
        className="pb-btn-primary"
      >
        {hasSubscription ? "Change plan" : "Choose a plan"}
      </button>
      {hasSubscription && (
        <button
          type="button"
          onClick={onManageBilling}
          className="pb-btn-secondary"
        >
          Manage billing
          <ExternalLink size={12} />
        </button>
      )}
    </div>
  );
}

function StatusBadge({ status }) {
  const map = {
    active:    { fg: "#22A06B", bg: "rgba(34, 160, 107, 0.12)", border: "rgba(34, 160, 107, 0.30)", label: "Active" },
    trial:     { fg: "#7A93FF", bg: "rgba(122, 147, 255, 0.12)", border: "rgba(122, 147, 255, 0.30)", label: "Trial" },
    trialing:  { fg: "#7A93FF", bg: "rgba(122, 147, 255, 0.12)", border: "rgba(122, 147, 255, 0.30)", label: "Trial" },
    past_due:  { fg: "#C97D3F", bg: "rgba(232, 155, 92, 0.12)", border: "rgba(232, 155, 92, 0.40)", label: "Past due" },
    canceled:  { fg: "#DC2626", bg: "rgba(220, 38, 38, 0.10)",  border: "rgba(220, 38, 38, 0.35)", label: "Canceled" },
    cancelled: { fg: "#DC2626", bg: "rgba(220, 38, 38, 0.10)",  border: "rgba(220, 38, 38, 0.35)", label: "Canceled" },
  };
  const v = map[String(status || "").toLowerCase()] || map.trial;
  return (
    <span className="pb-status-badge" style={{ color: v.fg, background: v.bg, border: `1px solid ${v.border}` }}>
      <span className="pb-status-dot" style={{ background: v.fg }} />
      {v.label}
    </span>
  );
}

function Loading({ message, error }) {
  return (
    <div
      className="text-center"
      style={{ padding: "60px 20px", color: error ? "#D14343" : BL_MUTED }}
    >
      <p className="text-sm">{message || "Loading…"}</p>
    </div>
  );
}

// ─── Helpers ──────────────────────────────────────────────────

function unwrap(raw) {
  if (raw == null) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    const f = raw[0];
    if (typeof f === "string") return f;
    return f?.label ?? String(f ?? "");
  }
  if (typeof raw === "object") return raw.label ?? "";
  return String(raw);
}
function num(raw) {
  if (raw == null) return null;
  if (Array.isArray(raw)) {
    if (raw.length === 0) return null;
    return Number(raw[0]);
  }
  if (typeof raw === "number") return raw;
  if (typeof raw === "string") return parseFloat(raw);
  return null;
}
function formatCount(n) {
  if (!Number.isFinite(n)) return "—";
  return n.toLocaleString("en-GB");
}
function formatDate(iso) {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString("en-GB", {
    day: "numeric", month: "short", year: "numeric",
  });
}

