    {
      name: "Studio",
      icon: "https://res.cloudinary.com/dspv9nm1n/image/upload/v1764176257/zn1adsgwgnuutjgoqqao.png",
      badge: "Save 166.7 hours/month",
      monthlyPrice: "$249.00",
      monthlySavings: "Save $3918.0/month",
      yearlyPrice: "$199.00",
      yearlySavings: "Save $3968.0/month",
      features: [
        "500 Video Reviews",
        "100MB Storage",
        "10 Team Seats",
        "10 Workspaces"
      ],
      monthlyUrl: urls?.studioMonthly,
      yearlyUrl: urls?.studioYearly
    }
