      monthlyPrice: "$99.00",
      monthlySavings: "Save $734.0/month",
      yearlyPrice: "$89.00",
      yearlySavings: "Save $744.0/month",
      features: [
        "100 Video Reviews",
        "50MB Storage",
        "5 Team Seats",
        "5 Workspaces"
      ],
      monthlyUrl: urls?.crewMonthly,
      yearlyUrl: urls?.crewYearly
