  const urls = userRecord ? {
    creatorMonthly: userRecord.fields.creatorMonthlyTrial,
    creatorYearly: userRecord.fields.creatorYearlyTrial,
    crewMonthly: userRecord.fields.crewMonthlyTrial,
    crewYearly: userRecord.fields.crewYearlyTrial,
