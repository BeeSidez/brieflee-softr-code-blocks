  return (
    <div className="container py-12">
      <div className="content max-w-5xl mx-auto">
        {/* Header Section */}
        <div className="text-center mb-8 space-y-3">
          <h1 className="font-sans font-extrabold text-2xl md:text-3xl lg:text-4xl" style={{ color: "#001364" }}>
            Select your free 7-day trial plan
