import { useState, useEffect, useRef } from 'react';
import { useCurrentUser } from '@/lib/user';
import { useRecordCreate, useRecordUpdate, useRecord, useUpload, q } from '@/lib/datasource';
import { Search, Shuffle, CloudUpload, Link, FileText, MessageSquare, Plus } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { toast } from 'sonner';

// ─── Submission table field IDs ───

// Fields for initial record creation (just user + type)
const createFields = q.select({
  submission_type: 'b82bF',
  users: 'DxNOa',
});

// Fields for updating the record after validation passes
const updateFields = q.select({
  video_file: 'PP7rO',
  video_url: 'XrARi',
  submission_type: 'b82bF',
  brief_attachment: 'GmjrC',
  submission_notes: 'UzR32',
  accounts: 'v94f0',
  users: 'DxNOa',
  logic: '3uQTp',
  is_bulk: 'CIp0E',
  user_validation: 'QqS0I',
});

// Fields for reading validation + polling
const readFields = q.select({
  // Validation lookup fields (auto-populate from users relationship)
  // — subscription_status comes from accounts.current_subscription.status (post-migration)
  // — videos_remaining comes from accounts.usage formulas (also post-migration)
  // — is_internal bypasses the gate for staff + test users
  users_subscription_status: 'SQuxf',
  users_videos_remaining: '3kzMt',
  users_is_internal: 'gdFt4',
  users_status: 'Lx9pZ',
  user_validation: 'QqS0I',
  // Polling fields
  status: '4flIO',
  title_notifications: 'edAmZ',
  message_notifications: '0rNpR',
});

// Submission type choice IDs
const SUBMISSION_TYPES = {
  review: '5ed52a56-f33e-475a-bc32-95b11756290f',
  remix: '4d21296f-a7a6-4264-9298-21c7c4a7e6f2',
};

// Logic choice IDs
const LOGIC_CHOICES = {
  file: 'f8b72c1c-340a-4996-84bf-bae4c6ae7245',
  url: '495afa00-1893-43f8-8879-fc996d7f72bf',
  brief: '92a7017f-215a-4704-aca2-94bd7f4a6c9a',
  notes: '255b438e-d37c-40c5-b31f-4ea76ff4c02b',
  bulk: 'dd34c7ee-0dbb-4760-96b4-87b44c7e3442',
};

export default function Block() {
  // ─── Conversation state ───
  const [showTyping1, setShowTyping1] = useState(false);
  const [showMessage1, setShowMessage1] = useState(false);
  const [showTyping2, setShowTyping2] = useState(false);
  const [showCards, setShowCards] = useState(false);

  // Validation state (after early record creation)
  const [showValidationTyping, setShowValidationTyping] = useState(false);
  const [validationPassed, setValidationPassed] = useState(false);
  const [validationFailed, setValidationFailed] = useState(false);
  const [validationError, setValidationError] = useState('');
  const [validationErrorType, setValidationErrorType] = useState(''); // 'payment' or 'credits'

  const [showTyping3, setShowTyping3] = useState(false);
  const [showMessage2, setShowMessage2] = useState(false);
  const [showTyping4, setShowTyping4] = useState(false);
  const [showUploadOptions, setShowUploadOptions] = useState(false);
  const [showUploadUI, setShowUploadUI] = useState(false);
  const [showTyping5, setShowTyping5] = useState(false);
  const [showMessage3, setShowMessage3] = useState(false);
  const [showContextOptions, setShowContextOptions] = useState(false);
  const [showTyping6, setShowTyping6] = useState(false);
  const [showMessage4, setShowMessage4] = useState(false);
  const [showButton, setShowButton] = useState(false);

  // Loading state
  const [showLoadingTyping, setShowLoadingTyping] = useState(false);
  const [showLoadingMessage, setShowLoadingMessage] = useState(false);
  const [showVideoFrame, setShowVideoFrame] = useState(false);
  const [reviewReady, setReviewReady] = useState(false);
  const [submissionRecordId, setSubmissionRecordId] = useState(null);
  const [pollingTimedOut, setPollingTimedOut] = useState(false);
  const [notificationTitle, setNotificationTitle] = useState('');
  const [notificationMessage, setNotificationMessage] = useState('');

  // Form state
  const [selectedMode, setSelectedMode] = useState(null);
  const [uploadMethod, setUploadMethod] = useState(null);
  const [videoFile, setVideoFile] = useState(null);
  const [videoFiles, setVideoFiles] = useState([]);
  const [videoLink, setVideoLink] = useState('');
  const [briefFile, setBriefFile] = useState(null);
  const [notes, setNotes] = useState('');
  const [isDragging, setIsDragging] = useState(false);
  const [showNotesTextarea, setShowNotesTextarea] = useState(false);
  const [noThanksClicked, setNoThanksClicked] = useState(false);
  const [isSubmitted, setIsSubmitted] = useState(false);
  const [isBulkUpload, setIsBulkUpload] = useState(false);
  const [showBulkUpload, setShowBulkUpload] = useState(false);

  const fileInputRef = useRef(null);
  const bulkInputRef = useRef(null);
  const briefInputRef = useRef(null);
  const pollingRef = useRef(null);
  const loadingRef = useRef(null);
  const chatLogRef = useRef(null);
  const user = useCurrentUser();

  // Hero greeting — rotating verb (all read naturally as "[verb] a video")
  const HERO_VERBS = ['review', 'remix', 'analyse', 'break down'];
  const [verbIdx, setVerbIdx] = useState(0);
  useEffect(() => {
    const id = setInterval(() => setVerbIdx((i) => (i + 1) % HERO_VERBS.length), 2400);
    return () => clearInterval(id);
  }, []);
  const firstName =
    (user && (user.firstName || user.first_name || user.fullName?.split(' ')[0] || user.name?.split(' ')[0])) || '';

  // Auto-scroll the chat bubble to the newest message — only on conversation
  // advances, never on unrelated re-renders (e.g. verb rotation tick)
  useEffect(() => {
    if (chatLogRef.current) {
      chatLogRef.current.scrollTo({ top: chatLogRef.current.scrollHeight, behavior: 'smooth' });
    }
  }, [
    showMessage1, showMessage2, showMessage3, showMessage4,
    showCards, showUploadOptions, showContextOptions, showUploadUI,
    showButton, showValidationTyping, validationPassed, validationFailed,
    showLoadingMessage, showVideoFrame, reviewReady, pollingTimedOut,
    isSubmitted, showBulkUpload,
  ]);

  // ─── Upload hook ───
  const { uploadAsync } = useUpload();

  // ─── Record creation hook (early creation — just user + type) ───
  const createRecord = useRecordCreate({
    fields: createFields,
    onSuccess: (newRecord) => {
      setSubmissionRecordId(newRecord.id);
      // Now fetch the record back to check validation fields
      setTimeout(() => {
        refetchSubmission();
      }, 1500); // Small delay for lookup fields to populate
    },
    onError: (error) => {
      toast.error('Something went wrong', {
        description: error.message,
      });
      setShowValidationTyping(false);
    },
  });

  // ─── Record update hook (updates existing record after validation) ───
  const updateRecord = useRecordUpdate({
    fields: updateFields,
    onSuccess: () => {
      toast.success('Submission created!');

      // Show loading sequence
      setShowLoadingTyping(true);
      setTimeout(() => {
        setShowLoadingTyping(false);
        setShowLoadingMessage(true);
      }, 1800);
      setTimeout(() => {
        setShowVideoFrame(true);
        // Start polling for review completion
        startPolling(submissionRecordId);
      }, 2300);
    },
    onError: (error) => {
      toast.error('Failed to submit', {
        description: error.message,
      });
      setShowButton(true);
      setIsSubmitted(false);
    },
  });

  // ─── Read submission record (for validation + polling) ───
  const { data: submissionData, refetch: refetchSubmission } = useRecord({
    recordId: submissionRecordId,
    select: readFields,
  });

  // ─── Handle validation when submission data comes back ───
  useEffect(() => {
    if (!submissionData?.fields || validationPassed || validationFailed) return;
    if (!showValidationTyping) return; // Only validate when we're expecting it

    const fields = submissionData.fields;
    const subscriptionStatus = extractFieldValue(fields.users_subscription_status);
    const videosRemaining = extractNumberValue(fields.users_videos_remaining);
    const isInternal = fields.users_is_internal === true;

    // Internal staff + test users bypass all gates
    if (!isInternal) {
      // Check subscription is active or trialing
      const ALLOWED = ['trialing', 'active'];
      if (!subscriptionStatus || !ALLOWED.includes(subscriptionStatus)) {
        setShowValidationTyping(false);
        setValidationFailed(true);
        setValidationErrorType('payment');
        setValidationError(
          'There is no active subscription on this account. Please upgrade to continue.'
        );
        return;
      }

      // Check credits
      if (videosRemaining <= 0) {
        setShowValidationTyping(false);
        setValidationFailed(true);
        setValidationErrorType('credits');
        setValidationError(
          'You have used all your video credits for this billing cycle. Upgrade or wait until your next renewal.'
        );
        return;
      }
    }

    // Validation passed
    setShowValidationTyping(false);
    setValidationPassed(true);

    // Continue the conversation
    setShowTyping3(true);
    setTimeout(() => {
      setShowTyping3(false);
      setShowMessage2(true);
    }, 1500);
    setTimeout(() => setShowTyping4(true), 2000);
    setTimeout(() => {
      setShowTyping4(false);
      setShowUploadOptions(true);
    }, 3500);
  }, [submissionData, showValidationTyping, validationPassed, validationFailed]);

  // ─── Handle polling results (separate from validation) ───
  useEffect(() => {
    if (!submissionData?.fields || !isSubmitted) return;
    if (!showVideoFrame) return; // Only check during polling phase

    const fields = submissionData.fields;
    const status = extractFieldValue(fields.status);

    if (status && status !== 'pending') {
      // Review complete — grab notification fields
      const title = extractFieldValue(fields.title_notifications);
      const message = extractFieldValue(fields.message_notifications);

      if (title) setNotificationTitle(title);
      if (message) setNotificationMessage(message);

      setReviewReady(true);

      if (pollingRef.current) {
        clearInterval(pollingRef.current);
        pollingRef.current = null;
      }
    }
  }, [submissionData, isSubmitted, showVideoFrame]);

  // ─── Helper: extract value from Airtable fields (handles arrays of objects) ───
  function extractFieldValue(raw) {
    if (Array.isArray(raw) && raw.length > 0) {
      return String(raw[0].label ?? raw[0] ?? '').trim().toLowerCase();
    }
    if (typeof raw === 'object' && raw !== null) {
      return String(raw.label ?? '').trim().toLowerCase();
    }
    return String(raw ?? '').trim().toLowerCase();
  }

  function extractNumberValue(raw) {
    let val;
    if (Array.isArray(raw)) {
      val = Number(raw[0] ?? 0);
    } else {
      val = Number(raw ?? 0);
    }
    return Number.isFinite(val) ? val : 0;
  }

  // ─── Polling for review completion ───
  const startPolling = (recordId) => {
    let attempts = 0;

    pollingRef.current = setInterval(async () => {
      attempts++;

      // Timeout after 120 seconds (12 attempts × 10s)
      if (attempts >= 12) {
        setPollingTimedOut(true);
        setReviewReady(true);
        clearInterval(pollingRef.current);
        pollingRef.current = null;
        return;
      }

      try {
        await refetchSubmission();
      } catch (e) {
        // Keep polling on error
      }
    }, 10000); // Poll every 10 seconds
  };

  // ─── Initial conversation start ───
  useEffect(() => {
    setTimeout(() => setShowTyping1(true), 300);
    setTimeout(() => {
      setShowTyping1(false);
      setShowMessage1(true);
    }, 1800);
    setTimeout(() => setShowTyping2(true), 2300);
    setTimeout(() => {
      setShowTyping2(false);
      setShowCards(true);
    }, 4000);
  }, []);

  // ─── After mode selection: create record immediately ───
  useEffect(() => {
    if (!selectedMode || selectedMode === 'campaign') return;
    if (submissionRecordId || !user?.id) return; // Already created or no user

    // Show validation typing indicator
    setShowValidationTyping(true);

    // Create submission with just user + type
    createRecord.mutate({
      submission_type: SUBMISSION_TYPES[selectedMode],
      users: [user.id],
    });
  }, [selectedMode, user]);

  // ─── Reset context when switching to Remix mode ───
  useEffect(() => {
    if (selectedMode === 'remix') {
      setShowMessage3(false);
      setShowContextOptions(false);
      setShowMessage4(false);
      setBriefFile(null);
      setNotes('');
      setShowNotesTextarea(false);
      setNoThanksClicked(false);
    }
  }, [selectedMode]);

  // ─── After upload method selection ───
  useEffect(() => {
    if (uploadMethod && !showUploadUI) {
      setShowUploadUI(true);
    }
  }, [uploadMethod]);

  // ─── After content is uploaded ───
  useEffect(() => {
    const hasContent = videoFile || videoFiles.length > 0 || videoLink.trim().length > 0;
    if (hasContent && !showMessage3) {
      if (selectedMode === 'remix') {
        setShowButton(true);
      } else {
        setShowTyping5(true);
        setTimeout(() => {
          setShowTyping5(false);
          setShowMessage3(true);
          setShowContextOptions(true);
        }, 1500);
      }
    }
  }, [videoFile, videoFiles, videoLink, selectedMode]);

  // ─── After context interaction ───
  useEffect(() => {
    if (
      (briefFile || notes.trim().length > 0 || showNotesTextarea || noThanksClicked) &&
      !showMessage4 &&
      selectedMode === 'review'
    ) {
      setShowTyping6(true);
      setTimeout(() => {
        setShowTyping6(false);
        setShowMessage4(true);
      }, 1500);
      setTimeout(() => setShowButton(true), 2000);
    }
  }, [briefFile, notes, showNotesTextarea, noThanksClicked, selectedMode]);

  // ─── Auto-scroll ───
  useEffect(() => {
    if (showVideoFrame && loadingRef.current) {
      loadingRef.current.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [showVideoFrame]);

  useEffect(() => {
    if (reviewReady && loadingRef.current) {
      loadingRef.current.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [reviewReady]);

  // ─── Clean up polling on unmount ───
  useEffect(() => {
    return () => {
      if (pollingRef.current) clearInterval(pollingRef.current);
    };
  }, []);

  // ─── File handlers ───

  const handleDragOver = (e) => {
    e.preventDefault();
    setIsDragging(true);
  };

  const handleDragLeave = () => {
    setIsDragging(false);
  };

  const handleDrop = (e) => {
    e.preventDefault();
    setIsDragging(false);
    const files = Array.from(e.dataTransfer.files);
    if (files.length === 0) return;

    const validFiles = files.filter((f) => f.type.startsWith('video/'));
    if (validFiles.length === 0) {
      toast.error('Please upload video files');
      return;
    }

    // Check total size
    const totalSize = validFiles.reduce((sum, f) => sum + f.size, 0);
    if (totalSize > 100 * 1024 * 1024) {
      toast.error('Total file size must be under 100MB');
      return;
    }

    if (validFiles.length > 100) {
      toast.error('Maximum 100 files per upload');
      return;
    }

    if (validFiles.length > 1) {
      setVideoFiles(validFiles);
      setIsBulkUpload(true);
      setVideoFile(null);
    } else {
      setVideoFile(validFiles[0]);
      setVideoFiles([]);
      setIsBulkUpload(false);
    }
    setVideoLink('');
  };

  const handleFileSelect = (e) => {
    const files = Array.from(e.target.files);
    if (files.length === 0) return;

    const validFiles = files.filter((f) => f.type.startsWith('video/'));
    if (validFiles.length === 0) {
      toast.error('Please upload video files');
      return;
    }

    const totalSize = validFiles.reduce((sum, f) => sum + f.size, 0);
    if (totalSize > 100 * 1024 * 1024) {
      toast.error('Total file size must be under 100MB');
      return;
    }

    if (validFiles.length > 1) {
      setVideoFiles(validFiles);
      setIsBulkUpload(true);
      setVideoFile(null);
    } else {
      setVideoFile(validFiles[0]);
      setVideoFiles([]);
      setIsBulkUpload(false);
    }
    setVideoLink('');
  };

  const handleBulkSelect = (e) => {
    const files = Array.from(e.target.files);
    if (files.length === 0) return;

    const validFiles = files.filter((f) => f.type.startsWith('video/'));
    if (validFiles.length === 0) {
      toast.error('Please upload video files');
      return;
    }

    if (validFiles.length > 100) {
      toast.error('Maximum 100 files per upload');
      return;
    }

    const totalSize = validFiles.reduce((sum, f) => sum + f.size, 0);
    if (totalSize > 100 * 1024 * 1024) {
      toast.error('Total file size must be under 100MB');
      return;
    }

    setVideoFiles(validFiles);
    setIsBulkUpload(true);
    setVideoFile(null);
    setVideoLink('');
  };

  const handleBriefSelect = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    if (file.type !== 'application/pdf') {
      toast.error('Brief must be a PDF file');
      return;
    }
    setBriefFile(file);
  };

  const handleNoThanks = () => {
    setNoThanksClicked(true);
  };

  // ─── Build logic array from user choices ───
  const buildLogicChoices = () => {
    const choices = [];
    if (uploadMethod === 'file') choices.push(LOGIC_CHOICES.file);
    if (uploadMethod === 'url') choices.push(LOGIC_CHOICES.url);
    if (briefFile) choices.push(LOGIC_CHOICES.brief);
    if (notes.trim().length > 0) choices.push(LOGIC_CHOICES.notes);
    if (isBulkUpload) choices.push(LOGIC_CHOICES.bulk);
    return choices;
  };

  // ─── Submit handler — uploads files then UPDATES the existing record ───
  const handleSubmit = async () => {
    if (!videoFile && videoFiles.length === 0 && !videoLink) {
      toast.error('Please upload a video or paste a link');
      return;
    }

    if (!submissionRecordId) {
      toast.error('Submission not ready yet. Please wait...');
      return;
    }

    setShowButton(false);
    setIsSubmitted(true);

    try {
      const payload = {
        logic: buildLogicChoices(),
        submission_notes: notes.trim() || null,
        is_bulk: isBulkUpload,
        user_validation: 'proceed', // Set to proceed — validation already passed
      };

      // Upload video file(s)
      if (isBulkUpload && videoFiles.length > 0) {
        toast.info(`Uploading ${videoFiles.length} videos...`);
        const results = await uploadAsync(videoFiles);
        const successfulUploads = results.filter((r) => r.status === 'completed' && r.url);

        if (successfulUploads.length === 0) {
          throw new Error('All video uploads failed');
        }

        payload.video_file = successfulUploads.map((r) => ({
          filename: r.file.name,
          url: r.url,
        }));

        if (successfulUploads.length < videoFiles.length) {
          toast.warning(
            `${successfulUploads.length} of ${videoFiles.length} videos uploaded successfully`
          );
        }
      } else if (videoFile) {
        toast.info('Uploading video...');
        const [videoResult] = await uploadAsync(videoFile);

        if (videoResult.status === 'completed' && videoResult.url) {
          payload.video_file = [{ filename: videoResult.file.name, url: videoResult.url }];
        } else {
          throw new Error(videoResult.error?.message || 'Video upload failed');
        }
      }

      // Add video URL if provided (not file)
      if (videoLink.trim() && !videoFile && videoFiles.length === 0) {
        payload.video_url = videoLink.trim();
      }

      // Upload brief attachment
      if (briefFile) {
        toast.info('Uploading brief...');
        const [briefResult] = await uploadAsync(briefFile);

        if (briefResult.status === 'completed' && briefResult.url) {
          payload.brief_attachment = [{ filename: briefResult.file.name, url: briefResult.url }];
        } else {
          throw new Error(briefResult.error?.message || 'Brief upload failed');
        }
      }

      // UPDATE the existing record (not create new)
      updateRecord.mutate({
        recordId: submissionRecordId,
        ...payload,
      });
    } catch (error) {
      console.error('Submit error:', error);
      toast.error('Upload failed', {
        description: error.message,
      });
      setShowButton(true);
      setIsSubmitted(false);
    }
  };

  const hasContent = videoFile || videoFiles.length > 0 || videoLink.trim().length > 0;

  // ─── Mode cards ───
  const modes = [
    {
      value: 'review',
      label: 'Review content',
      icon: Search,
      description:
        "Got a video you want checked? Upload it or paste a link and I'll review it against your content blueprint and quality standards.",
    },
    {
      value: 'remix',
      label: 'Remix content',
      icon: Shuffle,
      description:
        "Seen a piece of content you love? Drop it in and I'll break down what makes it work, then remix it for your brand.",
    },
    {
      value: 'campaign',
      label: 'Create campaign',
      icon: Plus,
      description:
        "Want creators to submit content to you? Create a project, build your brief, share the link. Creators upload directly and I'll review everything as it comes in.",
    },
  ];

  const uploadMethods = [
    { value: 'file', label: 'Upload a file', icon: CloudUpload },
    { value: 'url', label: 'Paste a link', icon: Link },
  ];

  // ─── Reusable components ───

  const TypingIndicator = ({ withAvatar = true }) => (
    <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-300">
      <div className="flex gap-2.5 items-start">
        {withAvatar ? (
          <img
            src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png"
            alt="Lee"
            className="w-8 h-8 rounded-full flex-shrink-0"
          />
        ) : (
          <div className="w-8 h-8 flex-shrink-0"></div>
        )}
        <div
          className="bg-white rounded-2xl rounded-tl-sm p-3 px-5 shadow-sm"
          style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}
        >
          <div className="flex gap-1.5">
            <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
            <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
            <div className="w-2 h-2 rounded-full typing-dot" style={{ backgroundColor: '#7A93FF' }}></div>
          </div>
        </div>
      </div>
    </div>
  );

  const LeeMessage = ({ children }) => (
    <div className="mb-4 animate-in fade-in slide-in-from-bottom-3 duration-500">
      <div className="flex gap-2.5 items-start">
        <img
          src="https://res.cloudinary.com/dspv9nm1n/image/upload/v1771427670/obl2odsrkhunneswor46.png"
          alt="Lee"
          className="w-8 h-8 rounded-full flex-shrink-0"
        />
        <div
          className="bg-white rounded-2xl rounded-tl-sm p-3 shadow-sm max-w-lg"
          style={{ border: '1px solid rgba(217, 224, 255, 0.4)' }}
        >
          <p className="text-sm leading-relaxed" style={{ color: '#000F4D', fontWeight: 300 }}>
            {children}
          </p>
        </div>
      </div>
    </div>
  );

  // ─── Message 4 text depends on context choice ───
  const getMessage4Text = () => {
    if (noThanksClicked) {
      return "No worries — I'll review it against your content blueprint and quality standards.";
    }
    return "Got it, I'll use that alongside your content blueprint and quality standards.";
  };

  return (
    <div
      className="flex flex-col"
      style={{
        background: '#FAFBFF',
        borderRadius: '16px',
        padding: '32px 0 28px',
      }}
    >
      <style>
        {`
          @import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;500;800&display=swap');
          * { font-family: 'League Spartan', sans-serif; }

          @keyframes bounce {
            0%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-8px); }
          }
          .typing-dot { animation: bounce 1.4s infinite; }
          .typing-dot:nth-child(2) { animation-delay: 0.2s; }
          .typing-dot:nth-child(3) { animation-delay: 0.4s; }

          @keyframes gradientSpin {
            0% { transform: rotate(0deg); }
