                <button
                  onClick={handleNoThanks}
                  className="inline-block text-left px-4 py-3 rounded-xl transition-all duration-200 bg-white shadow-sm hover:shadow-md"
                  style={{
                    border: '1px solid rgba(217, 224, 255, 0.4)',
                    opacity: isSubmitted ? 0.6 : 1,
                    cursor: isSubmitted ? 'default' : 'pointer',
                    pointerEvents: isSubmitted ? 'none' : 'auto',
                  }}
                >
                  <div className="flex items-center gap-2">
                    <span className="text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                      No thanks
                    </span>
                  </div>
                </button>
              </div>
            </div>
          )}

          {/* ══════════════════════════════════════════════════ */}
          {/* MESSAGE 4: Context response (varies)              */}
          {/* ══════════════════════════════════════════════════ */}

          {showTyping6 && <TypingIndicator />}

          {showMessage4 && <LeeMessage>{getMessage4Text()}</LeeMessage>}

          {/* ══════════════════════════════════════════════════ */}
          {/* SUBMIT BUTTON                                     */}
          {/* ══════════════════════════════════════════════════ */}

          {showButton && (
            <div className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <Button
                onClick={handleSubmit}
                disabled={!hasContent || updateRecord.status === 'pending'}
                className="text-sm py-2 px-5 shadow-sm hover:shadow-md transition-all duration-300"
                style={{
                  backgroundColor: hasContent ? '#7A93FF' : '#D9E0FF',
                  color: '#FFFFFF',
                  borderRadius: '8px',
                  fontWeight: 500,
                  cursor: hasContent ? 'pointer' : 'not-allowed',
                }}
              >
                {updateRecord.status === 'pending'
                  ? 'Submitting...'
                  : selectedMode === 'remix'
                  ? 'Remix this video →'
                  : 'Review my video →'}
              </Button>
            </div>
          )}

          {/* ══════════════════════════════════════════════════ */}
          {/* LOADING SECTION                                   */}
          {/* ══════════════════════════════════════════════════ */}

          {showLoadingTyping && <TypingIndicator />}

          {showLoadingMessage && (
            <LeeMessage>
              {reviewReady
                ? pollingTimedOut
                  ? "This is taking a little longer than usual. I'll send you an email when your review is ready."
                  : notificationTitle || "Your review is ready! Here's what I found."
                : 'Give me a moment while I review your content...'}
            </LeeMessage>
          )}

          {/* ══════════════════════════════════════════════════ */}
          {/* VIDEO FRAME with animated gradient border         */}
          {/* ══════════════════════════════════════════════════ */}

          {showVideoFrame && (
            <div ref={loadingRef} className="mb-4 ml-10 animate-in fade-in slide-in-from-bottom-3 duration-500">
              <div className={reviewReady ? 'review-ready' : ''}>
                <div className="video-frame-outer">
                  <div className="video-frame-inner">
                    {!reviewReady ? (
                      /* ── LOADING STATE ── */
                      <div className="flex flex-col items-center justify-center px-6 text-center">
                        <div
                          style={{
                            border: '3px solid #D9E0FF',
                            borderTop: '3px solid #7A93FF',
                            borderRadius: '50%',
                            width: '36px',
                            height: '36px',
                            animation: 'spin 1s linear infinite',
                          }}
                        ></div>
                        <p className="mt-5 text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          Analysing your content...
                        </p>
                        <p
                          className="mt-2 text-xs leading-relaxed"
                          style={{ color: '#001364', fontWeight: 300 }}
                        >
                          Our AI is reviewing your submission. This usually takes a few minutes.
                        </p>
                        <div className="flex gap-1.5 mt-6">
                          <div
                            className="w-1.5 h-1.5 rounded-full"
                            style={{ backgroundColor: '#7A93FF', animation: 'pulse 1.5s ease-in-out infinite' }}
                          ></div>
                          <div
                            className="w-1.5 h-1.5 rounded-full"
                            style={{
                              backgroundColor: '#7A93FF',
                              animation: 'pulse 1.5s ease-in-out 0.3s infinite',
                            }}
                          ></div>
                          <div
                            className="w-1.5 h-1.5 rounded-full"
                            style={{
                              backgroundColor: '#7A93FF',
                              animation: 'pulse 1.5s ease-in-out 0.6s infinite',
                            }}
                          ></div>
                        </div>
                      </div>
                    ) : pollingTimedOut ? (
                      /* ── TIMEOUT STATE ── */
                      <div
                        className="flex flex-col items-center justify-center px-6 text-center"
                        style={{ animation: 'fadeInUp 0.5s ease-out' }}
                      >
                        <div
                          className="w-12 h-12 rounded-full flex items-center justify-center"
                          style={{ backgroundColor: 'rgba(122, 147, 255, 0.1)' }}
                        >
                          <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#7A93FF"
                            strokeWidth="2.5"
                            strokeLinecap="round"
                            strokeLinejoin="round"
                          >
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                          </svg>
                        </div>
                        <p className="mt-4 text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          Still processing
                        </p>
                        <p
                          className="mt-1.5 text-xs leading-relaxed"
                          style={{ color: '#001364', fontWeight: 300 }}
                        >
                          We'll email you when it's ready.
                        </p>
                        <a
                          href="/submissions"
                          className="mt-5 inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm transition-all duration-200"
                          style={{
                            backgroundColor: '#7A93FF',
                            color: '#FFFFFF',
                            fontWeight: 500,
                            textDecoration: 'none',
                            boxShadow: '0 2px 8px rgba(122, 147, 255, 0.3)',
                          }}
                        >
                          Go to dashboard →
                        </a>
                      </div>
                    ) : (
                      /* ── READY STATE ── */
                      <div
                        className="flex flex-col items-center justify-center px-6 text-center"
                        style={{ animation: 'fadeInUp 0.5s ease-out' }}
                      >
                        <div
                          className="w-12 h-12 rounded-full flex items-center justify-center"
                          style={{ backgroundColor: 'rgba(122, 147, 255, 0.1)' }}
                        >
                          <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#7A93FF"
                            strokeWidth="2.5"
                            strokeLinecap="round"
                            strokeLinejoin="round"
                          >
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </div>
                        <p className="mt-4 text-sm" style={{ color: '#000F4D', fontWeight: 500 }}>
                          Review complete!
                        </p>
                        {notificationMessage && (
                          <p
                            className="mt-1.5 text-xs leading-relaxed"
                            style={{ color: '#001364', fontWeight: 300 }}
                          >
                            {notificationMessage}
                          </p>
                        )}
                        {!notificationMessage && (
                          <p
                            className="mt-1.5 text-xs leading-relaxed"
                            style={{ color: '#001364', fontWeight: 300 }}
                          >
                            Your content has been analysed. Click below to see your results.
                          </p>
                        )}
                        <a
                          href={'/submissions/details?recordId=' + submissionRecordId}
                          className="mt-5 inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm transition-all duration-200"
                          style={{
                            backgroundColor: '#7A93FF',
                            color: '#FFFFFF',
                            fontWeight: 500,
                            textDecoration: 'none',
                            boxShadow: '0 2px 8px rgba(122, 147, 255, 0.3)',
                          }}
                          onMouseEnter={(e) =>
                            (e.target.style.boxShadow = '0 4px 12px rgba(122, 147, 255, 0.4)')
                          }
                          onMouseLeave={(e) =>
                            (e.target.style.boxShadow = '0 2px 8px rgba(122, 147, 255, 0.3)')
                          }
                        >
                          {selectedMode === 'remix' ? 'View my remix →' : 'View my results →'}
                        </a>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}

            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
