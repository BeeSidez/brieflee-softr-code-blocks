        padding: 4px 10px; border-radius: 999px;
        margin-bottom: 12px;
      }
      .pt-desc { font-size: 13px; line-height: 1.5; color: #555; margin: 0 0 18px; min-height: 38px; }

      .pt-price-row { display: flex; align-items: baseline; gap: 4px; }
      .pt-price { font-size: 44px; line-height: 1; font-weight: 800; color: #001364; letter-spacing: -0.02em; }
      .pt-per { font-size: 14px; color: #555; font-weight: 500; }
      .pt-billed { font-size: 12px; color: #555; margin: 6px 0 18px; }

      .pt-saves { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
      .pt-save {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px; border-radius: 999px;
        font-size: 12px; font-weight: 600;
        background: #ECF0FF; color: #294ff6;
      }

      .pt-features { list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 8px; }
      .pt-features li {
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; color: #001364;
      }
      .pt-features li svg { color: #294ff6; flex-shrink: 0; }

      .pt-cta {
        width: 100%; padding: 14px 18px; font-size: 14px; font-weight: 700;
        background: #294ff6; color: #fff; border-radius: 12px;
        border: none; cursor: pointer;
        transition: all 200ms cubic-bezier(0.32,0.72,0,1);
      }
      .pt-cta:hover:not([disabled]) { background: #001364; transform: translateY(-1px); box-shadow: 0 8px 18px rgba(41,79,246,0.25); }
      .pt-cta[disabled] { opacity: 0.5; cursor: not-allowed; }

      .pt-trust {
        margin-top: 32px; display: flex; gap: 8px;
        align-items: center; justify-content: center;
        font-size: 13px; color: #555;
      }
      .pt-dot { color: #d6defc; }
    `}</style>
  );
}
