      }
      .pt-toggle-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 18px; border-radius: 999px;
        background: transparent; color: #001364;
        font-size: 14px; font-weight: 500; cursor: pointer;
        border: none; transition: all 200ms cubic-bezier(0.32,0.72,0,1);
      }
      .pt-toggle-btn.on {
        background: #fff; font-weight: 700;
        box-shadow: 0 1px 2px rgba(0,15,77,0.08);
      }
      .pt-toggle-badge {
        font-size: 11px; font-weight: 700;
        background: #294ff6; color: #fff;
        padding: 2px 8px; border-radius: 999px;
      }

      .pt-grid {
        display: grid; gap: 20px;
        grid-template-columns: 1fr;
        margin: 0 auto; max-width: 1100px;
      }
      @media (min-width: 880px) { .pt-grid { grid-template-columns: repeat(3, 1fr); } }

      .pt-card {
        background: #fff; border: 1px solid #d6defc;
        border-radius: 20px; overflow: hidden; text-align: left;
        box-shadow: 0 2px 8px rgba(0,15,77,0.04);
        transition: transform 200ms cubic-bezier(0.32,0.72,0,1), box-shadow 200ms;
      }
      .pt-card:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(41,79,246,0.10); }
