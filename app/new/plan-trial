// Plan page - TRIAL block.
// Visible only to users without an active Stripe subscription (set the gate in
// the Vibe block's Visibility tab: condition like "Stripe Customer ID is empty"
// or "subscription_status is empty").
//
// Reads the 6 trial Payment Link formula URLs from the users table and renders
// 3 plan cards with a Monthly / Yearly toggle. Click a card -> Stripe Payment
// Link with the 7-day trial baked in. Same tab navigation; Stripe redirects
// back to /set-up after card collection.

import { useState } from "react";
import { Button } from "@/components/ui/button";
import { useCurrentUser } from "@/lib/user";
import { useRecords, q } from "@/lib/datasource";
import { Check, Clock } from "lucide-react";

const select = q.select({
  creatorMonthlyTrial: "677EA",
  creatorYearlyTrial:  "mK0hY",
  crewMonthlyTrial:    "SFCVz",
  crewYearlyTrial:     "pdBWv",
  studioMonthlyTrial:  "mKn7h",
  studioYearlyTrial:   "Dl2tb",
});

const PLANS = [
  {
    tier: "Creator",
    desc: "For solos and freelancers reviewing their own UGC.",
    monthly: 59,  yearly: 588,
    maxVideos: 30,  maxWorkspaces: 1,  maxUsers: 1,
    hoursSaved: "10 hours / month",
    moneySaved: "$200 / month",
  },
  {
    tier: "Crew",
    desc: "The winning ad workflow for growing brands and small teams.",
    monthly: 99,  yearly: 1068,
    maxVideos: 100, maxWorkspaces: 5,  maxUsers: 5,
    hoursSaved: "33 hours / month",
    moneySaved: "$740 / month",
    popular: true,
  },
  {
    tier: "Studio",
    desc: "Scaled review for agencies running multiple brand accounts.",
    monthly: 249, yearly: 2388,
    maxVideos: 500, maxWorkspaces: 10, maxUsers: 10,
    hoursSaved: "167 hours / month",
    moneySaved: "$3,900 / month",
  },
];

const FEATURES = (p) => [
  `${p.maxVideos} videos / month`,
  `${p.maxWorkspaces} ${p.maxWorkspaces === 1 ? "workspace" : "workspaces"}`,
  `${p.maxUsers} ${p.maxUsers === 1 ? "seat" : "seats"}`,
  "AI video review",
  "Briefs & checklists",
  "AI QA Checklist",
  "Storyboard view",
  "Remix & revisions",
];

const TRIAL_DAYS = 7;

export default function Block() {
  const [isYearly, setIsYearly] = useState(true);
  const user = useCurrentUser();
  const { data, status } = useRecords({ select, count: 1 });

  const userRecord = data?.pages?.[0]?.items?.[0];
  const urls = userRecord
    ? {
        Creator: { Monthly: userRecord.fields.creatorMonthlyTrial, Yearly: userRecord.fields.creatorYearlyTrial },
        Crew:    { Monthly: userRecord.fields.crewMonthlyTrial,    Yearly: userRecord.fields.crewYearlyTrial },
        Studio:  { Monthly: userRecord.fields.studioMonthlyTrial,  Yearly: userRecord.fields.studioYearlyTrial },
      }
    : {};

  const handleStart = (tier) => {
    const interval = isYearly ? "Yearly" : "Monthly";
    const url = urls[tier]?.[interval];
    if (url) window.location.href = url;
  };

  if (status === "pending") {
    return (
      <div className="container py-12 text-center text-sm" style={{ color: "#6b7280" }}>
        Loading plans...
      </div>
    );
  }

  return (
    <div className="pt-root">
      <Style />
      <div className="container py-12">
        <div className="content text-center">
          <div className="pt-eyebrow">Pick your plan</div>
          <h1 className="pt-title">Try Brieflee free for {TRIAL_DAYS} days</h1>
          <p className="pt-sub">
            No charge until your trial ends. Cancel any time.
          </p>

          <IntervalToggle isYearly={isYearly} onChange={setIsYearly} />

          <div className="pt-grid">
            {PLANS.map((p) => {
              const monthlyEquivalent = isYearly ? Math.round(p.yearly / 12) : p.monthly;
              return (
                <div
                  key={p.tier}
                  className={"pt-card" + (p.popular ? " pt-card-popular" : "")}
                >
                  {p.popular && <div className="pt-popular">Most popular</div>}
                  <div className="pt-card-body">
                    <div className="pt-tier">{p.tier}</div>
                    <p className="pt-desc">{p.desc}</p>

                    <div className="pt-price-row">
                      <span className="pt-price">${monthlyEquivalent}</span>
                      <span className="pt-per">/mo</span>
                    </div>
                    <div className="pt-billed">
                      {isYearly ? `Billed $${p.yearly.toLocaleString()} annually` : "Billed monthly"}
                    </div>

                    <div className="pt-saves">
                      <div className="pt-save pt-save-time">
                        <Clock className="w-3.5 h-3.5" />
                        Save {p.hoursSaved}
                      </div>
                    </div>

                    <ul className="pt-features">
                      {FEATURES(p).map((f) => (
                        <li key={f}>
                          <Check className="w-3.5 h-3.5" />
                          <span>{f}</span>
                        </li>
                      ))}
                    </ul>

                    <Button
                      onClick={() => handleStart(p.tier)}
                      disabled={!urls[p.tier]?.[isYearly ? "Yearly" : "Monthly"]}
                      className="pt-cta"
                    >
                      Start {TRIAL_DAYS}-day free trial
                    </Button>
                  </div>
                </div>
              );
            })}
          </div>

          <div className="pt-trust">
            <span>$0 today</span>
            <span className="pt-dot">·</span>
            <span>Cancel anytime</span>
            <span className="pt-dot">·</span>
            <span>Powered by Stripe</span>
          </div>
        </div>
      </div>
    </div>
  );
}

function IntervalToggle({ isYearly, onChange }) {
  return (
    <div className="pt-toggle-wrap">
      <div className="pt-toggle">
        <button
          onClick={() => onChange(false)}
          className={"pt-toggle-btn" + (!isYearly ? " on" : "")}
        >
          Monthly
        </button>
        <button
          onClick={() => onChange(true)}
          className={"pt-toggle-btn" + (isYearly ? " on" : "")}
        >
          Yearly
          <span className="pt-toggle-badge">Save ~17%</span>
        </button>
      </div>
    </div>
  );
}

function Style() {
  return (
    <style>{`
      @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
      .pt-root, .pt-root * { font-family: 'Plus Jakarta Sans', sans-serif; }

      .pt-eyebrow {
        font-size: 12px; letter-spacing: 0.08em; font-weight: 700;
        text-transform: uppercase; color: #879cf7;
        margin-bottom: 12px;
      }
      .pt-title {
        font-size: 44px; line-height: 1.1; letter-spacing: -0.02em;
        font-weight: 800; color: #001364;
        margin: 0 0 12px;
      }
      .pt-sub {
        font-size: 16px; line-height: 1.55; color: #555;
