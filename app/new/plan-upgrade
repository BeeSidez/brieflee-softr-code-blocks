// Plan page - UPGRADE / DOWNGRADE block.
// Visible only to users with an active Stripe subscription (set the gate in
// the Vibe block's Visibility tab: condition like "Stripe Customer ID is not
// empty" or "subscription_status is one of trialing/active").
//
// Reads the 6 non-trial Payment Link formula URLs + the user's current Plan
// (Ux1pf, LINKED_RECORD -> pricing). Renders 3 plan cards. The user's current
// plan is greyed out + labelled "Current plan". All other cards are clickable.
// Clicking a tier BELOW the current shows a confirm dialog with what the user
// will lose; clicking a tier AT or ABOVE goes straight to checkout.

import { useState } from "react";
import { Button } from "@/components/ui/button";
import { useCurrentUser } from "@/lib/user";
import { useRecords, q } from "@/lib/datasource";
import { Check, Clock, X, AlertTriangle } from "lucide-react";

const select = q.select({
  creatorMonthly: "Dm9jQ",
  creatorYearly:  "CzRio",
  crewMonthly:    "L9h2t",
  crewYearly:     "bYDDj",
  studioMonthly:  "YXlM3",
  studioYearly:   "r7OxD",
  plan:           "Ux1pf",  // LINKED_RECORD -> pricing (the user's current plan)
});

// 6 canonical pricing rows. Ordered by tier rank so we can detect downgrade
// via index comparison (lower rank = lower tier).
const PRICING_ROWS = [
  { id: "MOFJ50J3sX5cQ4", tier: "Creator", interval: "Monthly", rank: 0 },
  { id: "efLCArKogDzBco", tier: "Creator", interval: "Yearly",  rank: 0 },
  { id: "3DudH4fLuqChIr", tier: "Crew",    interval: "Monthly", rank: 1 },
  { id: "QHonFLGNkspIop", tier: "Crew",    interval: "Yearly",  rank: 1 },
  { id: "AQI1eTOfZOYM5h", tier: "Studio",  interval: "Monthly", rank: 2 },
  { id: "KHrjkggVIoUOze", tier: "Studio",  interval: "Yearly",  rank: 2 },
];

const PLANS = [
  {
    tier: "Creator", rank: 0,
    desc: "For solos and freelancers reviewing their own UGC.",
    monthly: 59,  yearly: 588,
    maxVideos: 30,  maxWorkspaces: 1,  maxUsers: 1,
    hoursSaved: "10 hours / month",
  },
  {
    tier: "Crew", rank: 1,
    desc: "The winning ad workflow for growing brands and small teams.",
    monthly: 99,  yearly: 1068,
    maxVideos: 100, maxWorkspaces: 5,  maxUsers: 5,
    hoursSaved: "33 hours / month",
    popular: true,
  },
  {
    tier: "Studio", rank: 2,
    desc: "Scaled review for agencies running multiple brand accounts.",
    monthly: 249, yearly: 2388,
    maxVideos: 500, maxWorkspaces: 10, maxUsers: 10,
    hoursSaved: "167 hours / month",
  },
];

const FEATURES = (p) => [
  `${p.maxVideos} videos / month`,
  `${p.maxWorkspaces} ${p.maxWorkspaces === 1 ? "workspace" : "workspaces"}`,
  `${p.maxUsers} ${p.maxUsers === 1 ? "seat" : "seats"}`,
  "AI video review",
  "Briefs & checklists",
  "AI QA Checklist",
  "Storyboard view",
  "Remix & revisions",
];

export default function Block() {
  const [isYearly, setIsYearly] = useState(true);
  const [downgradeTarget, setDowngradeTarget] = useState(null); // a PLAN object or null
  const user = useCurrentUser();
  const { data, status } = useRecords({ select, count: 1 });

  const userRecord = data?.pages?.[0]?.items?.[0];

  // urls[Tier][Interval] -> Stripe Payment Link (non-trial)
  const urls = userRecord
    ? {
        Creator: { Monthly: userRecord.fields.creatorMonthly, Yearly: userRecord.fields.creatorYearly },
        Crew:    { Monthly: userRecord.fields.crewMonthly,    Yearly: userRecord.fields.crewYearly },
        Studio:  { Monthly: userRecord.fields.studioMonthly,  Yearly: userRecord.fields.studioYearly },
      }
    : {};

  // Current plan: linked record array on users.plan -> first item's id
  const planLinks = userRecord?.fields?.plan;
  const currentPlanId = Array.isArray(planLinks) ? planLinks[0]?.id : null;
  const currentPricing = PRICING_ROWS.find((r) => r.id === currentPlanId);
  const currentTier = currentPricing?.tier || null;
  const currentRank = currentPricing?.rank ?? null;

  const goTo = (tier) => {
    const interval = isYearly ? "Yearly" : "Monthly";
    const url = urls[tier]?.[interval];
    if (url) window.location.href = url;
  };

  const handleSelect = (plan) => {
    if (currentTier === plan.tier) return; // no-op on current
    if (currentRank !== null && plan.rank < currentRank) {
      // Downgrade -> confirmation modal
      setDowngradeTarget(plan);
      return;
    }
    goTo(plan.tier);
  };

  const confirmDowngrade = () => {
    if (downgradeTarget) {
      const tier = downgradeTarget.tier;
      setDowngradeTarget(null);
      goTo(tier);
    }
  };

  if (status === "pending") {
    return (
      <div className="container py-12 text-center text-sm" style={{ color: "#6b7280" }}>
        Loading plans...
      </div>
    );
  }

  return (
    <div className="pu-root">
      <Style />
      <div className="container py-12">
        <div className="content text-center">
          <div className="pu-eyebrow">Manage your plan</div>
          <h1 className="pu-title">Switch plan any time</h1>
          <p className="pu-sub">
            {currentTier
              ? <>You're currently on <strong>{currentTier}</strong>. Upgrade for more capacity, or change interval to save.</>
              : "Pick the plan that fits how you're working today."}
          </p>

          <IntervalToggle isYearly={isYearly} onChange={setIsYearly} />

          <div className="pu-grid">
            {PLANS.map((p) => {
              const isCurrent = currentTier === p.tier;
              const monthlyEquivalent = isYearly ? Math.round(p.yearly / 12) : p.monthly;

              return (
                <div
                  key={p.tier}
                  className={
                    "pu-card" +
                    (p.popular && !isCurrent ? " pu-card-popular" : "") +
                    (isCurrent ? " pu-card-current" : "")
                  }
                >
                  {p.popular && !isCurrent && <div className="pu-banner pu-banner-popular">Most popular</div>}
                  {isCurrent && <div className="pu-banner pu-banner-current">Your current plan</div>}

                  <div className="pu-card-body">
                    <div className="pu-tier">{p.tier}</div>
                    <p className="pu-desc">{p.desc}</p>

                    <div className="pu-price-row">
                      <span className="pu-price">${monthlyEquivalent}</span>
                      <span className="pu-per">/mo</span>
                    </div>
                    <div className="pu-billed">
                      {isYearly ? `Billed $${p.yearly.toLocaleString()} annually` : "Billed monthly"}
                    </div>

                    <div className="pu-saves">
                      <div className="pu-save">
                        <Clock className="w-3.5 h-3.5" />
                        Save {p.hoursSaved}
                      </div>
                    </div>

                    <ul className="pu-features">
                      {FEATURES(p).map((f) => (
                        <li key={f}>
                          <Check className="w-3.5 h-3.5" />
                          <span>{f}</span>
                        </li>
                      ))}
                    </ul>

                    <Button
                      onClick={() => handleSelect(p)}
                      disabled={isCurrent || !urls[p.tier]?.[isYearly ? "Yearly" : "Monthly"]}
                      className={"pu-cta" + (isCurrent ? " pu-cta-current" : "")}
                    >
                      {isCurrent
                        ? "Current plan"
                        : (currentRank !== null && p.rank < currentRank)
                          ? `Downgrade to ${p.tier}`
                          : (currentRank !== null && p.rank > currentRank)
                            ? `Upgrade to ${p.tier}`
                            : `Switch to ${p.tier}`}
                    </Button>
                  </div>
                </div>
              );
            })}
          </div>

          <div className="pu-trust">
            <span>Prorated automatically</span>
            <span className="pu-dot">·</span>
            <span>Change anytime</span>
            <span className="pu-dot">·</span>
            <span>Powered by Stripe</span>
          </div>
        </div>
      </div>

      {downgradeTarget && (
        <DowngradeModal
          current={PLANS.find((x) => x.tier === currentTier)}
          target={downgradeTarget}
          onClose={() => setDowngradeTarget(null)}
          onConfirm={confirmDowngrade}
        />
      )}
    </div>
  );
}

function IntervalToggle({ isYearly, onChange }) {
  return (
    <div className="pu-toggle-wrap">
      <div className="pu-toggle">
        <button onClick={() => onChange(false)} className={"pu-toggle-btn" + (!isYearly ? " on" : "")}>Monthly</button>
        <button onClick={() => onChange(true)}  className={"pu-toggle-btn" + ( isYearly ? " on" : "")}>
          Yearly
          <span className="pu-toggle-badge">Save ~17%</span>
        </button>
      </div>
    </div>
  );
}

function DowngradeModal({ current, target, onClose, onConfirm }) {
  if (!current || !target) return null;

  const lostHoursPerMonth = parseFloat(current.hoursSaved) - parseFloat(target.hoursSaved);
  const lostVideos = current.maxVideos - target.maxVideos;
  const lostWorkspaces = current.maxWorkspaces - target.maxWorkspaces;
  const lostSeats = current.maxUsers - target.maxUsers;

  return (
    <div className="pu-modal-bg" onClick={onClose}>
      <div className="pu-modal" onClick={(e) => e.stopPropagation()}>
        <button className="pu-modal-close" onClick={onClose} aria-label="Close">
          <X className="w-4 h-4" />
        </button>

        <div className="pu-modal-icon">
          <AlertTriangle className="w-6 h-6" />
        </div>
        <h2 className="pu-modal-title">Are you sure you want to downgrade?</h2>
        <p className="pu-modal-sub">
          You'll move from <strong>{current.tier}</strong> to <strong>{target.tier}</strong>.
          Here's what changes:
        </p>

        <ul className="pu-modal-list">
          {lostHoursPerMonth > 0 && (
            <li>
              <span className="pu-modal-bad">−{Math.round(lostHoursPerMonth)} hours / month back doing reviews manually</span>
            </li>
          )}
          {lostVideos > 0 && (
            <li>
              <span className="pu-modal-bad">−{lostVideos} videos / month</span>
              <span className="pu-modal-from">({current.maxVideos} → {target.maxVideos})</span>
            </li>
          )}
          {lostWorkspaces > 0 && (
            <li>
              <span className="pu-modal-bad">−{lostWorkspaces} {lostWorkspaces === 1 ? "workspace" : "workspaces"}</span>
              <span className="pu-modal-from">({current.maxWorkspaces} → {target.maxWorkspaces})</span>
            </li>
          )}
          {lostSeats > 0 && (
            <li>
              <span className="pu-modal-bad">−{lostSeats} {lostSeats === 1 ? "seat" : "seats"}</span>
              <span className="pu-modal-from">({current.maxUsers} → {target.maxUsers})</span>
            </li>
          )}
        </ul>

        <p className="pu-modal-note">
          Your changes take effect at your next billing date. Stripe handles the proration.
        </p>

        <div className="pu-modal-actions">
          <Button onClick={onClose} className="pu-modal-stay">Stay on {current.tier}</Button>
          <Button onClick={onConfirm} className="pu-modal-confirm">Continue downgrade</Button>
        </div>
      </div>
    </div>
  );
}

